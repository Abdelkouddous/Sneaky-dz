  file_change {
    absolute_path_uri: "file:///src/components/CheckoutModal.tsx"
    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "import React, { useState } from \'react\';\nimport { motion, AnimatePresence } from \'motion/react\';\nimport { CreditCard, CheckCircle2, ShieldCheck, Lock, ArrowRight, X, AlertCircle } from \'lucide-react\';\nimport { CartItem, Order, OrderItem, Product } from \'../types\';\n\ninterface CheckoutModalProps {\n  isOpen: boolean;\n  onClose: () => void;\n  cart: CartItem[];\n  onOrderSuccess: (order: Order) => void;\n  clearCart: () => void;\n}\n\nexport default function CheckoutModal({ isOpen, onClose, cart, onOrderSuccess, clearCart }: CheckoutModalProps) {\n  // Checkout progress steps: \'details\' | \'payment\' | \'processing\'\n  const [step, setStep] = useState<\'details\' | \'payment\' | \'processing\'>(\'details\');\n\n  // Customer Shipping & Billing State\n  const [fullName, setFullName] = useState(\'\');\n  const [email, setEmail] = useState(\'\');\n  const [phone, setPhone] = useState(\'\');\n  const [address, setAddress] = useState(\'\');\n  const [city, setCity] = useState(\'Algiers\');\n  const [postalCode, setPostalCode] = useState(\'\');\n\n  // Rental Duration configurations (default 3 days for garments in cart)\n  const [rentalDate, setRentalDate] = useState(() => {\n    const today = new Date();\n    today.setDate(today.getDate() + 2); // 2 days in advance minimum\n    return today.toISOString().split(\'T\')[0];\n  });\n  const [rentalDays, setRentalDays] = useState<number>(3);\n\n  // Chosen Algerian Payment Method\n  const [paymentType, setPaymentType] = useState<\'CIB\' | \'EDAHABIA\' | \'VISA_MC\'>(\'EDAHABIA\');\n  \n  // Card Details\n  const [cardNumber, setCardNumber] = useState(\'\');\n  const [cardHolder, setCardHolder] = useState(\'\');\n  const [cardExpiry, setCardExpiry] = useState(\'\');\n  const [cardCVV, setCardCVV] = useState(\'\');\n  const [errorMessage, setErrorMessage] = useState(\'\');\n\n  // Calculation helpers\n  const getSubtotal = () => {\n    return cart.reduce((acc, item) => {\n      if (item.type === \'buy\') {\n        return acc + item.product.price * item.quantity;\n      } else {\n        const rPrice = item.product.rentPrice || 0;\n        return acc + rPrice * rentalDays * item.quantity;\n      }\n    }, 0);\n  };\n\n  const getShippingFee = () => {\n    // Algiers shipping is cheap, other regions a bit higher\n    return city === \'Algiers\' ? 500 : 900;\n  };\n\n  const getGrandTotal = () => {\n    return getSubtotal() + getShippingFee();\n  };\n\n  const formatDZD = (num: number) => {\n    return new Intl.NumberFormat(\'fr-DZ\', { style: \'currency\', currency: \'DZD\', maximumFractionDigits: 0 }).format(num);\n  };\n\n  // Live card number mask/formatter\n  const handleCardNumberChange = (val: string) => {\n    const cleaned = val.replace(/\\D/g, \'\').slice(0, 16);\n    const matches = cleaned.match(/\\d{4,16}/g);\n    let formatted = \'\';\n    if (matches && matches[0]) {\n      const parts = matches[0].match(/.{1,4}/g);\n      if (parts) {\n        formatted = parts.join(\' \');\n      }\n    } else {\n      formatted = cleaned;\n    }\n    setCardNumber(formatted);\n  };\n\n  // Live expiry formatter (MM/YY)\n  const handleExpiryChange = (val: string) => {\n    const cleaned = val.replace(/\\D/g, \'\').slice(0, 4);\n    if (cleaned.length >= 2) {\n      setCardExpiry(`${cleaned.slice(0, 2)}/${cleaned.slice(2, 4)}`);\n    } else {\n      setCardExpiry(cleaned);\n    }\n  };\n\n  const handleNextStep = (e: React.FormEvent) => {\n    e.preventDefault();\n    if (!fullName || !email || !phone || !address || !postalCode) {\n      setErrorMessage(\'Please complete all contact and shipping address details first.\');\n      return;\n    }\n    setErrorMessage(\'\');\n    setStep(\'payment\');\n  };\n\n  // Submit payment order trigger\n  const handlePaymentSubmit = (e: React.FormEvent) => {\n    e.preventDefault();\n    \n    // Simple custom validation\n    if (cardNumber.replace(/\\s/g, \'\').length !== 16) {\n      setErrorMessage(\'Please enter a valid 16-digit card number.\');\n      return;\n    }\n    if (!cardHolder) {\n      setErrorMessage(\'Please type the cardholder name.\');\n      return;\n    }\n    if (cardExpiry.length !== 5) {\n      setErrorMessage(\'Enter expiry date in MM/YY format.\');\n      return;\n    }\n    if (cardCVV.length < 3) {\n      setErrorMessage(\'Please enter card pin security code.\');\n      return;\n    }\n\n    setErrorMessage(\'\');\n    setStep(\'processing\');\n\n    // Simulate Payment Gateway SATIM connection (3 seconds delay)\n    setTimeout(() => {\n      const newOrderItems: OrderItem[] = cart.map((item) => ({\n        productId: item.product.id,\n        productName: item.product.name,\n        image: item.product.image,\n        category: item.product.category,\n        quantity: item.quantity,\n        type: item.type,\n        price: item.type === \'buy\' ? item.product.price : (item.product.rentPrice || 0),\n        durationDays: item.type === \'rent\' ? rentalDays : undefined,\n      }));\n\n      const rentalEnd = () => {\n        if (cart.some(item => item.type === \'rent\')) {\n          const sDate = new Date(rentalDate);\n          sDate.setDate(sDate.getDate() + rentalDays);\n          return sDate.toISOString().split(\'T\')[0];\n        }\n        return undefined;\n      };\n\n      const mockOrder: Order = {\n        id: `DZ-${Math.floor(100000 + Math.random() * 900000)}`,\n        customerName: fullName,\n        customerEmail: email,\n        customerPhone: phone,\n        address: address,\n        city: city,\n        postalCode: postalCode,\n        items: newOrderItems,\n        total: getGrandTotal(),\n        date: new Date().toLocaleDateString(\'fr-DZ\', { year: \'numeric\', month: \'long\', day: \'numeric\' }),\n        status: \'pending\',\n        paymentMethod: paymentType,\n        paymentStatus: \'paid\',\n        transactionId: `TXN-${paymentType}-${Math.floor(100000000 + Math.random() * 900000000)}`,\n        rentalStartDate: cart.some(item => item.type === \'rent\') ? rentalDate : undefined,\n        rentalEndDate: rentalEnd(),\n      };\n\n      onOrderSuccess(mockOrder);\n      clearCart();\n    }, 3200);\n  };\n\n  const hasRentals = cart.some(item => item.type === \'rent\');\n\n  if (!isOpen) return null;\n\n  return (\n    <div className=\"fixed inset-0 bg-stone-950/65 backdrop-blur-xs z-50 flex items-center justify-center p-4\">\n      <motion.div\n        initial={{ opacity: 0, scale: 0.98, y: 10 }}\n        animate={{ opacity: 1, scale: 1, y: 0 }}\n        className=\"bg-white rounded-3xl max-w-4xl w-full max-h-[92vh] flex flex-col overflow-hidden shadow-2xl border border-stone-200\"\n        id=\"checkout-gateway-modal\"\n      >\n        \n        {/* Header bar banner */}\n        <div className=\"bg-amber-800 text-stone-50 px-6 py-4 flex items-center justify-between border-b border-amber-900/10\">\n          <div className=\"flex items-center gap-2\">\n            <Lock className=\"w-4 h-4 text-amber-300\" />\n            <h3 className=\"font-serif font-bold text-lg text-white\">Satisfying Checkout & Payment Tunnel</h3>\n          </div>\n          {step !== \'processing\' && (\n            <button\n              onClick={onClose}\n              className=\"text-amber-100 hover:text-white bg-amber-900/30 p-2 rounded-full hover:bg-amber-900/55 transition-colors cursor-pointer\"\n            >\n              <X className=\"w-4 h-4\" />\n            </button>\n          )}\n        </div>\n\n        {/* Multi-step indicator bar */}\n        <div className=\"bg-stone-50 border-b border-stone-150 px-8 py-3 flex gap-4 text-xs font-semibold justify-center\">\n          <div className=\"flex items-center gap-2\">\n            <span className={`w-5 h-5 rounded-full flex items-center justify-center text-[10px] ${\n              step === \'details\' ? \'bg-amber-800 text-white\' : \'bg-emerald-600 text-white\'\n            }`}>\n              {step === \'details\' ? \'1\' : \'\342\234\223\'}\n            </span>\n            <span className={step === \'details\' ? \'text-amber-900\' : \'text-stone-400\'}>\n              Shipping & Rental Dates\n            </span>\n          </div>\n          <span className=\"text-stone-300\">/</span>\n          <div className=\"flex items-center gap-2\">\n            <span className={`w-5 h-5 rounded-full flex items-center justify-center text-[10px] ${\n              step === \'payment\' ? \'bg-amber-800 text-white\' : step === \'processing\' ? \'bg-amber-800 text-white\' : \'bg-stone-200 text-stone-500\'\n            }`}>\n              2\n            </span>\n            <span className={step === \'payment\' ? \'text-amber-900\' : \'text-stone-400\'}>\n              SATIM Secure Gateway\n            </span>\n          </div>\n        </div>\n\n        {/* Modal Main body */}\n        <div className=\"overflow-y-auto flex-1 grid grid-cols-1 lg:grid-cols-12\">\n          \n          {/* Step content panel */}\n          <div className=\"lg:col-span-7 p-8 border-r border-stone-100\">\n            {errorMessage && (\n              <div className=\"bg-red-50 text-red-700 p-3.5 rounded-xl border border-red-150 text-xs font-semibold flex items-center gap-2 mb-6\">\n                <AlertCircle className=\"w-4 h-4 shrink-0\" />\n                <span>{errorMessage}</span>\n              </div>\n            )}\n\n            {step === \'details\' && (\n              <form onSubmit={handleNextStep} id=\"checkout-details-form\">\n                <h4 className=\"font-serif text-lg font-bold text-stone-900 mb-5\">\n                  1. Algerian Order Fulfillment Information\n                </h4>\n                \n                <div className=\"space-y-4\">\n                  <div>\n                    <label className=\"block text-[11px] font-semibold uppercase tracking-wider text-stone-400 mb-1\">\n                      Full Name\n                    </label>\n                    <input\n                      type=\"text\"\n                      required\n                      placeholder=\"e.g., Slimane Bencherif\"\n                      value={fullName}\n                      onChange={(e) => setFullName(e.target.value)}\n                      className=\"w-full bg-stone-50 border border-stone-200 rounded-xl px-4 py-2.5 text-xs focus:outline-none focus:border-amber-600 text-stone-800\"\n                    />\n                  </div>\n\n                  <div className=\"grid grid-cols-2 gap-4\">\n                    <div>\n                      <label className=\"block text-[11px] font-semibold uppercase tracking-wider text-stone-400 mb-1\">\n                        Email Address\n                      </label>\n                      <input\n                        type=\"email\"\n                        required\n                        placeholder=\"slimane.b@gmail.com\"\n                        value={email}\n                        onChange={(e) => setEmail(e.target.value)}\n                        className=\"w-full bg-stone-50 border border-stone-200 rounded-xl px-4 py-2.5 text-xs focus:outline-none focus:border-amber-600 text-stone-800\"\n                      />\n                    </div>\n                    <div>\n                      <label className=\"block text-[11px] font-semibold uppercase tracking-wider text-stone-400 mb-1\">\n                        Mobile Phone (Algeria)\n                      </label>\n                      <input\n                        type=\"tel\"\n                        required\n                        placeholder=\"e.g., +213 550 45 67 89\"\n                        value={phone}\n                        onChange={(e) => setPhone(e.target.value)}\n                        className=\"w-full bg-stone-50 border border-stone-200 rounded-xl px-4 py-2.5 text-xs focus:outline-none focus:border-amber-600 text-stone-800\"\n                      />\n                    </div>\n                  </div>\n\n                  <div>\n                    <label className=\"block text-[11px] font-semibold uppercase tracking-wider text-stone-400 mb-1\">\n                      Strict Shipping Street Address\n                    </label>\n                    <input\n                      type=\"text\"\n                      required\n                      placeholder=\"e.g., 20 Rue Didouche Mourad, Apt 4\"\n                      value={address}\n                      onChange={(e) => setAddress(e.target.value)}\n                      className=\"w-full bg-stone-50 border border-stone-200 rounded-xl px-4 py-2.5 text-xs focus:outline-none focus:border-amber-600 text-stone-800\"\n                    />\n                  </div>\n\n                  <div className=\"grid grid-cols-2 gap-4\">\n                    <div>\n                      <label className=\"block text-[11px] font-semibold uppercase tracking-wider text-stone-400 mb-1\">\n                        Fulfillment City\n                      </label>\n                      <select\n                        value={city}\n                        onChange={(e) => setCity(e.target.value)}\n                        className=\"w-full bg-stone-50 border border-stone-200 rounded-xl px-4 py-2.5 text-xs focus:outline-none focus:border-amber-600 text-stone-800\"\n                      >\n                        <option value=\"Algiers\">Algiers (Centre / Mitidja)</option>\n                        <option value=\"Oran\">Oran (El Bahia)</option>\n                        <option value=\"Constantine\">Constantine (Bridges City)</option>\n                        <option value=\"Tlemcen\">Tlemcen (Lalla Setti)</option>\n                        <option value=\"Tizi Ouzou\">Tizi Ouzou (Kabylie)</option>\n                        <option value=\"Ghardaia\">Ghardaia (Mzab valley)</option>\n                        <option value=\"Annaba\">Annaba</option>\n                        <option value=\"Setif\">Setif</option>\n                      </select>\n                    </div>\n                    <div>\n                      <label className=\"block text-[11px] font-semibold uppercase tracking-wider text-stone-400 mb-1\">\n                        Algerian Postal Code\n                      </label>\n                      <input\n                        type=\"text\"\n                        required\n                        placeholder=\"e.g., 16000\"\n                        value={postalCode}\n                        onChange={(e) => setPostalCode(e.target.value)}\n                        className=\"w-full bg-stone-50 border border-stone-200 rounded-xl px-4 py-2.5 text-xs focus:outline-none focus:border-amber-600 text-stone-800\"\n                      />\n                    </div>\n                  </div>\n                </div>\n\n                {/* Garment Rental parameters */}\n                {hasRentals && (\n                  <div className=\"bg-emerald-50/50 border border-emerald-150 rounded-2xl p-5 mt-6\">\n                    <h5 className=\"font-serif text-sm font-bold text-emerald-900 flex items-center gap-1.5 mb-3.5\">\n                      \360\237\223\205 Configure Heritage Wear Rent Range\n                    </h5>\n                    <p className=\"text-[11px] text-emerald-800 mb-4 font-light\">\n                      At least one clothing or jewelry product is selected to rent. Pick your starting date and period. Daily rentals include fully dry-cleaned garments.\n                    </p>\n                    <div className=\"grid grid-cols-2 gap-4\">\n                      <div>\n                        <label className=\"block text-[10px] font-semibold uppercase tracking-wider text-stone-400 mb-1\">\n                          Delivery Start Date\n                        </label>\n                        <input\n                          type=\"date\"\n                          value={rentalDate}\n                          min={new Date().toISOString().split(\'T\')[0]}\n                          onChange={(e) => setRentalDate(e.target.value)}\n                          className=\"w-full bg-white border border-stone-200 rounded-lg px-3 py-2 text-xs text-stone-850\"\n                        />\n                      </div>\n                      <div>\n                        <label className=\"block text-[10px] font-semibold uppercase tracking-wider text-stone-400 mb-1\">\n                          Rental Length (days)\n                        </label>\n                        <select\n                          value={rentalDays}\n                          onChange={(e) => setRentalDays(Number(e.target.value))}\n                          className=\"w-full bg-white border border-stone-200 rounded-lg px-3 py-2 text-xs text-stone-850\"\n                        >\n                          <option value=\"3\">3 Days (Ceremony basic)</option>\n                          <option value=\"5\">5 Days (Wedding length)</option>\n                          <option value=\"7\">7 Days (Full week festival)</option>\n                          <option value=\"14\">14 Days (Extended vacation)</option>\n                        </select>\n                      </div>\n                    </div>\n                  </div>\n                )}\n\n                <div className=\"mt-8 flex justify-end\">\n                  <button\n                    type=\"submit\"\n                    className=\"bg-amber-800 hover:bg-amber-900 text-white font-bold text-xs tracking-wider py-3 px-6 rounded-xl flex items-center gap-1.5 transition-all outline-none cursor-pointer\"\n                  >\n                    Proceed to Payment Gate\n                    <ArrowRight className=\"w-4 h-4\" />\n                  </button>\n                </div>\n              </form>\n            )}\n\n            {step === \'payment\' && (\n              <form onSubmit={handlePaymentSubmit} id=\"checkout-payment-form\">\n                <h4 className=\"font-serif text-lg font-bold text-stone-900 mb-4\">\n                  2. Choose Algerian Payment Gateway Client\n                </h4>\n\n                {/* Gateway visual selector */}\n                <div className=\"grid grid-cols-3 gap-3 mb-6\">\n                  {/* EDAHABIA */}\n                  <button\n                    type=\"button\"\n                    onClick={() => {\n                      setPaymentType(\'EDAHABIA\');\n                      setCardNumber(\'\');\n                    }}\n                    className={`flex flex-col items-center justify-center p-4 rounded-xl border transition-all cursor-pointer ${\n                      paymentType === \'EDAHABIA\'\n                        ? \'border-amber-600 bg-amber-50 shadow-xs\'\n                        : \'border-stone-200 bg-stone-50 hover:bg-stone-100\'\n                    }`}\n                  >\n                    <span className=\"text-yellow-600 text-xs font-extrabold uppercase tracking-wide\">\n                      EDAHABIA\n                    </span>\n                    <span className=\"text-[9px] text-stone-500 mt-1\">Alg\303\251rie Poste</span>\n                  </button>\n\n                  {/* CIB */}\n                  <button\n                    type=\"button\"\n                    onClick={() => {\n                      setPaymentType(\'CIB\');\n                      setCardNumber(\'\');\n                    }}\n                    className={`flex flex-col items-center justify-center p-4 rounded-xl border transition-all cursor-pointer ${\n                      paymentType === \'CIB\'\n                        ? \'border-emerald-600 bg-emerald-50 shadow-xs\'\n                        : \'border-stone-200 bg-stone-50 hover:bg-stone-100\'\n                    }`}\n                  >\n                    <span className=\"text-emerald-700 text-xs font-extrabold uppercase tracking-wide\">\n                      CIB CARD\n                    </span>\n                    <span className=\"text-[9px] text-stone-500 mt-1\">SATIM Interbank</span>\n                  </button>\n\n                  {/* VISA/MC */}\n                  <button\n                    type=\"button\"\n                    onClick={() => {\n                      setPaymentType(\'VISA_MC\');\n                      setCardNumber(\'\');\n                    }}\n                    className={`flex flex-col items-center justify-center p-4 rounded-xl border transition-all cursor-pointer ${\n                      paymentType === \'VISA_MC\'\n                        ? \'border-stone-800 bg-stone-50 shadow-xs\'\n                        : \'border-stone-200 bg-stone-50 hover:bg-stone-100\'\n                    }`}\n                  >\n                    <span className=\"text-stone-800 text-xs font-extrabold uppercase tracking-wide\">\n                      CREDIT CARD\n                    </span>\n                    <span className=\"text-[9px] text-stone-500 mt-1\">International Visa/MC</span>\n                  </button>\n                </div>\n\n                {/* Live visual Card layout! */}\n                <div className=\"mb-6\">\n                  <div className={`p-6 rounded-2xl text-white shadow-lg transition-all relative overflow-hidden aspect-[1.8/1] max-w-sm mx-auto ${\n                    paymentType === \'EDAHABIA\'\n                      ? \'bg-gradient-to-tr from-amber-600 via-amber-500 to-yellow-500\'\n                      : paymentType === \'CIB\'\n                      ? \'bg-gradient-to-tr from-indigo-900 to-emerald-700\'\n                      : \'bg-gradient-to-tr from-stone-900 to-stone-850\'\n                  }`}>\n                    {/* Metallic card chip */}\n                    <div className=\"w-10 h-8 bg-yellow-400/80 rounded-sm mb-6 border border-yellow-300\"></div>\n\n                    {/* Logo overlays based on type */}\n                    {paymentType === \'EDAHABIA\' && (\n                      <span className=\"absolute top-6 right-6 font-serif font-extrabold italic text-sm tracking-wide bg-stone-950/20 px-3 py-1 rounded\">\n                        Alg\303\251rie Poste \342\200\242 \330\247\331\204\330\260\331\207\330\250\331\212\330\251\n                      </span>\n                    )}\n                    {paymentType === \'CIB\' && (\n                      <span className=\"absolute top-6 right-6 font-sans font-extrabold text-sm tracking-wide bg-stone-50/15 px-3 py-1 rounded\">\n                        CIB SATIM\n                      </span>\n                    )}\n                    {paymentType === \'VISA_MC\' && (\n                      <span className=\"absolute top-6 right-6 font-mono font-bold text-xs tracking-wide border border-white/20 px-3 py-1 rounded\">\n                        INTERNATIONAL CARD\n                      </span>\n                    )}\n\n                    {/* Live values */}\n                    <div className=\"font-mono text-lg md:text-xl font-bold tracking-[0.2em] mb-4 text-center\">\n                      {cardNumber || \'\342\200\242\342\200\242\342\200\242\342\200\242 \342\200\242\342\200\242\342\200\242\342\200\242 \342\200\242\342\200\242\342\200\242\342\200\242 \342\200\242\342\200\242\342\200\242\342\200\242\'}\n                    </div>\n\n                    <div className=\"flex justify-between items-end mt-4\">\n                      <div>\n                        <span className=\"text-[9px] text-white/60 block uppercase tracking-wider\">Card Holder</span>\n                        <span className=\"font-semibold text-sm h-5 block uppercase font-mono tracking-wide\">\n                          {cardHolder || \'Your Name\'}\n                        </span>\n                      </div>\n                      <div>\n                        <span className=\"text-[9px] text-white/60 block uppercase tracking-wider\">Expires</span>\n                        <span className=\"font-mono text-sm h-5 block\">\n                          {cardExpiry || \'MM/YY\'}\n                        </span>\n                      </div>\n                    </div>\n                  </div>\n                </div>\n\n                {/* Numeric Card Forms */}\n                <div className=\"space-y-4\">\n                  <div>\n                    <label className=\"block text-[11px] font-semibold uppercase tracking-wider text-stone-400 mb-1\">\n                      {paymentType === \'EDAHABIA\' ? \'16-Digit Gold Card Number\' : paymentType === \'CIB\' ? \'16-Digit CIB Card Code\' : \'Credit Card Number\'}\n                    </label>\n                    <input\n                      type=\"text\"\n                      required\n                      placeholder=\"e.g., 5220 1234 5678 9012\"\n                      value={cardNumber}\n                      onChange={(e) => handleCardNumberChange(e.target.value)}\n                      className=\"w-full bg-stone-50 border border-stone-200 rounded-xl px-4 py-2.5 text-xs focus:outline-none focus:border-amber-600 font-mono text-stone-850\"\n                    />\n                  </div>\n\n                  <div>\n                    <label className=\"block text-[11px] font-semibold uppercase tracking-wider text-stone-400 mb-1\">\n                      Card Holder Name (Exact Name on Card)\n                    </label>\n                    <input\n                      type=\"text\"\n                      required\n                      placeholder=\"e.g., SLIMANE BENCHERIF\"\n                      value={cardHolder}\n                      onChange={(e) => setCardHolder(e.target.value)}\n                      className=\"w-full bg-stone-50 border border-stone-200 rounded-xl px-4 py-2.5 text-xs focus:outline-none focus:border-amber-600 font-mono text-stone-850 uppercase\"\n                    />\n                  </div>\n\n                  <div className=\"grid grid-cols-2 gap-4\">\n                    <div>\n                      <label className=\"block text-[11px] font-semibold uppercase tracking-wider text-stone-400 mb-1\">\n                        Expiry Date\n                      </label>\n                      <input\n                        type=\"text\"\n                        required\n                        placeholder=\"MM/YY\"\n                        value={cardExpiry}\n                        onChange={(e) => handleExpiryChange(e.target.value)}\n                        className=\"w-full bg-stone-50 border border-stone-200 rounded-xl px-4 py-2.5 text-xs focus:outline-none focus:border-amber-600 font-mono text-stone-850\"\n                      />\n                    </div>\n                    <div>\n                      <label className=\"block text-[11px] font-semibold uppercase tracking-wider text-stone-400 mb-1\">\n                        Security PIN / CVV\n                      </label>\n                      <input\n                        type=\"password\"\n                        required\n                        maxLength={4}\n                        placeholder=\"\342\200\242\342\200\242\342\200\242\"\n                        value={cardCVV}\n                        onChange={(e) => setCardCVV(e.target.value.replace(/\\D/g, \'\'))}\n                        className=\"w-full bg-stone-50 border border-stone-200 rounded-xl px-4 py-2.5 text-xs focus:outline-none focus:border-amber-600 font-mono text-stone-850\"\n                      />\n                    </div>\n                  </div>\n                </div>\n\n                <div className=\"mt-8 flex justify-between\">\n                  <button\n                    type=\"button\"\n                    onClick={() => {\n                      setStep(\'details\');\n                      setErrorMessage(\'\');\n                    }}\n                    className=\"border border-stone-300 font-bold text-xs px-5 py-3 rounded-xl text-stone-600 hover:bg-stone-50 transition-all cursor-pointer\"\n                  >\n                    Back to Shipping\n                  </button>\n                  <button\n                    type=\"submit\"\n                    className=\"bg-emerald-700 hover:bg-emerald-800 text-white font-bold text-xs tracking-wider py-3 px-6 rounded-xl flex items-center gap-2 transition-all outline-none cursor-pointer\"\n                  >\n                    <ShieldCheck className=\"w-4 h-4 text-emerald-300\" />\n                    Authorize payment {formatDZD(getGrandTotal())}\n                  </button>\n                </div>\n              </form>\n            )}\n\n            {step === \'processing\' && (\n              <div className=\"py-16 text-center\" id=\"satim-processing-tunnel\">\n                <div className=\"relative w-16 h-16 mx-auto mb-8\">\n                  <div className=\"absolute inset-0 rounded-full border-4 border-amber-200 animate-pulse\"></div>\n                  <div className=\"absolute inset-0 rounded-full border-4 border-amber-800 border-t-transparent animate-spin\"></div>\n                </div>\n\n                <h4 className=\"font-serif text-xl font-bold text-stone-900 mb-2\">\n                  Contacting Secure SATIM Gateway...\n                </h4>\n                <p className=\"text-xs text-stone-500 max-w-sm mx-auto leading-relaxed mb-6\">\n                  Your payment authorization request is encrypted using standard SSL/TLS tunnels. Connecting with {paymentType === \'EDAHABIA\' ? \'Alg\303\251rie Poste (Baridimobs)\' : paymentType === \'CIB\' ? \'national SATIM interbanks\' : \'international merchant banks\'} gateway...\n                </p>\n\n                <div className=\"bg-stone-50 border border-stone-150 inline-flex flex-col gap-2 p-4 rounded-2xl max-w-xs text-left text-[11px] text-stone-500 font-mono\">\n                  <div className=\"flex justify-between\">\n                    <span>Merchant Token:</span>\n                    <span className=\"font-semibold text-emerald-600 text-[10px]\">REGISTERED_LIVE</span>\n                  </div>\n                  <div className=\"flex justify-between\">\n                    <span>Amount Encoded:</span>\n                    <span className=\"font-semibold text-stone-800\">{formatDZD(getGrandTotal())}</span>\n                  </div>\n                  <div className=\"flex justify-between\">\n                    <span>SATIM Secure DNS:</span>\n                    <span className=\"text-stone-400\">auth.epay.satim.dz</span>\n                  </div>\n                </div>\n              </div>\n            )}\n          </div>\n\n          {/* Cart items summary breakdown */}\n          <div className=\"lg:col-span-5 p-8 bg-stone-50 flex flex-col justify-between\">\n            <div>\n              <h4 className=\"font-serif text-base font-bold text-stone-900 mb-4 pb-3 border-b border-stone-200\">\n                Traditional Cart Summary\n              </h4>\n\n              {/* Items feed list */}\n              <div className=\"space-y-4 max-h-[40vh] overflow-y-auto mb-6 pr-2\">\n                {cart.map((item, idx) => (\n                  <div key={idx} className=\"flex gap-3 text-xs align-start\">\n                    <img\n                      src={item.product.image}\n                      alt={item.product.name}\n                      referrerPolicy=\"no-referrer\"\n                      className=\"w-12 h-12 rounded-lg object-cover border border-stone-150 shrink-0\"\n                    />\n                    <div className=\"flex-1 min-w-0\">\n                      <h5 className=\"font-semibold text-stone-800 truncate font-serif\">{item.product.name}</h5>\n                      <div className=\"flex gap-1.5 items-center text-stone-400 text-[10px] mt-0.5\">\n                        <span className=\"bg-stone-200/80 px-1.5 py-0.5 rounded text-stone-600 capitalize font-medium\">\n                          Qty: {item.quantity}\n                        </span>\n                        <span>\342\200\242</span>\n                        <span className={`px-1.5 py-0.5 rounded font-bold ${\n                          item.type === \'rent\' ? \'bg-emerald-50 text-emerald-700\' : \'bg-amber-50 text-amber-700\'\n                        }`}>\n                          {item.type === \'rent\' ? `Rented ${rentalDays}d` : \'Purchased\'}\n                        </span>\n                      </div>\n                    </div>\n                    <div className=\"text-right font-mono font-bold text-stone-800 shrink-0 font-xs\">\n                      {item.type === \'buy\'\n                        ? formatDZD(item.product.price * item.quantity)\n                        : formatDZD((item.product.rentPrice || 0) * rentalDays * item.quantity)}\n                    </div>\n                  </div>\n                ))}\n              </div>\n            </div>\n\n            {/* Price Calculations Card */}\n            <div className=\"border-t border-stone-200 pt-5 space-y-2.5\">\n              <div className=\"flex justify-between text-xs text-stone-500\">\n                <span>Subtotal ({cart.length} items):</span>\n                <span className=\"font-mono font-semibold text-stone-800\">{formatDZD(getSubtotal())}</span>\n              </div>\n              <div className=\"flex justify-between text-xs text-stone-500\">\n                <span>Shipping via National EMS/Yalidine:</span>\n                <span className=\"font-mono font-semibold text-stone-800\">{formatDZD(getShippingFee())}</span>\n              </div>\n              {hasRentals && (\n                <div className=\"flex justify-between text-xs text-emerald-700\">\n                  <span>Rental dry-cleaning fee:</span>\n                  <span className=\"font-sans font-bold\">FREE (Heritage Promo)</span>\n                </div>\n              )}\n              <div className=\"flex justify-between text-xs text-stone-500\">\n                <span>Platform Security Tax (SATIM):</span>\n                <span className=\"font-sans text-[11px] text-emerald-600 font-semibold uppercase\">0% (Vat Exempt)</span>\n              </div>\n\n              <div className=\"flex justify-between text-sm font-bold text-stone-950 pt-3 border-t border-dashed border-stone-200\">\n                <span>Total Payment:</span>\n                <span className=\"font-mono text-base text-amber-800\">{formatDZD(getGrandTotal())}</span>\n              </div>\n\n              <div className=\"bg-stone-100 p-3 rounded-lg flex items-center gap-1.5 text-[10px] text-stone-500 mt-4 leading-normal\">\n                <ShieldCheck className=\"w-4 h-4 text-amber-600 shrink-0\" />\n                <span>Secured end-to-end by SATIM. Refund guarantees provided according to Algerian Commerce protection laws.</span>\n              </div>\n            </div>\n\n          </div>\n        </div>\n      </motion.div>\n    </div>\n  );\n}\n"
    }
