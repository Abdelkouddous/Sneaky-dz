      target_content: "            {step === \'processing\' && (\n              <div className=\"py-16 text-center\" id=\"satim-processing-tunnel\">\n                <div className=\"relative w-16 h-16 mx-auto mb-8\">\n                  <div className=\"absolute inset-0 rounded-full border-4 border-amber-200 animate-pulse\"></div>\n                  <div className=\"absolute inset-0 rounded-full border-4 border-amber-800 border-t-transparent animate-spin\"></div>\n                </div>\n\n                <h4 className=\"font-serif text-xl font-bold text-stone-900 mb-2\">\n                  Contacting Secure SATIM Gateway...\n                </h4>\n                <p className=\"text-xs text-stone-500 max-w-sm mx-auto leading-relaxed mb-6\">\n                  Your payment authorization request is encrypted using standard SSL/TLS tunnels. Connecting with {paymentType === \'EDAHABIA\' ? \'Alg\303\251rie Poste (Baridimobs)\' : paymentType === \'CIB\' ? \'national SATIM interbanks\' : \'international merchant banks\'} gateway...\n                </p>\n\n                <div className=\"bg-stone-50 border border-stone-150 inline-flex flex-col gap-2 p-4 rounded-2xl max-w-xs text-left text-[11px] text-stone-500 font-mono\">\n                  <div className=\"flex justify-between\">\n                    <span>Merchant Token:</span>\n                    <span className=\"font-semibold text-emerald-600 text-[10px]\">REGISTERED_LIVE</span>\n                  </div>\n                  <div className=\"flex justify-between\">\n                    <span>Amount Encoded:</span>\n                    <span className=\"font-semibold text-stone-800\">{formatDZD(getGrandTotal())}</span>\n                  </div>\n                  <div className=\"flex justify-between\">\n                    <span>SATIM Secure DNS:</span>\n                    <span className=\"text-stone-400\">auth.epay.satim.dz</span>\n                  </div>\n                </div>\n              </div>\n            )}\n          </div>\n\n          {/* Cart items summary breakdown */}\n          <div className=\"lg:col-span-5 p-8 bg-stone-50 flex flex-col justify-between\">\n            <div>\n              <h4 className=\"font-serif text-base font-bold text-stone-900 mb-4 pb-3 border-b border-stone-200\">\n                Traditional Cart Summary\n              </h4>\n\n              {/* Items feed list */}\n              <div className=\"space-y-4 max-h-[40vh] overflow-y-auto mb-6 pr-2\">\n                {cart.map((item, idx) => (\n                  <div key={idx} className=\"flex gap-3 text-xs align-start\">\n                    <img\n                      src={item.product.image}\n                      alt={item.product.name}\n                      referrerPolicy=\"no-referrer\"\n                      className=\"w-12 h-12 rounded-lg object-cover border border-stone-150 shrink-0\"\n                    />\n                    <div className=\"flex-1 min-w-0\">\n                      <h5 className=\"font-semibold text-stone-800 truncate font-serif\">{item.product.name}</h5>\n                      <div className=\"flex gap-1.5 items-center text-stone-400 text-[10px] mt-0.5\">\n                        <span className=\"bg-stone-200/80 px-1.5 py-0.5 rounded text-stone-600 capitalize font-medium\">\n                          Qty: {item.quantity}\n                        </span>\n                        <span>\342\200\242</span>\n                        <span className={`px-1.5 py-0.5 rounded font-bold ${\n                          item.type === \'rent\' ? \'bg-emerald-50 text-emerald-700\' : \'bg-amber-50 text-amber-700\'\n                        }`}>\n                          {item.type === \'rent\' ? `Rented ${rentalDays}d` : \'Purchased\'}\n                        </span>\n                      </div>\n                    </div>\n                    <div className=\"text-right font-mono font-bold text-stone-800 shrink-0 font-xs\">\n                      {item.type === \'buy\'\n                        ? formatDZD(item.product.price * item.quantity)\n                        : formatDZD((item.product.rentPrice || 0) * rentalDays * item.quantity)}\n                    </div>\n                  </div>\n                ))}\n              </div>\n            </div>\n\n            {/* Price Calculations Card */}\n            <div className=\"border-t border-stone-200 pt-5 space-y-2.5\">\n              <div className=\"flex justify-between text-xs text-stone-500\">\n                <span>Subtotal ({cart.length} items):</span>\n                <span className=\"font-mono font-semibold text-stone-800\">{formatDZD(getSubtotal())}</span>\n              </div>\n              <div className=\"flex justify-between text-xs text-stone-500\">\n                <span>Shipping via National EMS/Yalidine:</span>\n                <span className=\"font-mono font-semibold text-stone-800\">{formatDZD(getShippingFee())}</span>\n              </div>\n              {hasRentals && (\n                <div className=\"flex justify-between text-xs text-emerald-700\">\n                  <span>Rental dry-cleaning fee:</span>\n                  <span className=\"font-bold\">FREE (Heritage Promo)</span>\n                </div>\n              )}\n              <div className=\"flex justify-between text-xs text-stone-500\">\n                <span>Platform Security Tax (SATIM):</span>\n                <span className=\"font-sans text-[11px] text-emerald-600 font-semibold uppercase\">0% (Vat Exempt)</span>\n              </div>\n\n              <div className=\"flex justify-between text-sm font-bold text-stone-950 pt-3 border-t border-dashed border-stone-200\">\n                <span>Total Payment:</span>\n                <span className=\"font-mono text-base text-amber-800\">{formatDZD(getGrandTotal())}</span>\n              </div>\n\n              <div className=\"bg-stone-100 p-3 rounded-lg flex items-center gap-1.5 text-[10px] text-stone-500 mt-4 leading-normal\">\n                <ShieldCheck className=\"w-4 h-4 text-amber-600 shrink-0\" />\n                <span>Secured end-to-end by SATIM. Refund guarantees provided according to Algerian Commerce protection laws.</span>\n              </div>\n            </div>\n\n          </div>\n        </div>\n      </motion.div>\n    </div>\n  );\n}"
      replacement_content: "            {step === \'processing\' && (\n              <div className=\"py-16 text-center\" id=\"satim-processing-tunnel\">\n                <div className=\"relative w-16 h-16 mx-auto mb-8\">\n                  <div className=\"absolute inset-0 rounded-full border-4 border-[#BC5449]/20 animate-pulse\"></div>\n                  <div className=\"absolute inset-0 rounded-full border-4 border-[#BC5449] border-t-transparent animate-spin\"></div>\n                </div>\n\n                <h4 className=\"font-serif text-xl font-medium text-[#2D2D2D] mb-2\">\n                  Contacting Secure SATIM Gateway...\n                </h4>\n                <p className=\"text-xs text-[#8B4513]/70 max-w-sm mx-auto leading-relaxed mb-6\">\n                  Your payment authorization request is encrypted using standard SSL/TLS tunnels. Connecting with {paymentType === \'EDAHABIA\' ? \'Alg\303\251rie Poste (Baridimob)\' : paymentType === \'CIB\' ? \'national SATIM interbanks\' : \'international merchant banks\'} gateway...\n                </p>\n\n                <div className=\"bg-[#FAF8F5] border border-[#D9D1C7] inline-flex flex-col gap-2 p-5 rounded-[24px] max-w-xs text-left text-[11px] text-[#8B4513] font-mono shadow-xs\">\n                  <div className=\"flex justify-between\">\n                    <span>Merchant Token:</span>\n                    <span className=\"font-bold text-emerald-700 text-[10px]\">REGISTERED_LIVE</span>\n                  </div>\n                  <div className=\"flex justify-between\">\n                    <span>Amount Encoded:</span>\n                    <span className=\"font-bold text-[#1A1A1A]\">{formatDZD(getGrandTotal())}</span>\n                  </div>\n                  <div className=\"flex justify-between\">\n                    <span>SATIM Secure DNS:</span>\n                    <span className=\"text-stone-400\">auth.epay.satim.dz</span>\n                  </div>\n                </div>\n              </div>\n            )}\n          </div>\n\n          {/* Cart items summary breakdown */}\n          <div className=\"lg:col-span-5 p-8 bg-[#E8E2DA] flex flex-col justify-between border-t lg:border-t-0 lg:border-l border-[#D9D1C7]\">\n            <div>\n              <h4 className=\"font-serif text-base font-medium text-[#2D2D2D] mb-4 pb-3 border-b border-[#D9D1C7]\">\n                Traditional Cart Summary\n              </h4>\n\n              {/* Items feed list */}\n              <div className=\"space-y-4 max-h-[40vh] overflow-y-auto mb-6 pr-2\">\n                {cart.map((item, idx) => (\n                  <div key={idx} className=\"flex gap-3 text-xs align-start\">\n                    <img\n                      src={item.product.image}\n                      alt={item.product.name}\n                      referrerPolicy=\"no-referrer\"\n                      className=\"w-12 h-12 rounded-[14px] object-cover border border-[#D9D1C7] shrink-0 [clip-path:ellipse(100%_100%_at_50%_50%)]\"\n                    />\n                    <div className=\"flex-1 min-w-0\">\n                      <h5 className=\"font-medium text-[#1A1A1A] truncate font-serif\">{item.product.name}</h5>\n                      <div className=\"flex gap-1.5 items-center text-[#8B4513]/60 text-[10px] mt-0.5\">\n                        <span className=\"bg-[#FAF8F5] px-1.5 py-0.5 rounded-full text-[#8B4513] capitalize font-bold border border-[#D9D1C7]/10\">\n                          Qty: {item.quantity}\n                        </span>\n                        <span>\342\200\242</span>\n                        <span className={`px-1.5 py-0.5 rounded-full font-bold border ${\n                          item.type === \'rent\' ? \'bg-emerald-50 text-emerald-800 border-emerald-250/20\' : \'bg-amber-50 text-[#8B4513] border-[#8B4513]/10\'\n                        }`}>\n                          {item.type === \'rent\' ? `Rented ${rentalDays}d` : \'Purchased\'}\n                        </span>\n                      </div>\n                    </div>\n                    <div className=\"text-right font-mono font-bold text-[#1A1A1A] shrink-0 font-xs\">\n                      {item.type === \'buy\'\n                        ? formatDZD(item.product.price * item.quantity)\n                        : formatDZD((item.product.rentPrice || 0) * rentalDays * item.quantity)}\n                    </div>\n                  </div>\n                ))}\n              </div>\n            </div>\n\n            {/* Price Calculations Card */}\n            <div className=\"border-t border-[#D9D1C7] pt-5 space-y-2.5\">\n              <div className=\"flex justify-between text-xs text-[#8B4513]/70\">\n                <span>Subtotal ({cart.length} items):</span>\n                <span className=\"font-mono font-bold text-[#1A1A1A]\">{formatDZD(getSubtotal())}</span>\n              </div>\n              <div className=\"flex justify-between text-xs text-[#8B4513]/70\">\n                <span>Shipping via National EMS/Yalidine:</span>\n                <span className=\"font-mono font-bold text-[#1A1A1A]\">{formatDZD(getShippingFee())}</span>\n              </div>\n              {hasRentals && (\n                <div className=\"flex justify-between text-xs text-emerald-800\">\n                  <span>Rental dry-cleaning fee:</span>\n                  <span className=\"font-bold\">FREE (Heritage Promo)</span>\n                </div>\n              )}\n              <div className=\"flex justify-between text-xs text-[#8B4513]/70\">\n                <span>Platform Security Tax (SATIM):</span>\n                <span className=\"font-sans text-[10px] text-emerald-700 font-bold uppercase\">0% (Vat Exempt)</span>\n              </div>\n\n              <div className=\"flex justify-between text-sm font-bold text-[#1A1A1A] pt-3 border-t border-dashed border-[#D9D1C7]\">\n                <span>Total Payment:</span>\n                <span className=\"font-mono text-base text-[#BC5449] font-extrabold\">{formatDZD(getGrandTotal())}</span>\n              </div>\n\n              <div className=\"bg-[#FAF8F5]/80 p-3.5 rounded-[20px] flex items-start gap-2 text-[10px] text-[#8B4513]/75 mt-4 leading-normal border border-[#D9D1C7]/30\">\n                <ShieldCheck className=\"w-4.5 h-4.5 text-[#BC5449] shrink-0 mt-0.5\" />\n                <span>Secured end-to-end by SATIM. Refund guarantees provided according to Algerian Commerce protection laws.</span>\n              </div>\n            </div>\n\n          </div>\n        </div>\n      </motion.div>\n    </div>\n  );\n}"
