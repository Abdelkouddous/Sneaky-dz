  file_change {
    absolute_path_uri: "file:///src/App.tsx"
    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "import React, { useState, useEffect } from \'react\';\nimport { motion, AnimatePresence } from \'motion/react\';\nimport { ShoppingBag, Store, Trash2, Plus, Minus, X, CheckCircle2, ShieldCheck, Tag, Info, Sparkles, HelpCircle } from \'lucide-react\';\nimport { INITIAL_PRODUCTS, INITIAL_SELLERS } from \'./data\';\nimport { Product, Order, CartItem, OrderStatus } from \'./types\';\nimport BuyerCatalog from \'./components/BuyerCatalog\';\nimport SellerDashboard from \'./components/SellerDashboard\';\nimport CheckoutModal from \'./components/CheckoutModal\';\n\nexport default function App() {\n  // Navigation / Mode switcher: \'buyer\' | \'seller\'\n  const [view, setView] = useState<\'buyer\' | \'seller\'>(\'buyer\');\n\n  // Load state from LocalStorage or fallback to INITIALS\n  const [products, setProducts] = useState<Product[]>(() => {\n    const stored = localStorage.getItem(\'dzair_craft_products\');\n    return stored ? JSON.parse(stored) : INITIAL_PRODUCTS;\n  });\n\n  const [orders, setOrders] = useState<Order[]>(() => {\n    const stored = localStorage.getItem(\'dzair_craft_orders\');\n    if (stored) return JSON.parse(stored);\n    \n    // Fallback beautiful pre-populated orders to impress stakeholders immediately\n    const todayStr = new Date().toLocaleDateString(\'fr-DZ\', { year: \'numeric\', month: \'long\', day: \'numeric\' });\n    const initialMockOrders: Order[] = [\n      {\n        id: \'DZ-748293\',\n        customerName: \'Warda Boumediene\',\n        customerEmail: \'warda.bou@yahoo.fr\',\n        customerPhone: \'+213 661 34 56 12\',\n        address: \'14 Boulevard des Martyrs\',\n        city: \'Algiers\',\n        postalCode: \'16000\',\n        items: [\n          {\n            productId: \'p2\',\n            productName: \'Tlemcen Bridal Chedda Outfit\',\n            image: \'https://images.unsplash.com/photo-1610030469983-98e550d6193c?auto=format&fit=crop&w=800&h=800&q=80\',\n            category: \'clothing\',\n            quantity: 1,\n            type: \'rent\',\n            price: 8500,\n            durationDays: 5,\n          }\n        ],\n        total: 43400, // 8500 * 5 + 900 (ship)\n        date: todayStr,\n        status: \'processing\',\n        paymentMethod: \'EDAHABIA\',\n        paymentStatus: \'paid\',\n        transactionId: \'TXN-EDAHABIA-493029481\',\n        rentalStartDate: new Date(Date.now() + 86400000 * 3).toISOString().split(\'T\')[0],\n        rentalEndDate: new Date(Date.now() + 86400000 * 8).toISOString().split(\'T\')[0]\n      },\n      {\n        id: \'DZ-319502\',\n        customerName: \'Yacine Belkaid\',\n        customerEmail: \'yacine_belk@gmail.com\',\n        customerPhone: \'+213 552 90 40 10\',\n        address: \'Rue d\\\'Oran, Villa 9\',\n        city: \'Oran\',\n        postalCode: \'31000\',\n        items: [\n          {\n            productId: \'p5\',\n            productName: \'Hand-Painted Moorish Zellij Ceramic Vase\',\n            image: \'https://images.unsplash.com/photo-1579783900882-c0d3dad7b119?auto=format&fit=crop&w=800&h=800&q=80\',\n            category: \'handicrafts\',\n            quantity: 1,\n            type: \'buy\',\n            price: 18500,\n          }\n        ],\n        total: 19400, // 18500 + 900\n        date: \'08 juin 2026\',\n        status: \'delivered\',\n        paymentMethod: \'CIB\',\n        paymentStatus: \'paid\',\n        transactionId: \'TXN-CIB-582930294\',\n      }\n    ];\n    return initialMockOrders;\n  });\n\n  // Cart State Management\n  const [cart, setCart] = useState<CartItem[]>([]);\n  const [isCartOpen, setIsCartOpen] = useState(false);\n\n  // Checkout modal switch\n  const [isCheckoutOpen, setIsCheckoutOpen] = useState(false);\n\n  // Success Feedback Modal\n  const [confirmedOrder, setConfirmedOrder] = useState<Order | null>(null);\n\n  // Global toast alerts state\n  const [toastMessage, setToastMessage] = useState<string | null>(null);\n\n  // Sync to database\n  useEffect(() => {\n    localStorage.setItem(\'dzair_craft_products\', JSON.stringify(products));\n  }, [products]);\n\n  useEffect(() => {\n    localStorage.setItem(\'dzair_craft_orders\', JSON.stringify(orders));\n  }, [orders]);\n\n  // Show dynamic self-dismissing toast feedback\n  const showToast = (msg: string) => {\n    setToastMessage(msg);\n    setTimeout(() => {\n      setToastMessage(null);\n    }, 3000);\n  };\n\n  // Add Item to interactive shopping cart\n  const handleAddToCart = (product: Product, type: \'buy\' | \'rent\') => {\n    setCart((prev) => {\n      const existing = prev.find((item) => item.product.id === product.id && item.type === type);\n      if (existing) {\n        showToast(`Increased quantity for ${product.name} inside cart!`);\n        return prev.map((item) =>\n          item.product.id === product.id && item.type === type\n            ? { ...item, quantity: item.quantity + 1 }\n            : item\n        );\n      }\n      showToast(`Added ${product.name} (${type === \'buy\' ? \'Buy\' : \'Rent\'}) to cart!`);\n      return [...prev, { product, quantity: 1, type }];\n    });\n  };\n\n  const handleUpdateCartQty = (idx: number, delta: number) => {\n    setCart((prev) => {\n      const target = prev[idx];\n      const newQty = target.quantity + delta;\n      if (newQty <= 0) {\n        return prev.filter((_, i) => i !== idx);\n      }\n      return prev.map((item, i) => (i === idx ? { ...item, quantity: newQty } : item));\n    });\n  };\n\n  const handleRemoveCartItem = (idx: number) => {\n    setCart((prev) => prev.filter((_, i) => i !== idx));\n    showToast(\'Removed item from traditional cart.\');\n  };\n\n  // Add new product from vendor form\n  const handleAddProduct = (newProduct: Product) => {\n    setProducts((prev) => [newProduct, ...prev]);\n    showToast(`Successfully listed ${newProduct.name} in the marketplace.`);\n  };\n\n  // Adjust stock level in database\n  const handleUpdateStock = (productId: string, newStock: number) => {\n    setProducts((prev) =>\n      prev.map((p) => (p.id === productId ? { ...p, stock: newStock } : p))\n    );\n    showToast(\'Stock inventory updated successfully.\');\n  };\n\n  // Delete product listing completely\n  const handleDeleteProduct = (productId: string) => {\n    setProducts((prev) => prev.filter((p) => p.id !== productId));\n    showToast(\'Product listing removed.\');\n  };\n\n  // Fulfill or adjust order progress\n  const handleUpdateOrderStatus = (orderId: string, newStatus: OrderStatus) => {\n    setOrders((prev) =>\n      prev.map((o) => (o.id === orderId ? { ...o, status: newStatus } : o))\n    );\n    showToast(`Order ${orderId} updated to state: ${newStatus}`);\n  };\n\n  // Payment successful callback handler\n  const handleOrderSuccess = (order: Order) => {\n    setOrders((prev) => [order, ...prev]);\n    setConfirmedOrder(order);\n    setIsCheckoutOpen(false);\n\n    // Subtract stock levels\n    setProducts((prevPrds) => {\n      return prevPrds.map((p) => {\n        const matchingCartItem = order.items.find((item) => item.productId === p.id);\n        if (matchingCartItem && matchingCartItem.type === \'buy\') {\n          return { ...p, stock: Math.max(0, p.stock - matchingCartItem.quantity) };\n        }\n        return p;\n      });\n    });\n  };\n\n  const cartTotalAmount = () => {\n    return cart.reduce((sum, item) => {\n      const price = item.type === \'buy\' ? item.product.price : (item.product.rentPrice || 0);\n      // default hypothetical 3 days if view only cart before final checkout configs\n      const multiplier = item.type === \'rent\' ? 3 : 1;\n      return sum + (price * multiplier * item.quantity);\n    }, 0);\n  };\n\n  const formatDZD = (num: number) => {\n    return new Intl.NumberFormat(\'fr-DZ\', { style: \'currency\', currency: \'DZD\', maximumFractionDigits: 0 }).format(num);\n  };\n\n  return (\n    <div className=\"min-h-screen bg-[#FAF8F5] leading-normal flex flex-col font-sans text-stone-800 selection:bg-amber-100 selection:text-amber-900 overflow-x-hidden\">\n      \n      {/* Decorative Traditional Algerian Header Accent Pattern */}\n      <div className=\"h-2 bg-gradient-to-r from-amber-600 via-yellow-500 to-emerald-700 w-full\"></div>\n\n      {/* Main Navbar */}\n      <nav className=\"bg-white/90 backdrop-blur-md sticky top-0 z-40 border-b border-stone-100 py-4 px-6 md:px-12 flex items-center justify-between transition-all\">\n        {/* Brand identity */}\n        <div className=\"flex items-center gap-3\">\n          <div className=\"w-10 h-10 rounded-xl bg-amber-800 flex items-center justify-center text-white font-serif font-bold text-xl shadow-xs shrink-0 select-none\">\n            D\n          </div>\n          <div>\n            <h1 className=\"font-serif text-lg font-bold text-stone-900 tracking-tight flex items-center gap-1\">\n              Dzair Craft\n              <Sparkles className=\"w-4 h-4 text-amber-500\" />\n            </h1>\n            <p className=\"text-[10px] text-stone-400 font-medium uppercase tracking-widest font-sans\">\n              Algeria Traditional Marketplace\n            </p>\n          </div>\n        </div>\n\n        {/* Global Navigation View Mode Controllers */}\n        <div className=\"flex items-center gap-1.5 md:gap-4\">\n          <div className=\"flex bg-stone-100 p-1 rounded-xl border border-stone-200\">\n            <button\n              onClick={() => { setView(\'buyer\'); setIsCartOpen(false); }}\n              className={`flex items-center gap-1.5 px-3.5 py-1.5 rounded-lg text-xs font-bold transition-all cursor-pointer ${\n                view === \'buyer\'\n                  ? \'bg-amber-800 text-stone-50 shadow-xs\'\n                  : \'text-stone-500 hover:text-stone-800\'\n              }`}\n            >\n              <ShoppingBag className=\"w-3.5 h-3.5\" />\n              <span>Shop Guild</span>\n            </button>\n            <button\n              onClick={() => { setView(\'seller\'); setIsCartOpen(false); }}\n              className={`flex items-center gap-1.5 px-3.5 py-1.5 rounded-lg text-xs font-bold transition-all cursor-pointer ${\n                view === \'seller\'\n                  ? \'bg-amber-800 text-stone-50 shadow-xs\'\n                  : \'text-stone-500 hover:text-stone-800\'\n              }`}\n            >\n              <Store className=\"w-3.5 h-3.5\" />\n              <span>Seller Portal</span>\n            </button>\n          </div>\n\n          {/* Cart trigger button (Shown in shop view) */}\n          {view === \'buyer\' && (\n            <button\n              id=\"cart-trigger-btn\"\n              onClick={() => setIsCartOpen(true)}\n              className=\"bg-white hover:bg-stone-50 border border-stone-200 rounded-xl p-2.5 flex items-center justify-center gap-1.5 relative shadow-xs hover:border-amber-505 transition-colors cursor-pointer\"\n            >\n              <ShoppingBag className=\"w-4 h-4 text-stone-700\" />\n              {cart.length > 0 && (\n                <span className=\"bg-amber-700 text-stone-50 font-mono text-[9px] font-bold w-4 h-4 rounded-full flex items-center justify-center absolute -top-1.5 -right-1.5 animate-bounce\">\n                  {cart.reduce((s, i) => s + i.quantity, 0)}\n                </span>\n              )}\n            </button>\n          )}\n        </div>\n      </nav>\n\n      {/* Main Container Stage */}\n      <main className=\"flex-1 max-w-7xl w-full mx-auto px-6 py-10 md:px-12\">\n        <AnimatePresence mode=\"wait\">\n          {view === \'buyer\' ? (\n            <motion.div\n              key=\"buyer-view\"\n              initial={{ opacity: 0, y: 15 }}\n              animate={{ opacity: 1, y: 0 }}\n              exit={{ opacity: 0, y: -15 }}\n              transition={{ duration: 0.25 }}\n            >\n              <BuyerCatalog\n                products={products}\n                onAddToCart={handleAddToCart}\n              />\n            </motion.div>\n          ) : (\n            <motion.div\n              key=\"seller-view\"\n              initial={{ opacity: 0, y: 15 }}\n              animate={{ opacity: 1, y: 0 }}\n              exit={{ opacity: 0, y: -15 }}\n              transition={{ duration: 0.25 }}\n            >\n              <SellerDashboard\n                products={products}\n                orders={orders}\n                onAddProduct={handleAddProduct}\n                onUpdateStock={handleUpdateStock}\n                onUpdateOrderStatus={handleUpdateOrderStatus}\n                onDeleteProduct={handleDeleteProduct}\n              />\n            </motion.div>\n          )}\n        </AnimatePresence>\n      </main>\n\n      {/* Sliding Shopping Cart Drawer (overlay) */}\n      <AnimatePresence>\n        {isCartOpen && (\n          <div className=\"fixed inset-0 z-50 overflow-hidden\">\n            <div className=\"absolute inset-0 bg-stone-900/40 backdrop-blur-xs transition-opacity\" onClick={() => setIsCartOpen(false)}></div>\n            \n            <div className=\"absolute inset-y-0 right-0 max-w-md w-full flex\">\n              <motion.div\n                initial={{ x: \'100%\' }}\n                animate={{ x: 0 }}\n                exit={{ x: \'100%\' }}\n                transition={{ type: \'tween\', duration: 0.3 }}\n                className=\"w-full bg-white relative flex flex-col shadow-2xl h-full border-l border-stone-200\"\n                id=\"cart-overlay-drawer\"\n              >\n                {/* Header */}\n                <div className=\"p-6 border-b border-stone-150 flex items-center justify-between bg-stone-50\">\n                  <h3 className=\"font-serif text-lg font-bold text-stone-950 flex items-center gap-1.5 animate-pulse\">\n                    \360\237\233\222 Your Heritage Cart\n                  </h3>\n                  <button\n                    onClick={() => setIsCartOpen(false)}\n                    className=\"p-1 rounded-full text-stone-500 hover:text-stone-950 hover:bg-stone-200 transition-all cursor-pointer\"\n                  >\n                    <X className=\"w-5 h-5\" />\n                  </button>\n                </div>\n\n                {/* Items list */}\n                <div className=\"flex-1 overflow-y-auto p-6 space-y-5\">\n                  {cart.length === 0 ? (\n                    <div className=\"text-center py-20\">\n                      <ShoppingBag className=\"w-12 h-12 text-stone-300 mx-auto mb-4\" />\n                      <p className=\"text-stone-600 font-serif font-bold text-base\">Your Bag is Empty</p>\n                      <p className=\"text-stone-400 text-xs mt-1 max-w-xs mx-auto\">\n                        Return to our catalog to select premium Algerian traditional clothing for renting or buying.\n                      </p>\n                      <button\n                        onClick={() => setIsCartOpen(false)}\n                        className=\"mt-6 bg-amber-800 text-stone-50 text-xs font-bold px-4 py-2 rounded-xl\"\n                      >\n                        Browse Artworks\n                      </button>\n                    </div>\n                  ) : (\n                    cart.map((item, idx) => (\n                      <div key={idx} className=\"flex gap-4 border-b border-stone-100 pb-5\" id={`cart-item-${idx}`}>\n                        <img\n                          src={item.product.image}\n                          alt={item.product.name}\n                          referrerPolicy=\"no-referrer\"\n                          className=\"w-16 h-16 rounded-xl object-cover border border-stone-205 shrink-0\"\n                        />\n                        <div className=\"flex-1 min-w-0\">\n                          <h4 className=\"font-serif font-bold text-stone-900 truncate leading-tight text-sm\">\n                            {item.product.name}\n                          </h4>\n                          \n                          <div className=\"flex items-center gap-2 mt-1.5 flex-wrap\">\n                            <span className=\"text-[10px] text-stone-400 font-mono\">\n                              Center: {item.product.origin}\n                            </span>\n                            <span>\342\200\242</span>\n                            <span className={`text-[10px] font-bold px-2 py-0.5 rounded uppercase ${\n                              item.type === \'rent\' ? \'bg-emerald-50 text-emerald-850\' : \'bg-amber-50 text-amber-850\'\n                            }`}>\n                              {item.type === \'rent\' ? \'3-Day Rent\' : \'Buyout\'}\n                            </span>\n                          </div>\n\n                          <div className=\"flex items-center justify-between mt-3\">\n                            {/* Quantity controllers */}\n                            <div className=\"flex items-center border border-stone-200 rounded-lg bg-stone-50 scale-90 origin-left\">\n                              <button\n                                onClick={() => handleUpdateCartQty(idx, -1)}\n                                className=\"p-1 text-stone-500 hover:text-stone-900\"\n                              >\n                                <Minus className=\"w-3.5 h-3.5\" />\n                              </button>\n                              <span className=\"px-2.5 font-mono text-xs font-bold text-stone-850\">\n                                {item.quantity}\n                              </span>\n                              <button\n                                onClick={() => handleUpdateCartQty(idx, 1)}\n                                className=\"p-1 text-stone-500 hover:text-stone-900\"\n                              >\n                                <Plus className=\"w-3.5 h-3.5\" />\n                              </button>\n                            </div>\n\n                            {/* Individual total prices */}\n                            <span className=\"text-xs font-mono font-bold text-stone-800\">\n                              {item.type === \'buy\'\n                                ? formatDZD(item.product.price * item.quantity)\n                                : formatDZD((item.product.rentPrice || 0) * 3 * item.quantity)}\n                            </span>\n                          </div>\n                        </div>\n\n                        {/* Remove item button */}\n                        <button\n                          onClick={() => handleRemoveCartItem(idx)}\n                          className=\"text-stone-350 hover:text-red-700 self-start p-1\"\n                        >\n                          <Trash2 className=\"w-4 h-4\" />\n                        </button>\n                      </div>\n                    ))\n                  )}\n                </div>\n\n                {/* Footer and dynamic billing calculators */}\n                {cart.length > 0 && (\n                  <div className=\"p-6 bg-stone-50 border-t border-stone-150 space-y-4\">\n                    <div className=\"flex items-center justify-between font-serif text-base font-bold text-stone-900\">\n                      <span>Subtotal estimate:</span>\n                      <span className=\"font-mono text-amber-805\">{formatDZD(cartTotalAmount())}</span>\n                    </div>\n\n                    <p className=\"text-[10px] text-stone-450 leading-relaxed\">\n                      *Rent prices are calculated on an initial 3-day baseline period. You can easily adjust rental days or ship regions on the next screen.\n                    </p>\n\n                    <button\n                      onClick={() => {\n                        setIsCartOpen(false);\n                        setIsCheckoutOpen(true);\n                      }}\n                      className=\"w-full bg-amber-800 hover:bg-amber-900 text-stone-50 font-bold text-xs py-3.5 rounded-xl uppercase tracking-wider flex items-center justify-center gap-1.5 transition-colors cursor-pointer\"\n                    >\n                      <ShieldCheck className=\"w-4.5 h-4.5\" />\n                      <span>Proceed to Payment Tunnel</span>\n                    </button>\n                  </div>\n                )}\n              </motion.div>\n            </div>\n          </div>\n        )}\n      </AnimatePresence>\n\n      {/* SECURE CHECKOUT GATEWAY MODAL WINDOW */}\n      <CheckoutModal\n        isOpen={isCheckoutOpen}\n        onClose={() => setIsCheckoutOpen(false)}\n        cart={cart}\n        onOrderSuccess={handleOrderSuccess}\n        clearCart={() => setCart([])}\n      />\n\n      {/* ORDER CONFIRMED SUCCESS DIALOG OVERLAY */}\n      <AnimatePresence>\n        {confirmedOrder && (\n          <div className=\"fixed inset-0 bg-stone-900/60 backdrop-blur-sm z-50 flex items-center justify-center p-4\">\n            <motion.div\n              initial={{ scale: 0.9, opacity: 0 }}\n              animate={{ scale: 1, opacity: 1 }}\n              exit={{ scale: 0.9, opacity: 0 }}\n              className=\"bg-white rounded-3xl max-w-md w-full p-8 text-center shadow-2xl border border-stone-150\"\n              id=\"order-success-window\"\n            >\n              <div className=\"w-16 h-16 bg-emerald-50 text-emerald-600 rounded-full flex items-center justify-center mx-auto mb-6\">\n                <CheckCircle2 className=\"w-12 h-12\" />\n              </div>\n\n              <span className=\"bg-emerald-50 text-emerald-800 text-[10px] font-bold uppercase tracking-widest px-3 py-1 rounded-full border border-emerald-150\">\n                Payment Completed Securely\n              </span>\n\n              <h3 className=\"font-serif text-2xl font-bold text-stone-900 mt-4 mb-2\">\n                Order Received!\n              </h3>\n              <p className=\"text-stone-500 text-xs leading-relaxed max-w-xs mx-auto\">\n                Sahit! Your traditional transaction was authenticated successfully under reference{\' \'}\n                <strong className=\"text-stone-800 font-mono text-[11px] bg-stone-100 px-1 py-0.5 rounded\">{confirmedOrder.id}</strong>. Packagers are preparing your heritage item right now.\n              </p>\n\n              {/* Order quick overview */}\n              <div className=\"bg-stone-50 border border-stone-200 p-4 rounded-2xl text-left my-6 space-y-2 text-xs font-sans\">\n                <div className=\"flex justify-between\">\n                  <span className=\"text-stone-400\">Transaction ID:</span>\n                  <span className=\"font-mono text-stone-800 text-[10px] font-bold\">{confirmedOrder.transactionId}</span>\n                </div>\n                <div className=\"flex justify-between\">\n                  <span className=\"text-stone-400\">Paid amount:</span>\n                  <span className=\"font-mono text-amber-800 font-bold\">{formatDZD(confirmedOrder.total)}</span>\n                </div>\n                <div className=\"flex justify-between\">\n                  <span className=\"text-stone-400\">Gateway:</span>\n                  <span className=\"font-extrabold uppercase text-stone-750 text-[10px] bg-amber-100 text-amber-900 px-1 rounded\">{confirmedOrder.paymentMethod} Card</span>\n                </div>\n                <div className=\"flex justify-between\">\n                  <span className=\"text-stone-400\">Address destination:</span>\n                  <span className=\"font-semibold text-stone-850 text-right truncate max-w-[180px]\">{confirmedOrder.city}, Algeria</span>\n                </div>\n              </div>\n\n              {/* Guide link to seller dashboard */}\n              <div className=\"bg-amber-50 text-amber-950 p-3 rounded-xl text-[10px] leading-relaxed text-left flex items-start gap-2 mb-6\">\n                <Info className=\"w-4 h-4 text-amber-700 shrink-0\" />\n                <span>\n                  <strong>Tip for Stakeholders:</strong> Click the <strong>Seller Portal</strong> in the navigation header to track this new order, view customer details, package items, and manage inventory levels in real-time!\n                </span>\n              </div>\n\n              <div className=\"space-y-2.5\">\n                <button\n                  onClick={() => {\n                    setView(\'seller\');\n                    setConfirmedOrder(null);\n                  }}\n                  className=\"w-full bg-stone-900 hover:bg-stone-800 text-stone-50 font-bold text-xs py-3 rounded-xl transition-all cursor-pointer\"\n                >\n                  Go to Seller Orders Page\n                </button>\n                <button\n                  onClick={() => setConfirmedOrder(null)}\n                  className=\"w-full border border-stone-300 font-bold text-xs py-3 rounded-xl text-stone-600 hover:bg-stone-50 transition-colors cursor-pointer\"\n                >\n                  Continue Shopping\n                </button>\n              </div>\n            </motion.div>\n          </div>\n        )}\n      </AnimatePresence>\n\n      {/* Global alert toaster message popup */}\n      <AnimatePresence>\n        {toastMessage && (\n          <motion.div\n            initial={{ opacity: 0, y: 50 }}\n            animate={{ opacity: 1, y: 0 }}\n            exit={{ opacity: 0, y: 20 }}\n            className=\"fixed bottom-6 left-6 bg-stone-900 text-stone-50 px-4 py-3 rounded-2xl shadow-xl z-50 flex items-center gap-2 max-w-xs border border-stone-800\"\n            id=\"toast-notification-banner\"\n          >\n            <CheckCircle2 className=\"w-4 h-4 text-amber-500 shrink-0\" />\n            <span className=\"text-xs font-semibold\">{toastMessage}</span>\n          </motion.div>\n        )}\n      </AnimatePresence>\n\n      {/* Culturally Elegant Footer */}\n      <footer className=\"bg-stone-900 text-stone-300 border-t border-stone-800 py-12 px-6 md:px-12 mt-auto\">\n        <div className=\"max-w-7xl mx-auto flex flex-col md:flex-row items-center justify-between gap-6\" id=\"applet-footer\">\n          <div>\n            <h4 className=\"font-serif font-bold text-white text-base\">Dzair Craft</h4>\n            <p className=\"text-xs text-stone-450 mt-1 max-w-sm font-light\">\n              Providing premium traditional digital tools to showcase, rent, and buy traditional Algerian clothing, ceramics, brassware, and woolen artifacts with full interbank security. Built for stakeholders MVP exhibition.\n            </p>\n          </div>\n          <div className=\"text-center md:text-right\">\n            <span className=\"text-xs text-stone-500 font-mono block\">Current Local Time</span>\n            <span className=\"text-xs text-amber-400 font-mono font-bold\">15:45 (Algiers / Al-Asimah)</span>\n            <span className=\"text-[10px] text-stone-605 block mt-2\">\302\251 2026 Dzair Craft. Algeria Heritage.</span>\n          </div>\n        </div>\n      </footer>\n    </div>\n  );\n}\n"
    }
