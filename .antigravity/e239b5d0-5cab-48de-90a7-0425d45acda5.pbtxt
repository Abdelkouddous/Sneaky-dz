    instruction: "Style the intro banner and mode switches with Artistic Flair colors."
    replacement_infos {
      original_chunk {
        target_content: "      {/* Intro Banner */}\n      <div className=\"bg-stone-900 text-stone-100 rounded-3xl p-8 mb-10 relative overflow-hidden shadow-sm\" id=\"catalog-banner\">\n        <div className=\"absolute inset-0 opacity-10 bg-[radial-gradient(#d4af37_1px,transparent_1px)] [background-size:16px_16px]\"></div>\n        <div className=\"relative z-10 max-w-2xl\">\n          <span className=\"text-amber-400 text-xs font-bold uppercase tracking-widest bg-amber-400/10 px-3.5 py-1.5 rounded-full border border-amber-400/25\">\n            Algerian Heritage Showcase\n          </span>\n          <h1 className=\"font-serif text-3xl md:text-4xl lg:text-5xl font-bold mt-4 mb-2 tracking-tight\">\n            Wear the History. <br />\n            Cherish the Craft.\n          </h1>\n          <p className=\"text-stone-300 text-xs md:text-sm font-light leading-relaxed mb-6\">\n            Rent royal wedding garments like the Chedda of Tlemcen and Karakou of Algiers, or purchase certified handwoven carpets and brasswares handmade in historical Algerian centers of artisanal excellence.\n          </p>\n          <div className=\"flex flex-wrap gap-4 text-xs font-medium text-stone-300\">\n            <span className=\"flex items-center gap-1.5 bg-stone-800/80 px-3.5 py-2 rounded-xl\">\n              <Check className=\"w-4 h-4 text-amber-500\" />\n              100% Authentic Handiwork\n            </span>\n            <span className=\"flex items-center gap-1.5 bg-stone-800/80 px-3.5 py-2 rounded-xl\">\n              <Check className=\"w-4 h-4 text-amber-500\" />\n              Flexible Rental Durations\n            </span>\n            <span className=\"flex items-center gap-1.5 bg-stone-800/80 px-3.5 py-2 rounded-xl\">\n              <Check className=\"w-4 h-4 text-amber-500\" />\n              Secure Pay with CIB & EDAHABIA\n            </span>\n          </div>\n        </div>\n      </div>\n\n      {/* Advanced Filter Panel */}\n      <div className=\"bg-white rounded-2xl border border-stone-100 p-6 shadow-xs mb-8\" id=\"catalog-filters\">\n        <div className=\"flex flex-col lg:flex-row gap-4 items-center justify-between mb-6 pb-6 border-b border-stone-100\">\n          \n          {/* Search bar */}\n          <div className=\"relative w-full lg:max-w-md\">\n            <Search className=\"absolute left-3.5 top-1/2 -translate-y-1/2 w-4 h-4 text-stone-400\" />\n            <input\n              type=\"text\"\n              placeholder=\"Search Karakou, Margoum rug, copper teaset...\"\n              value={search}\n              onChange={(e) => setSearch(e.target.value)}\n              className=\"w-full bg-stone-50 border border-stone-200 rounded-xl pl-11 pr-4 py-2.5 text-sm focus:outline-none focus:border-amber-500 focus:bg-white transition-all text-stone-800\"\n            />\n          </div>\n\n          <div className=\"flex flex-wrap items-center gap-3 w-full lg:w-auto justify-end\">\n            {/* Rent/Buy filter buttons */}\n            <div className=\"flex bg-stone-50 p-1 rounded-xl border border-stone-200\">\n              <button\n                onClick={() => setSelectedType(\'all\')}\n                className={`px-3 py-1.5 rounded-lg text-xs font-bold transition-all ${\n                  selectedType === \'all\'\n                    ? \'bg-amber-600 text-white shadow-xs\'\n                    : \'text-stone-500 hover:text-stone-800\'\n                }`}\n              >\n                All Modes\n              </button>\n              <button\n                onClick={() => setSelectedType(\'buy\')}\n                className={`px-3 py-1.5 rounded-lg text-xs font-bold transition-all ${\n                  selectedType === \'buy\'\n                    ? \'bg-amber-600 text-white shadow-xs\'\n                    : \'text-stone-500 hover:text-stone-800\'\n                }`}\n              >\n                Buy Only\n              </button>\n              <button\n                onClick={() => setSelectedType(\'rent\')}\n                className={`px-3 py-1.5 rounded-lg text-xs font-bold transition-all ${\n                  selectedType === \'rent\'\n                    ? \'bg-amber-600 text-white shadow-xs\'\n                    : \'text-stone-500 hover:text-stone-800\'\n                }`}\n              >\n                Rent Only\n              </button>\n            </div>\n\n            {/* Sort Dropdown */}\n            <select\n              value={sortBy}\n              onChange={(e: any) => setSortBy(e.target.value)}\n              className=\"bg-stone-50 border border-stone-200 rounded-xl px-3 py-2 text-xs font-bold text-stone-700 focus:outline-none focus:border-amber-500\"\n            >\n              <option value=\"rating\">Sort by: Best Match</option>\n              <option value=\"priceAsc\">Price: Low to High</option>\n              <option value=\"priceDesc\">Price: High to Low</option>\n            </select>\n          </div>\n        </div>"
        replacement_content: "      {/* Intro Banner */}\n      <div className=\"bg-[#2D2D2D] text-[#F1EDE8] rounded-[40px] p-8 md:p-12 mb-10 relative overflow-hidden border border-[#D9D1C7]/10 shadow-lg\" id=\"catalog-banner\">\n        <div className=\"absolute inset-0 opacity-5 bg-[radial-gradient(#BC5449_1px,transparent_1px)] [background-size:20px_20px]\"></div>\n        <div className=\"relative z-10 max-w-2xl\">\n          <span className=\"text-[#BC5449] text-[10px] font-bold uppercase tracking-[0.2em] bg-white/5 px-4 py-2 rounded-full border border-[#BC5449]/35\">\n            Algerian Heritage Showcase\n          </span>\n          <h1 className=\"font-serif text-3xl md:text-5xl lg:text-6xl font-light mt-6 mb-4 tracking-tight leading-tight\">\n            Wear the History. <br />\n            <span className=\"italic font-light text-[#D9D1C7]\">Cherish the Craft.</span>\n          </h1>\n          <p className=\"text-[#D9D1C7]/80 text-xs md:text-sm font-sans tracking-wide leading-relaxed mb-8 max-w-xl\">\n            Rent royal wedding garments like the Chedda of Tlemcen and Karakou of Algiers, or purchase certified handwoven carpets and brasswares handmade in historical Algerian centers of artisanal excellence.\n          </p>\n          <div className=\"flex flex-wrap gap-3.5 text-xs font-semibold text-[#F1EDE8]\">\n            <span className=\"flex items-center gap-2 bg-[#1A1A1A]/40 border border-[#D9D1C7]/10 px-4 py-2 rounded-full\">\n              <Check className=\"w-3.5 h-3.5 text-[#BC5449]\" />\n              100% Authentic Handiwork\n            </span>\n            <span className=\"flex items-center gap-2 bg-[#1A1A1A]/40 border border-[#D9D1C7]/10 px-4 py-2 rounded-full\">\n              <Check className=\"w-3.5 h-3.5 text-[#BC5449]\" />\n              Flexible Rental Durations\n            </span>\n            <span className=\"flex items-center gap-2 bg-[#1A1A1A]/40 border border-[#D9D1C7]/10 px-4 py-2 rounded-full\">\n              <Check className=\"w-3.5 h-3.5 text-[#BC5449]\" />\n              Secure Pay with CIB & EDAHABIA\n            </span>\n          </div>\n        </div>\n      </div>\n\n      {/* Advanced Filter Panel */}\n      <div className=\"bg-[#F1EDE8]/40 rounded-3xl border border-[#D9D1C7] p-6 md:p-8 shadow-xs mb-10\" id=\"catalog-filters\">\n        <div className=\"flex flex-col lg:flex-row gap-4 items-center justify-between mb-6 pb-6 border-b border-[#D9D1C7]\">\n          \n          {/* Search bar */}\n          <div className=\"relative w-full lg:max-w-md\">\n            <Search className=\"absolute left-4 top-1/2 -translate-y-1/2 w-4 h-4 text-[#8B4513]/60\" />\n            <input\n              type=\"text\"\n              placeholder=\"Search Karakou, Margoum rug, copper teaset...\"\n              value={search}\n              onChange={(e) => setSearch(e.target.value)}\n              className=\"w-full bg-white border border-[#D9D1C7] rounded-full pl-11 pr-5 py-3 text-sm focus:outline-none focus:border-[#BC5449] focus:bg-white transition-all text-[#1A1A1A]\"\n            />\n          </div>\n\n          <div className=\"flex flex-wrap items-center gap-3 w-full lg:w-auto justify-end\">\n            {/* Rent/Buy filter buttons */}\n            <div className=\"flex bg-white rounded-full p-1 border border-[#D9D1C7]\">\n              <button\n                onClick={() => setSelectedType(\'all\')}\n                className={`px-4 py-1.5 rounded-full text-[10px] uppercase font-bold transition-all ${\n                  selectedType === \'all\'\n                    ? \'bg-[#BC5449] text-white\'\n                    : \'text-[#8B4513] hover:text-[#BC5449]\'\n                }`}\n              >\n                All Modes\n              </button>\n              <button\n                onClick={() => setSelectedType(\'buy\')}\n                className={`px-4 py-1.5 rounded-full text-[10px] uppercase font-bold transition-all ${\n                  selectedType === \'buy\'\n                    ? \'bg-[#BC5449] text-white\'\n                    : \'text-[#8B4513] hover:text-[#BC5449]\'\n                }`}\n              >\n                Buy Only\n              </button>\n              <button\n                onClick={() => setSelectedType(\'rent\')}\n                className={`px-4 py-1.5 rounded-full text-[10px] uppercase font-bold transition-all ${\n                  selectedType === \'rent\'\n                    ? \'bg-[#BC5449] text-white\'\n                    : \'text-[#8B4513] hover:text-[#BC5449]\'\n                }`}\n              >\n                Rent Only\n              </button>\n            </div>\n\n            {/* Sort Dropdown */}\n            <select\n              value={sortBy}\n              onChange={(e: any) => setSortBy(e.target.value)}\n              className=\"bg-white border border-[#D9D1C7] rounded-full px-4 py-2.5 text-[10px] uppercase font-bold text-[#8B4513] focus:outline-none focus:border-[#BC5449] cursor-pointer\"\n            >\n              <option value=\"rating\">Sort: Best Match</option>\n              <option value=\"priceAsc\">Price: Low to High</option>\n              <option value=\"priceDesc\">Price: High to Low</option>\n            </select>\n          </div>\n        </div>"
      }
