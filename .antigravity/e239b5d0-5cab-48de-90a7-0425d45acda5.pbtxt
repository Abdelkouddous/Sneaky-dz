    instruction: "Style the details step of the checkout form with Artistic Flair colors and borders."
    replacement_infos {
      original_chunk {
        target_content: "            {step === \'details\' && (\n              <form onSubmit={handleNextStep} id=\"checkout-details-form\">\n                <h4 className=\"font-serif text-lg font-bold text-stone-900 mb-5\">\n                  1. Algerian Order Fulfillment Information\n                </h4>\n                \n                <div className=\"space-y-4\">\n                  <div>\n                    <label className=\"block text-[11px] font-semibold uppercase tracking-wider text-stone-400 mb-1\">\n                      Full Name\n                    </label>\n                    <input\n                      type=\"text\"\n                      required\n                      placeholder=\"e.g., Slimane Bencherif\"\n                      value={fullName}\n                      onChange={(e) => setFullName(e.target.value)}\n                      className=\"w-full bg-stone-50 border border-stone-200 rounded-xl px-4 py-2.5 text-xs focus:outline-none focus:border-amber-600 text-stone-800\"\n                    />\n                  </div>\n\n                  <div className=\"grid grid-cols-2 gap-4\">\n                    <div>\n                      <label className=\"block text-[11px] font-semibold uppercase tracking-wider text-stone-400 mb-1\">\n                        Email Address\n                      </label>\n                      <input\n                        type=\"email\"\n                        required\n                        placeholder=\"slimane.b@gmail.com\"\n                        value={email}\n                        onChange={(e) => setEmail(e.target.value)}\n                        className=\"w-full bg-stone-50 border border-stone-200 rounded-xl px-4 py-2.5 text-xs focus:outline-none focus:border-amber-600 text-stone-800\"\n                      />\n                    </div>\n                    <div>\n                      <label className=\"block text-[11px] font-semibold uppercase tracking-wider text-stone-400 mb-1\">\n                        Mobile Phone (Algeria)\n                      </label>\n                      <input\n                        type=\"tel\"\n                        required\n                        placeholder=\"e.g., +213 550 45 67 89\"\n                        value={phone}\n                        onChange={(e) => setPhone(e.target.value)}\n                        className=\"w-full bg-stone-50 border border-stone-200 rounded-xl px-4 py-2.5 text-xs focus:outline-none focus:border-amber-600 text-stone-800\"\n                      />\n                    </div>\n                  </div>\n\n                  <div>\n                    <label className=\"block text-[11px] font-semibold uppercase tracking-wider text-stone-400 mb-1\">\n                      Strict Shipping Street Address\n                    </label>\n                    <input\n                      type=\"text\"\n                      required\n                      placeholder=\"e.g., 20 Rue Didouche Mourad, Apt 4\"\n                      value={address}\n                      onChange={(e) => setAddress(e.target.value)}\n                      className=\"w-full bg-stone-50 border border-stone-200 rounded-xl px-4 py-2.5 text-xs focus:outline-none focus:border-amber-600 text-stone-800\"\n                    />\n                  </div>\n\n                  <div className=\"grid grid-cols-2 gap-4\">\n                    <div>\n                      <label className=\"block text-[11px] font-semibold uppercase tracking-wider text-stone-400 mb-1\">\n                        Fulfillment City\n                      </label>\n                      <select\n                        value={city}\n                        onChange={(e) => setCity(e.target.value)}\n                        className=\"w-full bg-stone-50 border border-stone-200 rounded-xl px-4 py-2.5 text-xs focus:outline-none focus:border-amber-600 text-stone-800\"\n                      >\n                        <option value=\"Algiers\">