    replacement_infos {
      original_chunk {
        target_content: "  return (\n    <div className=\"min-h-screen bg-[#FAF8F5] leading-normal flex flex-col font-sans text-stone-800 selection:bg-amber-100 selection:text-amber-900 overflow-x-hidden\">\n      \n      {/* Decorative Traditional Algerian Header Accent Pattern */}\n      <div className=\"h-2 bg-gradient-to-r from-amber-600 via-yellow-500 to-emerald-700 w-full\"></div>\n\n      {/* Main Navbar */}\n      <nav className=\"bg-white/90 backdrop-blur-md sticky top-0 z-40 border-b border-stone-100 py-4 px-6 md:px-12 flex items-center justify-between transition-all\">\n        {/* Brand identity */}\n        <div className=\"flex items-center gap-3\">\n          <div className=\"w-10 h-10 rounded-xl bg-amber-800 flex items-center justify-center text-white font-serif font-bold text-xl shadow-xs shrink-0 select-none\">\n            D\n          </div>\n          <div>\n            <h1 className=\"font-serif text-lg font-bold text-stone-900 tracking-tight flex items-center gap-1\">\n              Dzair Craft\n              <Sparkles className=\"w-4 h-4 text-amber-500\" />\n            </h1>\n            <p className=\"text-[10px] text-stone-400 font-medium uppercase tracking-widest font-sans\">\n              Algeria Traditional Marketplace\n            </p>\n          </div>\n        </div>\n\n        {/* Global Navigation View Mode Controllers */}\n        <div className=\"flex items-center gap-1.5 md:gap-4\">\n          <div className=\"flex bg-stone-100 p-1 rounded-xl border border-stone-200\">\n            <button\n              onClick={() => { setView(\'buyer\'); setIsCartOpen(false); }}\n              className={`flex items-center gap-1.5 px-3.5 py-1.5 rounded-lg text-xs font-bold transition-all cursor-pointer ${\n                view === \'buyer\'\n                  ? \'bg-amber-800 text-stone-50 shadow-xs\'\n                  : \'text-stone-500 hover:text-stone-800\'\n              }`}\n            >\n              <ShoppingBag className=\"w-3.5 h-3.5\" />\n              <span>Shop Guild</span>\n            </button>\n            <button\n              onClick={() => { setView(\'seller\'); setIsCartOpen(false); }}\n              className={`flex items-center gap-1.5 px-3.5 py-1.5 rounded-lg text-xs font-bold transition-all cursor-pointer ${\n                view === \'seller\'\n                  ? \'bg-amber-800 text-stone-50 shadow-xs\'\n                  : \'text-stone-500 hover:text-stone-800\'\n              }`}\n            >\n              <Store className=\"w-3.5 h-3.5\" />\n              <span>Seller Portal</span>\n            </button>\n          </div>\n\n          {/* Cart trigger button (Shown in shop view) */}\n          {view === \'buyer\' && (\n            <button\n              id=\"cart-trigger-btn\"\n              onClick={() => setIsCartOpen(true)}\n              className=\"bg-white hover:bg-stone-50 border border-stone-200 rounded-xl p-2.5 flex items-center justify-center gap-1.5 relative shadow-xs hover:border-amber-505 transition-colors cursor-pointer\"\n            >\n              <ShoppingBag className=\"w-4 h-4 text-stone-700\" />\n              {cart.length > 0 && (\n                <span className=\"bg-amber-700 text-stone-50 font-mono text-[9px] font-bold w-4 h-4 rounded-full flex items-center justify-center absolute -top-1.5 -right-1.5 animate-bounce\">\n                  {cart.reduce((s, i) => s + i.quantity, 0)}\n                </span>\n              )}\n            </button>\n          )}\n        </div>\n      </nav>"
        replacement_content: "  return (\n    <div className=\"min-h-screen bg-[#F7F3F0] leading-normal flex flex-col font-sans text-[#1A1A1A] selection:bg-[#E8E2DA] selection:text-[#8B4513] overflow-x-hidden\">\n      \n      {/* Decorative Traditional Algerian Header Accent Pattern */}\n      <div className=\"h-2 bg-gradient-to-r from-[#8B4513] via-[#BC5449] to-[#D9D1C7] w-full\"></div>\n\n      {/* Main Navbar */ font-serif}\n      <nav className=\"bg-[#F1EDE8] sticky top-0 z-40 border-b border-[#D9D1C7] py-4 px-6 md:px-12 flex items-center justify-between transition-all\">\n        {/* Brand identity */}\n        <div className=\"flex items-center gap-4\">\n          <div className=\"w-10 h-10 bg-[#8B4513] flex items-center justify-center text-white font-serif text-xl shrink-0 select-none shadow-xs\">\n            D\n          </div>\n          <div>\n            <h1 className=\"font-serif text-xl md:text-2xl font-normal text-[#2D2D2D] tracking-tight flex items-center gap-1\">\n              DZAIR <span className=\"italic font-light text-base md:text-lg text-[#8B4513]\">Craft</span>\n            </h1>\n            <p className=\"text-[10px] text-[#8B4513] font-semibold uppercase tracking-[0.2em] font-sans\">\n              Algerian Cultural Marketplace\n            </p>\n          </div>\n        </div>\n\n        {/* Global Navigation View Mode Controllers */}\n        <div className=\"flex items-center gap-1.5 md:gap-4\">\n          <div className=\"flex bg-white rounded-full p-1 border border-[#D9D1C7]\">\n            <button\n              onClick={() => { setView(\'buyer\'); setIsCartOpen(false); }}\n              className={`flex items-center gap-1.5 px-4 py-1.5 rounded-full text-[10px] uppercase font-bold transition-all cursor-pointer ${\n                view === \'buyer\'\n                  ? \'bg-[#BC5449] text-white\'\n                  : \'text-[#8B4513] hover:text-[#BC5449]\'\n              }`}\n            >\n              <ShoppingBag className=\"w-3 h-3\" />\n              <span>Shop Guild</span>\n            </button>\n            <button\n              onClick={() => { setView(\'seller\'); setIsCartOpen(false); }}\n              className={`flex items-center gap-1.5 px-4 py-1.5 rounded-full text-[10px] uppercase font-bold transition-all cursor-pointer ${\n                view === \'seller\'\n                  ? \'bg-[#BC5449] text-white\'\n                  : \'text-[#8B4513] hover:text-[#BC5449]\'\n              }`}\n            >\n              <Store className=\"w-3.5 h-3.5\" />\n              <span>Seller Portal</span>\n            </button>\n          </div>\n\n          {/* Cart trigger button (Shown in shop view) */}\n          {view === \'buyer\' && (\n            <button\n              id=\"cart-trigger-btn\"\n              onClick={() => setIsCartOpen(true)}\n              className=\"bg-white hover:bg-[#F1EDE8] border border-[#D9D1C7] rounded-full p-2.5 flex items-center justify-center gap-1.5 relative transition-colors cursor-pointer\"\n            >\n              <ShoppingBag className=\"w-4 h-4 text-[#8B4513]\" />\n              {cart.length > 0 && (\n                <span className=\"bg-[#BC5449] text-white font-mono text-[9px] font-bold w-4 h-4 rounded-full flex items-center justify-center absolute -top-1.5 -right-1.5 animate-bounce\">\n                  {cart.reduce((s, i) => s + i.quantity, 0)}\n                </span>\n              )}\n            </button>\n          )}\n        </div>\n      </nav>"
