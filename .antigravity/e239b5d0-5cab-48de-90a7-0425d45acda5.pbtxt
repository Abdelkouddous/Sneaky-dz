          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "    const matchesType = "
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "      selectedType === \'all\' || "
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "      (selectedType === \'buy\' && p.isBuyable) || "
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "      (selectedType === \'rent\' && p.isRentable);"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
