    replacement_chunks {
      target_content: "  return (\n    <div className=\"w-full bg-white rounded-3xl border border-stone-150 p-6 md:p-8 shadow-xs\" id=\"seller-zone\">\n      {/* Dashboard Top bar navigation state toggle */}\n      <div className=\"flex flex-col md:flex-row md:items-center justify-between border-b border-stone-150 pb-6 mb-8 gap-4\">\n        <div>\n          <span className=\"text-xs font-bold text-amber-700 uppercase tracking-widest block mb-1\">Seller Administration Mode</span>\n          <h2 className=\"font-serif text-2xl font-bold text-stone-900\">Artisan Guild Inventory & Fulfillment Portal</h2>\n        </div>\n\n        {/* Action Select buttons */}\n        <div className=\"flex flex-wrap gap-2\">\n          {[\n            { id: \'stats\', label: \'\360\237\223\212 Guild Stats\' },\n            { id: \'inventory\', label: \'\360\237\223\246 Stock Records\' },\n            { id: \'orders\', label: \'\360\237\223\234 Client Orders\' },\n            { id: \'add\', label: \'\342\236\225 Catalog New Item\' }\n          ].map((tab) => (\n            <button\n              key={tab.id}\n              onClick={() => setActiveTab(tab.id as any)}\n              className={`px-4 py-2 rounded-xl text-xs font-bold tracking-wide transition-all cursor-pointer ${\n                activeTab === tab.id\n                  ? \'bg-amber-800 text-white shadow-xs\'\n                  : \'bg-stone-50 border border-stone-200 text-stone-600 hover:bg-stone-100\'\n              }`}\n            >\n              {tab.label}\n            </button>\n          ))}\n        </div>\n      </div>\n\n      {/* RENDER STATS TAB */}\n      {activeTab === \'stats\' && (\n        <div className=\"space-y-8\" id=\"seller-dashboard-stats\">\n          {/* KPI metrics cluster */}\n          <div className=\"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6\">\n            <div className=\"bg-stone-50 rounded-2xl p-5 border border-stone-150\">\n              <div className=\"flex items-center justify-between mb-3 text-stone-400\">\n                <span className=\"text-xs font-semibold uppercase tracking-wider\">Gross Earnings</span>\n                <DollarSign className=\"w-5 h-5 text-amber-700\" />\n              </div>\n              <p className=\"text-2xl font-bold font-mono text-stone-900\">{formatDZD(totalSalesVal)}</p>\n              <span className=\"text-[10px] text-green-600 font-medium block mt-1\">100% Secure payout guaranteed</span>\n            </div>\n\n            <div className=\"bg-stone-50 rounded-2xl p-5 border border-stone-150\">\n              <div className=\"flex items-center justify-between mb-3 text-stone-400\">\n                <span className=\"text-xs font-semibold uppercase tracking-wider\">Fulfillment Orders</span>\n                <ShoppingBag className=\"w-5 h-5 text-indigo-700\" />\n              </div>\n              <p className=\"text-2xl font-bold font-mono text-stone-900\">{orders.length}</p>\n              <span className=\"text-[10px] text-stone-450 block mt-1\">\n                {orders.filter((o) => o.status === \'pending\').length} pending processing\n              </span>\n            </div>\n\n            <div className=\"bg-stone-50 rounded-2xl p-5 border border-stone-150\">\n              <div className=\"flex items-center justify-between mb-3 text-stone-400\">\n                <span className=\"text-xs font-semibold uppercase tracking-wider\">Active Dress Rentals</span>\n                <CalendarRange className=\"w-5 h-5 text-emerald-700\" />\n              </div>\n              <p className=\"text-2xl font-bold font-mono text-stone-900\">{activeRentalsCount}</p>\n              <span className=\"text-[10px] text-emerald-600 block mt-1\">Sanitized items due soon</span>\n            </div>\n\n            <div className=\"bg-stone-50 rounded-2xl p-5 border border-stone-150\">\n              <div className=\"flex items-center justify-between mb-3 text-stone-400\">\n                <span className=\"text-xs font-semibold uppercase tracking-wider\">Atelier Inventory</span>\n                <Box className=\"w-5 h-5 text-bronze-700\" />\n              </div>\n              <p className=\"text-2xl font-bold font-mono text-stone-900\">{products.length}</p>\n              <span className=\"text-[10px] text-amber-700 font-medium block mt-1\">Algerian genuine items</span>\n            </div>\n          </div>\n\n          <div className=\"grid grid-cols-1 lg:grid-cols-2 gap-8\">\n            {/* Quick alert panel */}\n            <div className=\"bg-amber-50/50 border border-amber-100 rounded-2xl p-6\">\n              <h4 className=\"font-serif text-base font-bold text-amber-900 mb-2 flex items-center gap-1.5\">\n                <AlertCircle className=\"w-5 h-5 text-amber-700\" />\n                Artisan Vendor Operations Advisory\n              </h4>\n              <p className=\"text-xs text-amber-800 leading-relaxed font-light mb-4\">\n                Dear Atelier Coordinator, please make sure all traditional royal garments listed for rental are thoroughly dry-cleaned and checked for premium weave count prior to mailing. Algerian brides expect impeccable standard for wedding garments.\n              </p>\n              <div className=\"space-y-2 text-xs\">\n                <div className=\"flex justify-between items-center bg-white p-2.5 rounded-lg border border-amber-100\">\n                  <span className=\"font-medium text-stone-700\">SATIM Gateway Settlement Limit:</span>\n                  <span className=\"font-bold text-stone-900 font-mono\">Real-time instantly</span>\n                </div>\n                <div className=\"flex justify-between items-center bg-white p-2.5 rounded-lg border border-amber-100\">\n                  <span className=\"font-medium text-stone-700\">National EMS Shipping Contract:</span>\n                  <span className=\"font-bold text-stone-900\">Signed with Yalidine</span>\n                </div>\n              </div>\n            </div>\n\n            {/* Quick action list */}\n            <div className=\"border border-stone-150 p-6 rounded-2xl flex flex-col justify-between\">\n              <div>\n                <h4 className=\"font-serif text-base font-bold text-stone-900 mb-2\">\n                  Atelier Quick Tasks\n                </h4>\n                <p className=\"text-stone-500 text-xs font-light mb-4\">\n                  Easily review inventory levels and list new heritage items to present to stakeholders. This serves as a fully interactive wireframe mock rendering.\n                </p>\n              </div>\n              <div className=\"flex gap-3\">\n                <button\n                  onClick={() => setActiveTab(\'add\')}\n                  className=\"bg-stone-900 hover:bg-stone-805 text-stone-100 px-4 py-2.5 rounded-xl font-bold text-xs flex items-center gap-1 cursor-pointer\"\n                >\n                  <PlusCircle className=\"w-4 h-4\" />\n                  List New Art\n                </button>\n                <button\n                  onClick={() => setActiveTab(\'inventory\')}\n                  className=\"bg-stone-100 hover:bg-stone-200 text-stone-700 px-4 py-2.5 rounded-xl font-bold text-xs cursor-pointer\"\n                >\n                  Inspect Stocks\n                </button>\n              </div>\n            </div>\n          </div>\n        </div>\n      )}"
      replacement_content: "  return (\n    <div className=\"w-full bg-[#FAF8F5] rounded-[44px] border border-[#D9D1C7] p-6 md:p-10 shadow-lg\" id=\"seller-zone\">\n      {/* Dashboard Top bar navigation state toggle */}\n      <div className=\"flex flex-col md:flex-row md:items-center justify-between border-b border-[#D9D1C7] pb-6 mb-8 gap-4\">\n        <div>\n          <span className=\"text-[10px] font-bold text-[#8B4513] uppercase tracking-[0.2em] block mb-1\">Seller Administration Mode</span>\n          <h2 className=\"font-serif text-2xl md:text-3xl font-light text-[#2D2D2D]\">Artisan Guild Portal & <span className=\"italic font-light\">Inventory</span></h2>\n        </div>\n\n        {/* Action Select buttons */}\n        <div className=\"flex flex-wrap gap-2\">\n          {[\n            { id: \'stats\', label: \'\360\237\223\212 Guild Stats\' },\n            { id: \'inventory\', label: \'\360\237\223\246 Stock Records\' },\n            { id: \'orders\', label: \'\360\237\223\234 Client Orders\' },\n            { id: \'add\', label: \'\342\236\225 Catalog New Item\' }\n          ].map((tab) => (\n            <button\n              key={tab.id}\n              onClick={() => setActiveTab(tab.id as any)}\n              className={`px-5 py-2.5 rounded-full text-[10px] uppercase font-bold tracking-wider transition-all cursor-pointer ${\n                activeTab === tab.id\n                  ? \'bg-[#BC5449] text-white shadow-md\'\n                  : \'bg-white border border-[#D9D1C7] text-[#8B4513] hover:bg-[#F1EDE8]\'\n              }`}\n            >\n              {tab.label}\n            </button>\n          ))}\n        </div>\n      </div>\n\n      {/* RENDER STATS TAB */}\n      {activeTab === \'stats\' && (\n        <div className=\"space-y-8\" id=\"seller-dashboard-stats\">\n          {/* KPI metrics cluster using the Dark Section design from \"El-Assala Studio\" dashboard mockup */}\n          <div className=\"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6\">\n            <div className=\"bg-[#2D2D2D] text-[#F1EDE8] rounded-[30px] p-6 border border-[#D9D1C7]/15 shadow-sm\">\n              <div className=\"flex items-center justify-between mb-3 text-white/50\">\n                <span className=\"text-[10px] uppercase tracking-widest font-bold\">Gross Earnings</span>\n                <DollarSign className=\"w-5 h-5 text-[#BC5449]\" />\n              </div>\n              <p className=\"text-3xl font-normal font-mono text-[#BC5449]\">{formatDZD(totalSalesVal)}</p>\n              <span className=\"text-[9px] text-[#D9D1C7]/60 block mt-2\">100% Secure payout guaranteed</span>\n            </div>\n\n            <div className=\"bg-[#2D2D2D] text-[#F1EDE8] rounded-[30px] p-6 border border-[#D9D1C7]/15 shadow-sm\">\n              <div className=\"flex items-center justify-between mb-3 text-white/50\">\n                <span className=\"text-[10px] uppercase tracking-widest font-bold\">Orders Volume</span>\n                <ShoppingBag className=\"w-5 h-5 text-[#BC5449]\" />\n              </div>\n              <p className=\"text-3xl font-normal font-mono text-white\">{orders.length}</p>\n              <span className=\"text-[9px] text-[#D9D1C7]/60 block mt-2\">\n                {orders.filter((o) => o.status === \'pending\').length} pending processing\n              </span>\n            </div>\n\n            <div className=\"bg-[#2D2D2D] text-[#F1EDE8] rounded-[30px] p-6 border border-[#D9D1C7]/15 shadow-sm\">\n              <div className=\"flex items-center justify-between mb-3 text-white/50\">\n                <span className=\"text-[10px] uppercase tracking-widest font-bold\">Dress Rentals</span>\n                <CalendarRange className=\"w-5 h-5 text-emerald-400\" />\n              </div>\n              <p className=\"text-3xl font-normal font-mono text-white\">{activeRentalsCount}</p>\n              <span className=\"text-[9px] text-[#D9D1C7]/60 block mt-2\">Sanitized items on duration</span>\n            </div>\n\n            <div className=\"bg-[#2D2D2D] text-[#F1EDE8] rounded-[30px] p-6 border border-[#D9D1C7]/15 shadow-sm\">\n              <div className=\"flex items-center justify-between mb-3 text-white/50\">\n                <span className=\"text-[10px] uppercase tracking-widest font-bold\">Active Inventory</span>\n                <Box className=\"w-5 h-5 text-[#BC5449]\" />\n              </div>\n              <p className=\"text-3xl font-normal font-mono text-[#BC5449]\">{products.length}</p>\n              <span className=\"text-[9px] text-[#D9D1C7]/60 block mt-2\">Algerian traditional items</span>\n            </div>\n          </div>\n\n          <div className=\"grid grid-cols-1 lg:grid-cols-2 gap-8\">\n            {/* Quick alert panel */}\n            <div className=\"bg-[#E8E2DA] border border-[#D9D1C7] rounded-[32px] p-6 text-[#1A1A1A]\">\n              <h4 className=\"font-serif text-base font-bold text-[#8B4513] mb-2 flex items-center gap-1.5\">\n                <AlertCircle className=\"w-5 h-5 text-[#BC5449]\" />\n                Artisan Vendor Operations Advisory\n              </h4>\n              <p className=\"text-xs text-[#8B4513]/90 leading-relaxed font-sans mb-4\">\n                Dear Atelier Coordinator, please make sure all traditional royal garments listed for rental are thoroughly dry-cleaned and checked for premium weave count prior to mailing. Algerian brides expect impeccable standards for wedding garments.\n              </p>\n              <div className=\"space-y-2 text-xs\">\n                <div className=\"flex justify-between items-center bg-white/60 p-2.5 rounded-xl border border-[#D9D1C7]\">\n                  <span className=\"font-medium text-[#1A1A1A]\">SATIM Gateway Settlement Limit:</span>\n                  <span className=\"font-bold text-[#8B4513] font-mono\">Real-time instantly</span>\n                </div>\n                <div className=\"flex justify-between items-center bg-white/60 p-2.5 rounded-xl border border-[#D9D1C7]\">\n                  <span className=\"font-medium text-[#1A1A1A]\">National EMS Shipping Contract:</span>\n                  <span className=\"font-bold text-[#8B4513]\">Signed with Yalidine</span>\n                </div>\n              </div>\n            </div>\n\n            {/* Quick action list */}\n            <div className=\"bg-white border border-[#D9D1C7] p-6 rounded-[32px] flex flex-col justify-between\">\n              <div>\n                <h4 className=\"font-serif text-lg font-medium text-[#2D2D2D] mb-2\">\n                  Atelier Quick Tasks\n                </h4>\n                <p className=\"text-[#8B4513]/70 text-xs font-sans leading-relaxed mb-4\">\n                  Easily review inventory levels and list new heritage items to present to stakeholders. This serves as a fully interactive wireframe mock rendering.\n                </p>\n              </div>\n              <div className=\"flex gap-3\">\n                <button\n                  onClick={() => setActiveTab(\'add\')}\n                  className=\"bg-[#1A1A1A] hover:bg-[#8B4513] text-white px-5 py-3 rounded-full text-[10px] uppercase font-bold tracking-widest flex items-center gap-1 cursor-pointer transition-colors\"\n                >\n                  <PlusCircle className=\"w-4 h-4\" />\n                  List New Art\n                </button>\n                <button\n                  onClick={() => setActiveTab(\'inventory\')}\n                  className=\"bg-[#F1EDE8] hover:bg-[#D9D1C7]/50 border border-[#D9D1C7] text-[#1A1A1A] px-5 py-3 rounded-full text-[10px] uppercase font-bold tracking-widest cursor-pointer transition-colors\"\n                >\n                  Inspect Stocks\n                </button>\n              </div>\n            </div>\n          </div>\n        </div>\n      )}"
