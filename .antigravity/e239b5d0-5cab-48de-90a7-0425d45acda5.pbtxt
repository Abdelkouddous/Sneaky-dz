  file_change {
    absolute_path_uri: "file:///src/components/BuyerCatalog.tsx"
    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "import React, { useState } from \'react\';\nimport { motion, AnimatePresence } from \'motion/react\';\nimport { Search, SlidersHorizontal, MapPin, Tag, Star, Calendar, ShoppingCart, X, Check, Eye } from \'lucide-react\';\nimport { Product, ALGERIAN_CITIES } from \'../data\';\nimport ProductCard from \'./ProductCard\';\n\ninterface BuyerCatalogProps {\n  products: Product[];\n  onAddToCart: (product: Product, type: \'buy\' | \'rent\') => void;\n}\n\nexport default function BuyerCatalog({ products, onAddToCart }: BuyerCatalogProps) {\n  // Filters & Search controls\n  const [search, setSearch] = useState(\'\');\n  const [selectedCategory, setSelectedCategory] = useState<string>(\'all\');\n  const [selectedOrigin, setSelectedOrigin] = useState<string>(\'all\');\n  const [selectedType, setSelectedType] = useState<\'all\' | \'buy\' | \'rent\'>(\'all\');\n  const [priceRange, setPriceRange] = useState<number>(200000);\n  const [sortBy, setSortBy] = useState<\'rating\' | \'priceAsc\' | \'priceDesc\'>(\'rating\');\n\n  // Product detail view state\n  const [detailedProduct, setDetailedProduct] = useState<Product | null>(null);\n\n  // Filtered lists\n  const filteredProducts = products.filter((p) => {\n    const matchesSearch = p.name.toLowerCase().includes(search.toLowerCase()) || \n                          p.description.toLowerCase().includes(search.toLowerCase()) ||\n                          p.origin.toLowerCase().includes(search.toLowerCase());\n    const matchesCategory = selectedCategory === \'all\' || p.category === selectedCategory;\n    const matchesOrigin = selectedOrigin === \'all\' || p.origin === selectedOrigin;\n    const matchesPrice = p.price <= priceRange;\n    const matchesType = \n      selectedType === \'all\' || \n      (selectedType === \'buy\' && p.isBuyable) || \n      (selectedType === \'rent\' && p.isRentable);\n\n    return matchesSearch && matchesCategory && matchesOrigin && matchesPrice && matchesType;\n  });\n\n  // Sorted list\n  const sortedProducts = [...filteredProducts].sort((a, b) => {\n    if (sortBy === \'rating\') return b.rating - a.rating;\n    if (sortBy === \'priceAsc\') return a.price - b.price;\n    if (sortBy === \'priceDesc\') return b.price - a.price;\n    return 0;\n  });\n\n  const formatDZD = (num: number) => {\n    return new Intl.NumberFormat(\'fr-DZ\', { style: \'currency\', currency: \'DZD\', maximumFractionDigits: 0 }).format(num);\n  };\n\n  return (\n    <div className=\"w-full\">\n      {/* Intro Banner */}\n      <div className=\"bg-stone-900 text-stone-100 rounded-3xl p-8 mb-10 relative overflow-hidden shadow-sm\" id=\"catalog-banner\">\n        <div className=\"absolute inset-0 opacity-10 bg-[radial-gradient(#d4af37_1px,transparent_1px)] [background-size:16px_16px]\"></div>\n        <div className=\"relative z-10 max-w-2xl\">\n          <span className=\"text-amber-400 text-xs font-bold uppercase tracking-widest bg-amber-400/10 px-3.5 py-1.5 rounded-full border border-amber-400/25\">\n            Algerian Heritage Showcase\n          </span>\n          <h1 className=\"font-serif text-3xl md:text-4xl lg:text-5xl font-bold mt-4 mb-2 tracking-tight\">\n            Wear the History. <br />\n            Cherish the Craft.\n          </h1>\n          <p className=\"text-stone-300 text-xs md:text-sm font-light leading-relaxed mb-6\">\n            Rent royal wedding garments like the Chedda of Tlemcen and Karakou of Algiers, or purchase certified handwoven carpets and brasswares handmade in historical Algerian centers of artisanal excellence.\n          </p>\n          <div className=\"flex flex-wrap gap-4 text-xs font-medium text-stone-300\">\n            <span className=\"flex items-center gap-1.5 bg-stone-800/80 px-3.5 py-2 rounded-xl\">\n              <Check className=\"w-4 h-4 text-amber-500\" />\n              100% Authentic Handiwork\n            </span>\n            <span className=\"flex items-center gap-1.5 bg-stone-800/80 px-3.5 py-2 rounded-xl\">\n              <Check className=\"w-4 h-4 text-amber-500\" />\n              Flexible Rental Durations\n            </span>\n            <span className=\"flex items-center gap-1.5 bg-stone-800/80 px-3.5 py-2 rounded-xl\">\n              <Check className=\"w-4 h-4 text-amber-500\" />\n              Secure Pay with CIB & EDAHABIA\n            </span>\n          </div>\n        </div>\n      </div>\n\n      {/* Advanced Filter Panel */}\n      <div className=\"bg-white rounded-2xl border border-stone-100 p-6 shadow-xs mb-8\" id=\"catalog-filters\">\n        <div className=\"flex flex-col lg:flex-row gap-4 items-center justify-between mb-6 pb-6 border-b border-stone-100\">\n          \n          {/* Search bar */}\n          <div className=\"relative w-full lg:max-w-md\">\n            <Search className=\"absolute left-3.5 top-1/2 -translate-y-1/2 w-4 h-4 text-stone-400\" />\n            <input\n              type=\"text\"\n              placeholder=\"Search Karakou, Margoum rug, copper teaset...\"\n              value={search}\n              onChange={(e) => setSearch(e.target.value)}\n              className=\"w-full bg-stone-50 border border-stone-200 rounded-xl pl-11 pr-4 py-2.5 text-sm focus:outline-none focus:border-amber-500 focus:bg-white transition-all text-stone-800\"\n            />\n          </div>\n\n          <div className=\"flex flex-wrap items-center gap-3 w-full lg:w-auto justify-end\">\n            {/* Rent/Buy filter buttons */}\n            <div className=\"flex bg-stone-50 p-1 rounded-xl border border-stone-200\">\n              <button\n                onClick={() => setSelectedType(\'all\')}\n                className={`px-3 py-1.5 rounded-lg text-xs font-bold transition-all ${\n                  selectedType === \'all\'\n                    ? \'bg-amber-600 text-white shadow-xs\'\n                    : \'text-stone-500 hover:text-stone-800\'\n                }`}\n              >\n                All Modes\n              </button>\n              <button\n                onClick={() => setSelectedType(\'buy\')}\n                className={`px-3 py-1.5 rounded-lg text-xs font-bold transition-all ${\n                  selectedType === \'buy\'\n                    ? \'bg-amber-600 text-white shadow-xs\'\n                    : \'text-stone-500 hover:text-stone-800\'\n                }`}\n              >\n                Buy Only\n              </button>\n              <button\n                onClick={() => setSelectedType(\'rent\')}\n                className={`px-3 py-1.5 rounded-lg text-xs font-bold transition-all ${\n                  selectedType === \'rent\'\n                    ? \'bg-amber-600 text-white shadow-xs\'\n                    : \'text-stone-500 hover:text-stone-800\'\n                }`}\n              >\n                Rent Only\n              </button>\n            </div>\n\n            {/* Sort Dropdown */}\n            <select\n              value={sortBy}\n              onChange={(e: any) => setSortBy(e.target.value)}\n              className=\"bg-stone-50 border border-stone-200 rounded-xl px-3 py-2 text-xs font-bold text-stone-700 focus:outline-none focus:border-amber-500\"\n            >\n              <option value=\"rating\">Sort by: Best Match</option>\n              <option value=\"priceAsc\">Price: Low to High</option>\n              <option value=\"priceDesc\">Price: High to Low</option>\n            </select>\n          </div>\n        </div>\n\n        {/* Categories, Regions, and Price sub-grid */}\n        <div className=\"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6\">\n          \n          {/* Category selection */}\n          <div>\n            <label className=\"block text-xs font-semibold uppercase tracking-wider text-stone-400 mb-2.5\">\n              Category\n            </label>\n            <div className=\"flex flex-wrap gap-2\">\n              {[\n                { id: \'all\', label: \'All Artifacts\' },\n                { id: \'clothing\', label: \'\360\237\221\227 Garments & Dress\' },\n                { id: \'handicrafts\', label: \'\360\237\217\272 Handcrafted Art\' },\n                { id: \'art\', label: \'\360\237\216\250 Carpets & Rugs\' }\n              ].map((cat) => (\n                <button\n                  key={cat.id}\n                  onClick={() => setSelectedCategory(cat.id)}\n                  className={`px-3 py-1.5 rounded-lg text-xs font-medium border transition-all cursor-pointer ${\n                    selectedCategory === cat.id\n                      ? \'border-amber-600 bg-amber-50 text-amber-900 font-semibold\'\n                      : \'border-stone-200 text-stone-600 hover:bg-stone-50\'\n                  }`}\n                >\n                  {cat.label}\n                </button>\n              ))}\n            </div>\n          </div>\n\n          {/* Historical regions selection */}\n          <div>\n            <label className=\"block text-xs font-semibold uppercase tracking-wider text-stone-400 mb-2.5\">\n              Artisan Region / Origin\n            </label>\n            <div className=\"flex flex-wrap gap-1.5\">\n              <button\n                onClick={() => setSelectedOrigin(\'all\')}\n                className={`px-2.5 py-1 rounded-md text-[11px] font-medium transition-all cursor-pointer ${\n                  selectedOrigin === \'all\'\n                    ? \'bg-stone-900 text-stone-50\'\n                    : \'bg-stone-100 text-stone-600 hover:bg-stone-200\'\n                }`}\n              >\n                All Regions\n              </button>\n              {ALGERIAN_CITIES.map((city) => (\n                <button\n                  key={city}\n                  onClick={() => setSelectedOrigin(city)}\n                  className={`px-2.5 py-1 rounded-md text-[11px] font-medium transition-all cursor-pointer ${\n                    selectedOrigin === city\n                      ? \'bg-amber-800 text-white\'\n                      : \'bg-stone-100 text-stone-600 hover:bg-stone-200\'\n                  }`}\n                >\n                  {city}\n                </button>\n              ))}\n            </div>\n          </div>\n\n          {/* Max Price slider */}\n          <div>\n            <div className=\"flex items-center justify-between mb-2.5\">\n              <label className=\"block text-xs font-semibold uppercase tracking-wider text-stone-400\">\n                Max Budget Limit\n              </label>\n              <span className=\"text-xs font-mono font-bold text-stone-700 bg-stone-100 px-2 py-0.5 rounded\">\n                \342\211\244 {formatDZD(priceRange)}\n              </span>\n            </div>\n            <input\n              type=\"range\"\n              min=\"10000\"\n              max=\"200000\"\n              step=\"5000\"\n              value={priceRange}\n              onChange={(e) => setPriceRange(Number(e.target.value))}\n              className=\"w-full accent-amber-600 h-1 bg-stone-150 rounded-lg cursor-pointer\"\n            />\n            <div className=\"flex justify-between text-[10px] text-stone-400 mt-1\">\n              <span>10K DZD</span>\n              <span>100K DZD</span>\n              <span>200K DZD</span>\n            </div>\n          </div>\n        </div>\n      </div>\n\n      {/* Catalog Display Grid */}\n      <div className=\"relative\">\n        {sortedProducts.length === 0 ? (\n          <div className=\"text-center py-20 bg-white rounded-3xl border border-stone-100\">\n            <SlidersHorizontal className=\"w-10 h-10 text-stone-300 mx-auto mb-4\" />\n            <h3 className=\"text-lg font-serif font-bold text-stone-800\">No Heritage Pieces Found</h3>\n            <p className=\"text-stone-500 text-xs mt-1 max-w-sm mx-auto\">\n              We couldn\'t find any traditional products matching your active filters. Try adjusting your region, price range, or search keywords.\n            </p>\n            <button\n              onClick={() => {\n                setSearch(\'\');\n                setSelectedCategory(\'all\');\n                setSelectedOrigin(\'all\');\n                setSelectedType(\'all\');\n                setPriceRange(200000);\n              }}\n              className=\"mt-6 bg-stone-900 text-stone-50 px-5 py-2.5 rounded-xl font-bold text-xs hover:bg-stone-800 transition-colors\"\n            >\n              Clear All Filters\n            </button>\n          </div>\n        ) : (\n          <motion.div\n            layout\n            className=\"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6\"\n            id=\"buyer-products-grid\"\n          >\n            {sortedProducts.map((product) => (\n              <ProductCard\n                key={product.id}\n                product={product}\n                onAddToCart={onAddToCart}\n                onOpenDetails={(p) => setDetailedProduct(p)}\n              />\n            ))}\n          </motion.div>\n        )}\n      </div>\n\n      {/* Product Detail Modal */}\n      <AnimatePresence>\n        {detailedProduct && (\n          <div className=\"fixed inset-0 bg-stone-900/60 backdrop-blur-xs z-50 flex items-center justify-center p-4\">\n            <motion.div\n              initial={{ scale: 0.95, opacity: 0 }}\n              animate={{ scale: 1, opacity: 1 }}\n              exit={{ scale: 0.95, opacity: 0 }}\n              className=\"bg-white rounded-3xl max-w-3xl w-full max-h-[90vh] overflow-y-auto shadow-2xl relative\"\n              id=\"product-detail-modal\"\n            >\n              {/* Close Button */}\n              <button\n                onClick={() => setDetailedProduct(null)}\n                className=\"absolute top-4 right-4 bg-stone-100 hover:bg-stone-200 text-stone-700 rounded-full p-2 z-10 transition-colors\"\n              >\n                <X className=\"w-5 h-5\" />\n              </button>\n\n              <div className=\"grid grid-cols-1 md:grid-cols-2\">\n                {/* Photo Stage */}\n                <div className=\"relative h-72 md:h-full min-h-[350px]\">\n                  <img\n                    src={detailedProduct.image}\n                    alt={detailedProduct.name}\n                    referrerPolicy=\"no-referrer\"\n                    className=\"absolute inset-0 w-full h-full object-cover\"\n                  />\n                  <div className=\"absolute inset-0 bg-gradient-to-t from-stone-950/60 via-transparent to-transparent\"></div>\n                  <div className=\"absolute bottom-6 left-6 right-6 text-white\">\n                    <span className=\"bg-amber-600 text-[10px] font-bold uppercase tracking-wider px-2.5 py-1 rounded-md shadow inline-block mb-2\">\n                      Handcrafted in {detailedProduct.origin}\n                    </span>\n                    <h2 className=\"text-xl md:text-2xl font-serif font-bold text-white leading-tight\">\n                      {detailedProduct.name}\n                    </h2>\n                  </div>\n                </div>\n\n                {/* Meta details */}\n                <div className=\"p-8 flex flex-col justify-between\">\n                  <div>\n                    <div className=\"flex items-center gap-1.5 mb-3 text-stone-400 text-xs\">\n                      <span className=\"text-stone-800 font-semibold uppercase\">{detailedProduct.category}</span>\n                      <span>\342\200\242</span>\n                      <div className=\"flex items-center gap-1 text-amber-500 font-bold\">\n                        <Star className=\"w-3.5 h-3.5 fill-amber-500\" />\n                        <span>{detailedProduct.rating.toFixed(1)}</span>\n                      </div>\n                    </div>\n\n                    <p className=\"text-stone-600 text-xs leading-relaxed mb-6\">\n                      {detailedProduct.description}\n                    </p>\n\n                    {/* Metadata table list */}\n                    <div className=\"space-y-2 border-t border-b border-stone-100 py-4 mb-6\">\n                      <div className=\"flex justify-between text-xs\">\n                        <span className=\"text-stone-400\">Artisan Center:</span>\n                        <span className=\"font-semibold text-stone-800\">{detailedProduct.origin}, Algeria</span>\n                      </div>\n                      {detailedProduct.material && (\n                        <div className=\"flex justify-between text-xs\">\n                          <span className=\"text-stone-400\">Authentic materials:</span>\n                          <span className=\"font-semibold text-stone-800\">{detailedProduct.material}</span>\n                        </div>\n                      )}\n                      {detailedProduct.size && (\n                        <div className=\"flex justify-between text-xs\">\n                          <span className=\"text-stone-400\">Available size:</span>\n                          <span className=\"font-semibold text-stone-800\">{detailedProduct.size}</span>\n                        </div>\n                      )}\n                      <div className=\"flex justify-between text-xs\">\n                        <span className=\"text-stone-400\">Available units:</span>\n                        <span className=\"font-semibold text-stone-800\">{detailedProduct.stock} units-in-stock</span>\n                      </div>\n                    </div>\n                  </div>\n\n                  {/* Pricing action cards inside modal */}\n                  <div>\n                    <div className=\"flex flex-col gap-3 mb-6\">\n                      {detailedProduct.isBuyable && (\n                        <div className=\"flex items-center justify-between bg-stone-50 p-3 rounded-xl border border-stone-100\">\n                          <div>\n                            <span className=\"text-[10px] text-stone-400 block tracking-wide uppercase\">Own permanently</span>\n                            <span className=\"font-mono font-bold text-stone-900\">{formatDZD(detailedProduct.price)}</span>\n                          </div>\n                          <button\n                            onClick={() => {\n                              onAddToCart(detailedProduct, \'buy\');\n                              setDetailedProduct(null);\n                            }}\n                            className=\"bg-stone-900 text-stone-100 text-xs font-bold px-4 py-2 rounded-lg hover:bg-stone-800 active:scale-95 duration-100 cursor-pointer\"\n                          >\n                            Buy Authenic Piece\n                          </button>\n                        </div>\n                      )}\n\n                      {detailedProduct.isRentable && detailedProduct.rentPrice && (\n                        <div className=\"flex items-center justify-between bg-emerald-50/50 p-3 rounded-xl border border-emerald-100\">\n                          <div>\n                            <span className=\"text-[10px] text-emerald-700 block tracking-wide uppercase font-semibold\">Rent (3-day minimum)</span>\n                            <span className=\"font-mono font-bold text-emerald-800\">{formatDZD(detailedProduct.rentPrice)}<span className=\"text-[11px] font-sans font-normal text-emerald-600 block\">per day</span></span>\n                          </div>\n                          <button\n                            onClick={() => {\n                              onAddToCart(detailedProduct, \'rent\');\n                              setDetailedProduct(null);\n                            }}\n                            className=\"bg-emerald-700 text-white text-xs font-bold px-4 py-2 rounded-lg hover:bg-emerald-800 active:scale-95 duration-100 cursor-pointer\"\n                          >\n                            Rent Garment\n                          </button>\n                        </div>\n                      )}\n                    </div>\n\n                    <div className=\"bg-stone-50 p-3 rounded-xl flex items-center gap-2 text-[11px] text-stone-500\">\n                      <Tag className=\"w-3.5 h-3.5 text-amber-600 shrink-0\" />\n                      <span>Rentals include professional sanitized cleaning and shipping insurance.</span>\n                    </div>\n                  </div>\n                </div>\n              </div>\n            </motion.div>\n          </div>\n        )}\n      </AnimatePresence>\n    </div>\n  );\n}\n"
    }
    diff {
