      target_content: "  return (\n    <motion.div\n      id={`product-card-${product.id}`}\n      layout\n      initial={{ opacity: 0, y: 15 }}\n      animate={{ opacity: 1, y: 0 }}\n      exit={{ opacity: 0, y: -15 }}\n      transition={{ duration: 0.3 }}\n      className=\"bg-white rounded-2xl border border-stone-100 shadow-sm hover:shadow-md transition-all duration-300 overflow-hidden flex flex-col h-full\"\n    >\n      {/* Product Image Stage */}\n      <div className=\"relative aspect-square overflow-hidden group bg-stone-50\">\n        <img\n          src={product.image}\n          alt={product.name}\n          referrerPolicy=\"no-referrer\"\n          className=\"w-full h-full object-cover group-hover:scale-105 transition-transform duration-500\"\n        />\n        \n        {/* Origin Badge */}\n        <span className=\"absolute top-3 left-3 bg-stone-900/90 text-stone-100 text-xs font-medium tracking-wide px-3 py-1 rounded-full backdrop-blur-xs font-sans\">\n          {product.origin}\n        </span>\n\n        {/* Categories / Type Flags */}\n        <div className=\"absolute top-3 right-3 flex flex-col gap-1.5 align-end\">\n          {product.isRentable && (\n            <span className=\"bg-emerald-600 text-stone-50 text-[10px] font-bold uppercase tracking-wider px-2 py-0.5 rounded shadow\">\n              Rent Available\n            </span>\n          )}\n          {product.isBuyable && (\n            <span className=\"bg-amber-600 text-stone-50 text-[10px] font-bold uppercase tracking-wider px-2 py-0.5 rounded shadow\">\n              Buy Authentic\n            </span>\n          )}\n        </div>\n\n        {/* Quick details Overlay on Hover */}\n        <div className=\"absolute inset-0 bg-stone-900/40 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-center justify-center\">\n          <button\n            onClick={() => onOpenDetails(product)}\n            className=\"bg-white text-stone-900 text-sm font-semibold tracking-wide py-2.5 px-5 rounded-xl hover:bg-stone-100 transition-colors shadow-lg active:scale-95 duration-100\"\n          >\n            Explore Artifact\n          </button>\n        </div>\n      </div>\n\n      {/* Product Content info */}\n      <div className=\"p-5 flex-1 flex flex-col\">\n        <div className=\"flex items-center justify-between mb-2\">\n          <span className=\"text-amber-700 text-xs font-semibold uppercase tracking-wider font-sans\">\n            {product.category === \'clothing\' ? \'\360\237\221\227 Clothing\' : product.category === \'handicrafts\' ? \'\360\237\217\272 Handcrafted\' : \'\360\237\216\250 Traditional Art\'}\n          </span>\n          <div className=\"flex items-center gap-1\">\n            <Star className=\"w-3.5 h-3.5 fill-amber-400 text-amber-400\" />\n            <span className=\"text-xs font-bold text-stone-700\">{product.rating.toFixed(1)}</span>\n          </div>\n        </div>\n\n        <h3 className=\"font-serif text-lg font-bold text-stone-900 group-hover:text-amber-800 transition-colors line-clamp-1 mb-1.5\">\n          {product.name}\n        </h3>\n        \n        <p className=\"text-stone-500 text-xs line-clamp-2 leading-relaxed mb-4 flex-1\">\n          {product.description}\n        </p>\n\n        {/* Dynamic Pricing / Rent Option Details */}\n        <div className=\"grid grid-cols-2 gap-2 border-t border-stone-100 pt-4 mt-auto\">\n          {product.isBuyable ? (\n            <div className=\"flex flex-col\">\n              <span className=\"text-[10px] text-stone-400 uppercase tracking-wider\">Buy Price</span>\n              <span className=\"text-sm font-bold text-stone-900 font-mono\">\n                {formatDZD(product.price)}\n              </span>\n            </div>\n          ) : (\n            <div className=\"flex flex-col\">\n              <span className=\"text-[10px] text-stone-400 uppercase tracking-wide\">For Sale</span>\n              <span className=\"text-xs font-medium text-stone-400\">Not Available</span>\n            </div>\n          )}\n\n          {product.isRentable && product.rentPrice ? (\n            <div className=\"flex flex-col border-l border-stone-100 pl-3\">\n              <span className=\"text-[10px] text-emerald-600 font-medium uppercase tracking-wider\">Rent / day</span>\n              <span className=\"text-sm font-bold text-emerald-700 font-mono\">\n                {formatDZD(product.rentPrice)}\n              </span>\n            </div>\n          ) : (\n            <div className=\"flex flex-col border-l border-stone-100 pl-3\">\n              <span className=\"text-[10px] text-stone-400 uppercase tracking-wide\">For Rent</span>\n              <span className=\"text-xs font-medium text-stone-400\">Not Available</span>\n            </div>\n          )}\n        </div>\n\n        {/* Action Button Strip */}\n        <div className=\"flex gap-2 mt-4\" id={`product-actions-${product.id}`}>\n          {product.isBuyable && (\n            <button\n              onClick={() => onAddToCart(product, \'buy\')}\n              className={`flex-1 flex items-center justify-center gap-1 text-xs font-bold tracking-wide py-2.5 px-2 rounded-xl transition-all active:scale-95 cursor-pointer ${\n                product.stock > 0\n                  ? \'bg-stone-900 text-stone-100 hover:bg-stone-800\'\n                  : \'bg-stone-100 text-stone-400 cursor-not-allowed\'\n              }`}\n              disabled={product.stock <= 0}\n            >\n              <ShoppingCart className=\"w-3.5 h-3.5\" />\n              <span>{product.stock > 0 ? \'Buy Item\' : \'Sold Out\'}</span>\n            </button>\n          )}\n\n          {product.isRentable && (\n            <button\n              onClick={() => onAddToCart(product, \'rent\')}\n              className=\"flex-1 flex items-center justify-center gap-1 text-xs font-bold tracking-wide py-2.5 px-2 rounded-xl bg-emerald-50 text-emerald-800 hover:bg-emerald-100 border border-emerald-100 transition-all active:scale-95 cursor-pointer\"\n            >\n              <Calendar className=\"w-3.5 h-3.5\" />\n              <span>Rent Dress</span>\n            </button>\n          )}\n        </div>\n      </div>\n    </motion.div>"
      replacement_content: "  return (\n    <motion.div\n      id={`product-card-${product.id}`}\n      layout\n      initial={{ opacity: 0, y: 15 }}\n      animate={{ opacity: 1, y: 0 }}\n      exit={{ opacity: 0, y: -15 }}\n      transition={{ duration: 0.3 }}\n      className=\"bg-white rounded-[40px] border border-[#D9D1C7] hover:border-[#BC5449] shadow-xs hover:shadow-lg transition-all duration-300 overflow-hidden flex flex-col h-full\"\n    >\n      {/* Product Image Stage with Traditional Moorish Arch Styling */}\n      <div className=\"relative aspect-square overflow-hidden group bg-[#E8E2DA] m-3 rounded-t-[120px] rounded-b-[20px] border border-[#D9D1C7]/60\">\n        <img\n          src={product.image}\n          alt={product.name}\n          referrerPolicy=\"no-referrer\"\n          className=\"w-full h-full object-cover group-hover:scale-105 transition-transform duration-700\"\n        />\n        \n        {/* Origin Badge */}\n        <span className=\"absolute bottom-3 left-1/2 -translate-x-1/2 bg-white/95 backdrop-blur-sm text-[#8B4513] text-[9.5px] uppercase tracking-widest font-bold px-3 py-1.5 rounded-full shadow-sm border border-[#D9D1C7] font-sans\">\n          {product.origin}\n        </span>\n\n        {/* Categories / Type Flags */}\n        <div className=\"absolute top-4 right-4 flex flex-col gap-1.5 items-end\">\n          {product.isRentable && (\n            <span className=\"bg-[#BC5449] text-white text-[9px] font-bold uppercase tracking-wider px-2.5 py-1 rounded-full shadow-sm\">\n              Rent Available\n            </span>\n          )}\n          {product.isBuyable && (\n            <span className=\"bg-[#8B4513] text-white text-[9px] font-bold uppercase tracking-wider px-2.5 py-1 rounded-full shadow-sm\">\n              Buy Original\n            </span>\n          )}\n        </div>\n\n        {/* Quick details Overlay on Hover */}\n        <div className=\"absolute inset-0 bg-[#2D2D2D]/40 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-center justify-center\">\n          <button\n            onClick={() => onOpenDetails(product)}\n            className=\"bg-white text-[#1A1A1A] text-[10px] uppercase tracking-widest font-bold py-3 px-6 rounded-full hover:bg-[#F7F3F0] transition-colors shadow-lg active:scale-95 duration-100 cursor-pointer\"\n          >\n            Explore Artifact\n          </button>\n        </div>\n      </div>\n\n      {/* Product Content info */}\n      <div className=\"p-5 pt-2 flex-1 flex flex-col\">\n        <div className=\"flex items-center justify-between mb-2\">\n          <span className=\"text-[#BC5449] text-[10px] font-bold uppercase tracking-[0.15em] font-sans\">\n            {product.category === \'clothing\' ? \'\360\237\221\227 Garment Outfit\' : product.category === \'handicrafts\' ? \'\360\237\217\272 Handcrafted Art\' : \'\360\237\216\250 Traditional Weaving\'}\n          </span>\n          <div className=\"flex items-center gap-1\">\n            <Star className=\"w-3.5 h-3.5 fill-[#BC5449] text-[#BC5449]\" />\n            <span className=\"text-xs font-bold text-[#1A1A1A]\">{product.rating.toFixed(1)}</span>\n          </div>\n        </div>\n\n        <h3 className=\"font-serif text-lg font-medium text-[#2D2D2D] hover:text-[#8B4513] transition-colors line-clamp-1 mb-1.5\">\n          {product.name}\n        </h3>\n        \n        <p className=\"text-[#8B4513]/70 text-xs line-clamp-2 leading-relaxed mb-4 flex-1\">\n          {product.description}\n        </p>\n\n        {/* Dynamic Pricing / Rent Option Details */}\n        <div className=\"grid grid-cols-2 gap-2 border-t border-[#D9D1C7] pt-4 mt-auto\">\n          {product.isBuyable ? (\n            <div className=\"flex flex-col\">\n              <span className=\"text-[9px] text-[#8B4513]/60 uppercase tracking-widest\">Buy Price</span>\n              <span className=\"text-base font-bold text-[#1A1A1A] font-mono leading-tight mt-0.5\">\n                {formatDZD(product.price)}\n              </span>\n            </div>\n          ) : (\n            <div className=\"flex flex-col\">\n              <span className=\"text-[9px] text-[#8B4513]/60 uppercase tracking-widest font-light\">Heritage Buy</span>\n              <span className=\"text-xs font-medium text-[#D9D1C7] mt-0.5\">Not For Sale</span>\n            </div>\n          )}\n\n          {product.isRentable && product.rentPrice ? (\n            <div className=\"flex flex-col border-l border-[#D9D1C7] pl-3\">\n              <span className=\"text-[9px] text-[#BC5449] font-bold uppercase tracking-widest\">Rent / Day</span>\n              <span className=\"text-base font-bold text-[#BC5449] font-mono leading-tight mt-0.5\">\n                {formatDZD(product.rentPrice)}\n              </span>\n            </div>\n          ) : (\n            <div className=\"flex flex-col border-l border-[#D9D1C7] pl-3\">\n              <span className=\"text-[9px] text-[#8B4513]/60 uppercase tracking-widest font-light\">Rent Period</span>\n              <span className=\"text-xs font-medium text-[#D9D1C7] mt-0.5\">Not For Rent</span>\n            </div>\n          )}\n        </div>\n\n        {/* Action Button Strip */}\n        <div className=\"flex gap-2 mt-4\" id={`product-actions-${product.id}`}>\n          {product.isBuyable && (\n            <button\n              onClick={() => onAddToCart(product, \'buy\')}\n              className={`flex-1 flex items-center justify-center gap-1.5 text-[10px] uppercase font-bold tracking-wider py-3 px-2 rounded-full transition-all active:scale-95 cursor-pointer ${\n                product.stock > 0\n                  ? \'bg-[#1A1A1A] text-white hover:bg-[#8B4513]\'\n                  : \'bg-[#F1EDE8] text-[#D9D1C7] cursor-not-allowed\'\n              }`}\n              disabled={product.stock <= 0}\n            >\n              <ShoppingCart className=\"w-3.5 h-3.5\" />\n              <span>{product.stock > 0 ? \'Buy Original\' : \'Sold\'}</span>\n            </button>\n          )}\n\n          {product.isRentable && (\n            <button\n              onClick={() => onAddToCart(product, \'rent\')}\n              className=\"flex-1 flex items-center justify-center gap-1.5 text-[10px] uppercase font-bold tracking-wider py-3 px-2 rounded-full bg-white text-[#8B4513] hover:bg-[#F1EDE8] border border-[#D9D1C7] transition-all active:scale-95 cursor-pointer\"\n            >\n              <Calendar className=\"w-3.5 h-3.5\" />\n              <span>Rent Outfit</span>\n            </button>\n          )}\n        </div>\n      </div>\n    </motion.div>"
    }
