    instruction: "Style the detailed popover modal with Artistic layout borders and buttons in BuyerCatalog.tsx."
    replacement_infos {
      original_chunk {
        target_content: "      {/* Product Detail Modal */}\n      <AnimatePresence>\n        {detailedProduct && (\n          <div className=\"fixed inset-0 bg-stone-900/60 backdrop-blur-xs z-50 flex items-center justify-center p-4\">\n            <motion.div\n              initial={{ scale: 0.95, opacity: 0 }}\n              animate={{ scale: 1, opacity: 1 }}\n              exit={{ scale: 0.95, opacity: 0 }}\n              className=\"bg-white rounded-3xl max-w-3xl w-full max-h-[90vh] overflow-y-auto shadow-2xl relative\"\n              id=\"product-detail-modal\"\n            >\n              {/* Close Button */}\n              <button\n                onClick={() => setDetailedProduct(null)}\n                className=\"absolute top-4 right-4 bg-stone-100 hover:bg-stone-200 text-stone-700 rounded-full p-2 z-10 transition-colors\"\n              >\n                <X className=\"w-5 h-5\" />\n              </button>\n\n              <div className=\"grid grid-cols-1 md:grid-cols-2\">\n                {/* Photo Stage */}\n                <div className=\"relative h-72 md:h-full min-h-[350px]\">\n                  <img\n                    src={detailedProduct.image}\n                    alt={detailedProduct.name}\n                    referrerPolicy=\"no-referrer\"\n                    className=\"absolute inset-0 w-full h-full object-cover\"\n                  />\n                  <div className=\"absolute inset-0 bg-gradient-to-t from-stone-950/60 via-transparent to-transparent\"></div>\n                  <div className=\"absolute bottom-6 left-6 right-6 text-white\">\n                    <span className=\"bg-amber-600 text-[10px] font-bold uppercase tracking-wider px-2.5 py-1 rounded-md shadow inline-block mb-2\">\n                      Handcrafted in {detailedProduct.origin}\n                    </span>\n                    <h2 className=\"text-xl md:text-2xl font-serif font-bold text-white leading-tight\">\n                      {detailedProduct.name}\n                    </h2>\n                  </div>\n                </div>\n\n                {/* Meta details */}\n                <div className=\"p-8 flex flex-col justify-between\">\n                  <div>\n                    <div className=\"flex items-center gap-1.5 mb-3 text-stone-400 text-xs\">\n                      <span className=\"text-stone-800 font-semibold uppercase\">{detailedProduct.category}</span>\n                      <span>\342\200\242</span>\n                      <div className=\"flex items-center gap-1 text-amber-500 font-bold\">\n                        <Star className=\"w-3.5 h-3.5 fill-amber-500\" />\n                        <span>{detailedProduct.rating.toFixed(1)}</span>\n                      </div>\n                    </div>\n\n                    <p className=\"text-stone-600 text-xs leading-relaxed mb-6\">\n                      {detailedProduct.description}\n                    </p>\n\n                    {/* Metadata table list */}\n                    <div className=\"space-y-2 border-t border-b border-stone-100 py-4 mb-6\">\n                      <div className=\"flex justify-between text-xs\">\n                        <span className=\"text-stone-400\">Artisan Center:</span>\n                        <span className=\"font-semibold text-stone-800\">{detailedProduct.origin}, Algeria</span>\n                      </div>\n                      {detailedProduct.material && (\n                        <div className=\"flex justify-between text-xs\">\n                          <span className=\"text-stone-400\">Authentic materials:</span>\n                          <span className=\"font-semibold text-stone-800\">{detailedProduct.material}</span>\n                        </div>\n                      )}\n                      {detailedProduct.size && (\n                        <div className=\"flex justify-between text-xs\">\n                          <span className=\"text-stone-400\">Available size:</span>\n                          <span className=\"font-semibold text-stone-800\">{detailedProduct.size}</span>\n                        </div>\n                      )}\n                      <div className=\"flex justify-between text-xs\">\n                        <span className=\"text-stone-400\">Available units:</span>\n                        <span className=\"font-semibold text-stone-800\">{detailedProduct.stock} units-in-stock</span>\n                      </div>\n                    </div>\n                  </div>\n\n                  {/* Pricing action cards inside modal */}\n                  <div>\n                    <div className=\"flex flex-col gap-3 mb-6\">\n                      {detailedProduct.isBuyable && (\n                        <div className=\"flex items-center justify-between bg-stone-50 p-3 rounded-xl border border-stone-100\">\n                          <div>\n                            <span className=\"text-[10px] text-stone-400 block tracking-wide uppercase\">Own permanently</span>\n                            <span className=\"font-mono font-bold text-stone-900\">{formatDZD(detailedProduct.price)}</span>\n                          </div>\n                          <button\n                            onClick={() => {\n                              onAddToCart(detailedProduct, \'buy\');\n                              setDetailedProduct(null);\n                            }}\n                            className=\"bg-stone-900 text-stone-100 text-xs font-bold px-4 py-2 rounded-lg hover:bg-stone-800 active:scale-95 duration-100 cursor-pointer\"\n                          >\n                            Buy Authenic Piece\n                          </button>\n                        </div>\n                      )}\n\n                      {detailedProduct.isRentable && detailedProduct.rentPrice && (\n                        <div className=\"flex items-center justify-between bg-emerald-50/50 p-3 rounded-xl border border-emerald-100\">\n                          <div>\n                            <span className=\"text-[10px] text-emerald-700 block tracking-wide uppercase font-semibold\">Rent (3-day minimum)</span>\n                            <span className=\"font-mono font-bold text-emerald-800\">{formatDZD(detailedProduct.rentPrice)}<span className=\"text-[11px] font-sans font-normal text-emerald-600 block\">per day</span></span>\n                          </div>\n                          <button\n                            onClick={() => {\n                              onAddToCart(detailedProduct, \'rent\');\n                              setDetailedProduct(null);\n                            }}\n                            className=\"bg-emerald-700 text-white text-xs font-bold px-4 py-2 rounded-lg hover:bg-emerald-800 active:scale-95 duration-100 cursor-pointer\"\n                          >\n                            Rent Garment\n                          </button>\n                        </div>\n                      )}\n                    </div>\n\n                    <div className=\"bg-stone-50 p-3 rounded-xl flex items-center gap-2 text-[11px] text-stone-500\">\n                      <Tag className=\"w-3.5 h-3.5 text-amber-600 shrink-0\" />\n                      <span>Rentals include professional sanitized cleaning and shipping insurance.</span>\n                    </div>\n                  </div>\n                </div>\n              </div>\n            </motion.div>\n          </div>\n        )}\n      </AnimatePresence>"
        replacement_content: "      {/* Product Detail Modal */}\n      <AnimatePresence>\n        {detailedProduct && (\n          <div className=\"fixed inset-0 bg-[#2D2D2D]/60 backdrop-blur-xs z-50 flex items-center justify-center p-4\">\n            <motion.div\n              initial={{ scale: 0.95, opacity: 0 }}\n              animate={{ scale: 1, opacity: 1 }}\n              exit={{ scale: 0.95, opacity: 0 }}\n              className=\"bg-[#F7F3F0] rounded-[54px] max-w-3xl w-full max-h-[90vh] overflow-y-auto shadow-2xl relative border border-[#D9D1C7]\"\n              id=\"product-detail-modal\"\n            >\n              {/* Close Button */}\n              <button\n                onClick={() => setDetailedProduct(null)}\n                className=\"absolute top-5 right-5 bg-white hover:bg-[#F1EDE8] text-[#8B4513] rounded-full p-2.5 z-10 transition-colors border border-[#D9D1C7]\"\n              >\n                <X className=\"w-4 h-4\" />\n              </button>\n \n              <div className=\"grid grid-cols-1 md:grid-cols-2\">\n                {/* Photo Stage (with Moorish Arch styling on the modal left edge) */}\n                <div className=\"relative h-72 md:h-full min-h-[400px] bg-[#E8E2DA] p-3\">\n                  <div className=\"w-full h-full rounded-t-[140px] rounded-b-[30px] overflow-hidden border border-[#D9D1C7]/60 relative\">\n                    <img\n                      src={detailedProduct.image}\n                      alt={detailedProduct.name}\n                      referrerPolicy=\"no-referrer\"\n                      className=\"absolute inset-0 w-full h-full object-cover\"\n                    />\n                    <div className=\"absolute inset-0 bg-gradient-to-t from-[#2D2D2D]/80 via-transparent to-transparent\"></div>\n                    <div className=\"absolute bottom-6 left-6 right-6 text-white\">\n                      <span className=\"bg-[#8B4513] text-[9px] font-bold uppercase tracking-wider px-3 py-1.5 rounded-full border border-[#D9D1C7]/30 inline-block mb-3\">\n                        Handcrafted in {detailedProduct.origin}\n                      </span>\n                      <h2 className=\"text-2xl md:text-3xl font-serif font-light text-white leading-tight\">\n                        {detailedProduct.name}\n                      </h2>\n                    </div>\n                  </div>\n                </div>\n \n                {/* Meta details */}\n                <div className=\"p-8 md:p-10 flex flex-col justify-between\">\n                  <div>\n                    <div className=\"flex items-center gap-1.5 mb-3 text-[#8B4513]/70 text-xs font-semibold\">\n                      <span className=\"text-[#BC5449] uppercase tracking-wider\">{detailedProduct.category}</span>\n                      <span>\342\200\242</span>\n                      <div className=\"flex items-center gap-1 text-[#BC5449]\">\n                        <Star className=\"w-3.5 h-3.5 fill-[#BC5449]\" />\n                        <span>{detailedProduct.rating.toFixed(1)}</span>\n                      </div>\n                    </div>\n \n                    <p className=\"text-[#1A1A1A]/80 text-xs leading-relaxed mb-6 font-sans\">\n                      {detailedProduct.description}\n                    </p>\n \n                    {/* Metadata table list */}\n                    <div className=\"space-y-2.5 border-t border-b border-[#D9D1C7] py-4 mb-6\">\n                      <div className=\"flex justify-between text-xs\">\n                        <span className=\"text-[#8B4513]/75 font-medium\">Artisan Center:</span>\n                        <span className=\"font-bold text-[#1A1A1A]\">{detailedProduct.origin}, Algeria</span>\n                      </div>\n                      {detailedProduct.material && (\n                        <div className=\"flex justify-between text-xs\">\n                          <span className=\"text-[#8B4513]/75 font-medium\">Authentic materials:</span>\n                          <span className=\"font-bold text-[#1A1A1A]\">{detailedProduct.material}</span>\n                        </div>\n                      )}\n                      {detailedProduct.size && (\n                        <div className=\"flex justify-between text-xs\">\n                          <span className=\"text-[#8B4513]/75 font-medium\">Available size:</span>\n                          <span className=\"font-bold text-[#1A1A1A]\">{detailedProduct.size}</span>\n                        </div>\n                      )}\n                      <div className=\"flex justify-between text-xs\">\n                        <span className=\"text-[#8B4513]/75 font-medium\">Available units:</span>\n                        <span className=\"font-bold text-[#1A1A1A]\">{detailedProduct.stock} units-in-stock</span>\n                      </div>\n                    </div>\n                  </div>\n \n                  {/* Pricing action cards inside modal */}\n                  <div>\n                    <div className=\"flex flex-col gap-3 mb-6\">\n                      {detailedProduct.isBuyable && (\n                        <div className=\"flex items-center justify-between bg-white p-3.5 rounded-3xl border border-[#D9D1C7]\">\n                          <div>\n                            <span className=\"text-[9px] text-[#8B4513]/60 block tracking-wider uppercase font-bold\">Own permanently</span>\n                            <span className=\"text-base font-bold text-[#1A1A1A] font-mono\">{formatDZD(detailedProduct.price)}</span>\n                          </div>\n                          <button\n                            onClick={() => {\n                              onAddToCart(detailedProduct, \'buy\');\n                              setDetailedProduct(null);\n                            }}\n                            className=\"bg-[#1A1A1A] text-white text-[10px] uppercase tracking-wider font-bold px-4 py-2.5 rounded-full hover:bg-[#8B4513] duration-150 cursor-pointer\"\n                          >\n                            Buy Authentic\n                          </button>\n                        </div>\n                      )}\n \n                      {detailedProduct.isRentable && detailedProduct.rentPrice && (\n                        <div className=\"flex items-center justify-between bg-white p-4 rounded-3xl border border-[#BC5449]/30\">\n                          <div>\n                            <span className=\"text-[9px] text-[#BC5449] block tracking-wider uppercase font-bold\">Rent garment</span>\n                            <span className=\"text-base font-bold text-[#BC5449] font-mono\">{formatDZD(detailedProduct.rentPrice)}<span className=\"text-[9px] font-sans font-normal text-stone-500 block\">per day</span></span>\n                          </div>\n                          <button\n                            onClick={() => {\n                              onAddToCart(detailedProduct, \'rent\');\n                              setDetailedProduct(null);\n                            }}\n                            className=\"bg-[#BC5449] text-white text-[10px] uppercase tracking-wider font-bold px-4 py-2.5 rounded-full hover:bg-[#1A1A1A] duration-150 cursor-pointer\"\n                          >\n                            Rent Outfit\n                          </button>\n                        </div>\n                      )}\n                    </div>\n \n                    <div className=\"bg-[#E8E2DA] p-3 rounded-2xl flex items-center gap-2 text-[10px] text-[#8B4513] font-semibold\">\n                      <Tag className=\"w-3.5 h-3.5 text-[#BC5449] shrink-0\" />\n                      <span>Rentals include professional sanitized cleaning and shipping insurance.</span>\n                    </div>\n                  </div>\n                </div>\n              </div>\n            </motion.div>\n          </div>\n        )}\n      </AnimatePresence>"
