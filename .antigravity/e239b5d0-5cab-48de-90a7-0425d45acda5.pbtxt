intricate gold thread embroidery from the heart of Tlemcen.</p>\\n          </div>\\n        </div>\\n      </div>\\n\\n      <!-- RIGHT: SELLER DASHBOARD PREVIEW -->\\n      <div class=\\\"col-span-5 flex flex-col\\\">\\n        <!-- SELLER OVERVIEW -->\\n        <div class=\\\"p-10 bg-[#2D2D2D] text-[#F1EDE8] flex-1\\\">\\n          <div class=\\\"flex items-center justify-between mb-10\\\">\\n            <div>\\n              <p class=\\\"text-[10px] uppercase tracking-widest opacity-60 mb-1\\\">Seller Dashboard</p>\\n              <h3 class=\\\"text-2xl font-serif\\\">El-Assala Studio</h3>\\n            </div>\\n            <div class=\\\"text-right text-xs opacity-60\\\">Member since<br/>Aug 2023</div>\\n          </div>\\n\\n          <!-- DASHBOARD STATS -->\\n          <div class=\\\"grid grid-cols-2 gap-4 mb-10\\\">\\n            <div class=\\\"border border-white/10 p-4\\\">\\n              <p class=\\\"text-[10px] uppercase text-white/50 mb-1\\\">Monthly Revenue</p>\\n              <p class=\\\"text-2xl font-mono text-[#BC5449]\\\">$4,820</p>\\n            </div>\\n            <div class=\\\"border border-white/10 p-4\\\">\\n              <p class=\\\"text-[10px] uppercase text-white/50 mb-1\\\">Pending Orders</p>\\n              <p class=\\\"text-2xl font-mono\\\">14</p>\\n            </div>\\n          </div>\\n\\n          <!-- INVENTORY STATUS -->\\n          <div>\\n            <div class=\\\"flex items-center justify-between mb-4 border-b border-white/10 pb-2\\\">\\n              <p class=\\\"text-[10px] uppercase tracking-widest text-white/70\\\">Active Inventory</p>\\n              <p class=\\\"text-[10px] text-[#BC5449] underline cursor-pointer\\\">Manage All</p>\\n            </div>\\n            <div class=\\\"space-y-4\\\">\\n              <div class=\\\"flex items-center justify-between text-sm\\\">\\n                <span class=\\\"opacity-70 font-light\\\">Karakou Algiers (Gold)</span>\\n                <span class=\\\"text-[10px] bg-green-900/40 text-green-400 px-2 py-0.5 border border-green-800\\\">6 IN STOCK</span>\\n              </div>\\n              <div class=\\\"flex items-center justify-between text-sm\\\">\\n                <span class=\\\"opacity-70 font-light\\\">Kabyle Silver Bracelet</span>\\n                <span class=\\\"text-[10px] bg-orange-900/40 text-orange-400 px-2 py-0.5 border border-orange-800\\\">LOW STOCK</span>\\n              </div>\\n              <div class=\\\"flex items-center justify-between text-sm\\\">\\n                <span class=\\\"opacity-70 font-light\\\">M\'zabite Ceramic Set</span>\\n                <span class=\\\"text-[10px] bg-white/10 px-2 py-0.5 border border-white/20\\\">12 IN STOCK</span>\\n              </div>\\n            </div>\\n          </div>\\n        </div>\\n\\n        <!-- FULFILLMENT PREVIEW -->\\n        <div class=\\\"p-10 bg-white border-t border-[#D9D1C7]\\\">\\n           <p class=\\\"text-[10px] uppercase tracking-widest mb-6 font-bold text-[#8B4513]\\\">Order Fulfillment</p>\\n           <div class=\\\"flex items-center gap-4\\\">\\n             <div class=\\\"w-12 h-12 bg-[#F7F3F0] border border-[#D9D1C7] flex items-center justify-center font-mono text-xs\\\">#882</div>\\n             <div class=\\\"flex-1\\\">\\n               <p class=\\\"text-xs font-bold\\\">Shipment for Sarah B.</p>\\n               <p class=\\\"text-[10px] text-gray-400\\\">Alger City Centre \342\200\242 Standard Shipping</p>\\n             </div>\\n             <button class=\\\"px-4 py-2 border border-[#1A1A1A] text-[10px] uppercase font-bold hover:bg-[#1A1A1A] hover:text-white\\\">Ship</button>\\n           </div>\\n        </div>\\n      </div>\\n    </div>\\n  </div>\\n</div>\\n                    </body>\\n                  </html>\n[AIS_METADATA_SECTION_END]"
