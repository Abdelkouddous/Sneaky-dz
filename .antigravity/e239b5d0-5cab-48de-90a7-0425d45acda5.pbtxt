  file_change {
    absolute_path_uri: "file:///src/components/SellerDashboard.tsx"
    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "import React, { useState } from \'react\';\nimport { motion, AnimatePresence } from \'motion/react\';\nimport { PlusCircle, ShoppingBag, DollarSign, CalendarRange, Trash2, Edit3, Save, Check, RefreshCw, Box, AlertCircle, FilePlus } from \'lucide-react\';\nimport { Product, Order, OrderStatus } from \'../types\';\nimport { ALGERIAN_CITIES } from \'../data\';\n\ninterface SellerDashboardProps {\n  products: Product[];\n  orders: Order[];\n  onAddProduct: (product: Product) => void;\n  onUpdateStock: (productId: string, newStock: number) => void;\n  onUpdateOrderStatus: (orderId: string, newStatus: OrderStatus) => void;\n  onDeleteProduct: (productId: string) => void;\n}\n\nexport default function SellerDashboard({\n  products,\n  orders,\n  onAddProduct,\n  onUpdateStock,\n  onUpdateOrderStatus,\n  onDeleteProduct\n}: SellerDashboardProps) {\n\n  // Current tab inside vendor area: \'inventory\' | \'orders\' | \'add-product\'\n  const [activeTab, setActiveTab] = useState<\'inventory\' | \'orders\' | \'add\' | \'stats\'>(\'stats\');\n\n  // Form states for creating a new design item\n  const [newName, setNewName] = useState(\'\');\n  const [newCat, setNewCat] = useState<\'clothing\' | \'handicrafts\' | \'art\'>(\'clothing\');\n  const [newDesc, setNewDesc] = useState(\'\');\n  const [newPrice, setNewPrice] = useState<number>(35000);\n  const [newRentPrice, setNewRentPrice] = useState<number>(2000);\n  const [isRentable, setIsRentable] = useState(true);\n  const [isBuyable, setIsBuyable] = useState(true);\n  const [newOrigin, setNewOrigin] = useState(\'Algiers\');\n  const [newStock, setNewStock] = useState<number>(3);\n  const [newMaterial, setNewMaterial] = useState(\'\');\n  const [newSize, setNewSize] = useState(\'\');\n  const [formSuccess, setFormSuccess] = useState(false);\n\n  // Quick edit stock state tracker\n  const [editingStockId, setEditingStockId] = useState<string | null>(null);\n  const [tempStock, setTempStock] = useState<number>(0);\n\n  // Sum up KPIs\n  const totalSalesVal = orders\n    .filter((o) => o.paymentStatus === \'paid\')\n    .reduce((acc, o) => acc + o.total, 0);\n\n  const activeRentalsCount = orders\n    .filter((o) => o.status !== \'delivered\' && o.status !== \'cancelled\')\n    .reduce((acc, o) => acc + o.items.filter(item => item.type === \'rent\').reduce((sum, i) => sum + i.quantity, 0), 0);\n\n  const formatDZD = (num: number) => {\n    return new Intl.NumberFormat(\'fr-DZ\', { style: \'currency\', currency: \'DZD\', maximumFractionDigits: 0 }).format(num);\n  };\n\n  const handleAddProductSubmit = (e: React.FormEvent) => {\n    e.preventDefault();\n    if (!newName || !newDesc) return;\n\n    // Use a high quality cultural preset image based on selected category to keep it beautiful\n    const categoryImages = {\n      clothing: \'https://images.unsplash.com/photo-1595777457583-95e059d581b8?auto=format&fit=crop&w=800&h=800&q=80\',\n      handicrafts: \'https://images.unsplash.com/photo-1579783900882-c0d3dad7b119?auto=format&fit=crop&w=800&h=800&q=80\',\n      art: \'https://images.unsplash.com/photo-1534447677768-be436bb09401?auto=format&fit=crop&w=800&h=800&q=80\'\n    };\n\n    const newPrd: Product = {\n      id: `p-${Date.now()}`,\n      name: newName,\n      category: newCat,\n      description: newDesc,\n      price: Number(newPrice),\n      rentPrice: isRentable ? Number(newRentPrice) : undefined,\n      image: categoryImages[newCat] || categoryImages.clothing,\n      sellerId: \'s_vendor_current\',\n      sellerName: \'My Artisan Atelier\',\n      stock: Number(newStock),\n      isRentable: isRentable,\n      isBuyable: isBuyable,\n      rating: 5.0, // New product gets 5 stars initial\n      origin: newOrigin,\n      material: newMaterial || undefined,\n      size: newSize || undefined\n    };\n\n    onAddProduct(newPrd);\n    setFormSuccess(true);\n    \n    // Clear state\n    setNewName(\'\');\n    setNewDesc(\'\');\n    setNewMaterial(\'\');\n    setNewSize(\'\');\n    setNewStock(3);\n    setNewPrice(35000);\n    setNewRentPrice(2000);\n\n    setTimeout(() => {\n      setFormSuccess(false);\n      setActiveTab(\'inventory\');\n    }, 2000);\n  };\n\n  const handleSaveStock = (pId: string) => {\n    onUpdateStock(pId, tempStock);\n    setEditingStockId(null);\n  };\n\n  return (\n    <div className=\"w-full bg-white rounded-3xl border border-stone-150 p-6 md:p-8 shadow-xs\" id=\"seller-zone\">\n      {/* Dashboard Top bar navigation state toggle */}\n      <div className=\"flex flex-col md:flex-row md:items-center justify-between border-b border-stone-150 pb-6 mb-8 gap-4\">\n        <div>\n          <span className=\"text-xs font-bold text-amber-700 uppercase tracking-widest block mb-1\">Seller Administration Mode</span>\n          <h2 className=\"font-serif text-2xl font-bold text-stone-900\">Artisan Guild Inventory & Fulfillment Portal</h2>\n        </div>\n\n        {/* Action Select buttons */}\n        <div className=\"flex flex-wrap gap-2\">\n          {[\n            { id: \'stats\', label: \'\360\237\223\212 Guild Stats\' },\n            { id: \'inventory\', label: \'\360\237\223\246 Stock Records\' },\n            { id: \'orders\', label: \'\360\237\223\234 Client Orders\' },\n            { id: \'add\', label: \'\342\236\225 Catalog New Item\' }\n          ].map((tab) => (\n            <button\n              key={tab.id}\n              onClick={() => setActiveTab(tab.id as any)}\n              className={`px-4 py-2 rounded-xl text-xs font-bold tracking-wide transition-all cursor-pointer ${\n                activeTab === tab.id\n                  ? \'bg-amber-800 text-white shadow-xs\'\n                  : \'bg-stone-50 border border-stone-200 text-stone-600 hover:bg-stone-100\'\n              }`}\n            >\n              {tab.label}\n            </button>\n          ))}\n        </div>\n      </div>\n\n      {/* RENDER STATS TAB */}\n      {activeTab === \'stats\' && (\n        <div className=\"space-y-8\" id=\"seller-dashboard-stats\">\n          {/* KPI metrics cluster */}\n          <div className=\"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6\">\n            <div className=\"bg-stone-50 rounded-2xl p-5 border border-stone-150\">\n              <div className=\"flex items-center justify-between mb-3 text-stone-400\">\n                <span className=\"text-xs font-semibold uppercase tracking-wider\">Gross Earnings</span>\n                <DollarSign className=\"w-5 h-5 text-amber-700\" />\n              </div>\n              <p className=\"text-2xl font-bold font-mono text-stone-900\">{formatDZD(totalSalesVal)}</p>\n              <span className=\"text-[10px] text-green-600 font-medium block mt-1\">100% Secure payout guaranteed</span>\n            </div>\n\n            <div className=\"bg-stone-50 rounded-2xl p-5 border border-stone-150\">\n              <div className=\"flex items-center justify-between mb-3 text-stone-400\">\n                <span className=\"text-xs font-semibold uppercase tracking-wider\">Fulfillment Orders</span>\n                <ShoppingBag className=\"w-5 h-5 text-indigo-700\" />\n              </div>\n              <p className=\"text-2xl font-bold font-mono text-stone-900\">{orders.length}</p>\n              <span className=\"text-[10px] text-stone-450 block mt-1\">\n                {orders.filter((o) => o.status === \'pending\').length} pending processing\n              </span>\n            </div>\n\n            <div className=\"bg-stone-50 rounded-2xl p-5 border border-stone-150\">\n              <div className=\"flex items-center justify-between mb-3 text-stone-400\">\n                <span className=\"text-xs font-semibold uppercase tracking-wider\">Active Dress Rentals</span>\n                <CalendarRange className=\"w-5 h-5 text-emerald-700\" />\n              </div>\n              <p className=\"text-2xl font-bold font-mono text-stone-900\">{activeRentalsCount}</p>\n              <span className=\"text-[10px] text-emerald-600 block mt-1\">Sanitized items due soon</span>\n            </div>\n\n            <div className=\"bg-stone-50 rounded-2xl p-5 border border-stone-150\">\n              <div className=\"flex items-center justify-between mb-3 text-stone-400\">\n                <span className=\"text-xs font-semibold uppercase tracking-wider\">Atelier Inventory</span>\n                <Box className=\"w-5 h-5 text-bronze-700\" />\n              </div>\n              <p className=\"text-2xl font-bold font-mono text-stone-900\">{products.length}</p>\n              <span className=\"text-[10px] text-amber-700 font-medium block mt-1\">Algerian genuine items</span>\n            </div>\n          </div>\n\n          <div className=\"grid grid-cols-1 lg:grid-cols-2 gap-8\">\n            {/* Quick alert panel */}\n            <div className=\"bg-amber-50/50 border border-amber-100 rounded-2xl p-6\">\n              <h4 className=\"font-serif text-base font-bold text-amber-900 mb-2 flex items-center gap-1.5\">\n                <AlertCircle className=\"w-5 h-5 text-amber-700\" />\n                Artisan Vendor Operations Advisory\n              </h4>\n              <p className=\"text-xs text-amber-800 leading-relaxed font-light mb-4\">\n                Dear Atelier Coordinator, please make sure all traditional royal garments listed for rental are thoroughly dry-cleaned and checked for premium weave count prior to mailing. Algerian brides expect impeccable standard for wedding garments.\n              </p>\n              <div className=\"space-y-2 text-xs\">\n                <div className=\"flex justify-between items-center bg-white p-2.5 rounded-lg border border-amber-100\">\n                  <span className=\"font-medium text-stone-700\">SATIM Gateway Settlement Limit:</span>\n                  <span className=\"font-bold text-stone-900 font-mono\">Real-time instantly</span>\n                </div>\n                <div className=\"flex justify-between items-center bg-white p-2.5 rounded-lg border border-amber-100\">\n                  <span className=\"font-medium text-stone-700\">National EMS Shipping Contract:</span>\n                  <span className=\"font-bold text-stone-900\">Signed with Yalidine</span>\n                </div>\n              </div>\n            </div>\n\n            {/* Quick action list */}\n            <div className=\"border border-stone-150 p-6 rounded-2xl flex flex-col justify-between\">\n              <div>\n                <h4 className=\"font-serif text-base font-bold text-stone-900 mb-2\">\n                  Atelier Quick Tasks\n                </h4>\n                <p className=\"text-stone-500 text-xs font-light mb-4\">\n                  Easily review inventory levels and list new heritage items to present to stakeholders. This serves as a fully interactive wireframe mock rendering.\n                </p>\n              </div>\n              <div className=\"flex gap-3\">\n                <button\n                  onClick={() => setActiveTab(\'add\')}\n                  className=\"bg-stone-900 hover:bg-stone-805 text-stone-100 px-4 py-2.5 rounded-xl font-bold text-xs flex items-center gap-1 cursor-pointer\"\n                >\n                  <PlusCircle className=\"w-4 h-4\" />\n                  List New Art\n                </button>\n                <button\n                  onClick={() => setActiveTab(\'inventory\')}\n                  className=\"bg-stone-100 hover:bg-stone-200 text-stone-700 px-4 py-2.5 rounded-xl font-bold text-xs cursor-pointer\"\n                >\n                  Inspect Stocks\n                </button>\n              </div>\n            </div>\n          </div>\n        </div>\n      )}\n\n      {/* RENDER INVENTORY TABLE */}\n      {activeTab === \'inventory\' && (\n        <div className=\"space-y-6\" id=\"seller-inventory-table\">\n          <div className=\"flex justify-between items-center mb-2\">\n            <h4 className=\"font-serif text-lg font-bold text-stone-900\">Atelier Stock Records</h4>\n            <span className=\"text-xs text-stone-400 font-mono\">{products.length} registered products</span>\n          </div>\n\n          <div className=\"overflow-x-auto border border-stone-150 rounded-2xl\">\n            <table className=\"w-full text-left border-collapse\">\n              <thead>\n                <tr className=\"bg-stone-50 text-stone-500 text-[10px] font-bold uppercase tracking-wider border-b border-stone-150\">\n                  <th className=\"px-6 py-4\">Product Details</th>\n                  <th className=\"px-6 py-4\">Region</th>\n                  <th className=\"px-6 py-4\">Mode Availability</th>\n                  <th className=\"px-6 py-4\">Financials</th>\n                  <th className=\"px-6 py-4\">Inventory Level</th>\n                  <th className=\"px-6 py-4 text-right\">Actions</th>\n                </tr>\n              </thead>\n              <tbody className=\"divide-y divide-stone-150 text-xs\">\n                {products.map((p) => (\n                  <tr key={p.id} className=\"hover:bg-stone-50/50 transition-colors\">\n                    <td className=\"px-6 py-4\">\n                      <div className=\"flex items-center gap-3\">\n                        <img\n                          src={p.image}\n                          alt={p.name}\n                          className=\"w-10 h-10 object-cover rounded-lg border border-stone-250 shrink-0\"\n                          referrerPolicy=\"no-referrer\"\n                        />\n                        <div>\n                          <p className=\"font-serif font-bold text-stone-900\">{p.name}</p>\n                          <p className=\"text-[10px] text-amber-800 font-semibold uppercase tracking-wider mt-0.5 capitalize\">\n                            {p.category}\n                          </p>\n                        </div>\n                      </div>\n                    </td>\n                    <td className=\"px-6 py-4 font-medium text-stone-600\">{p.origin}</td>\n                    <td className=\"px-6 py-4\">\n                      <div className=\"flex flex-col gap-1\">\n                        {p.isBuyable && (\n                          <span className=\"inline-flex self-start bg-amber-50 text-amber-800 text-[9px] font-bold px-2 py-0.5 rounded uppercase font-mono\">\n                            Purchasing\n                          </span>\n                        )}\n                        {p.isRentable && (\n                          <span className=\"inline-flex self-start bg-emerald-50 text-emerald-800 text-[9px] font-bold px-2 py-0.5 rounded uppercase font-mono\">\n                            Rents Available\n                          </span>\n                        )}\n                      </div>\n                    </td>\n                    <td className=\"px-6 py-4\">\n                      <div className=\"flex flex-col gap-0.5 font-mono\">\n                        {p.isBuyable && (\n                          <span className=\"font-semibold text-stone-800 text-xs\">\n                            Buy: {formatDZD(p.price)}\n                          </span>\n                        )}\n                        {p.isRentable && p.rentPrice && (\n                          <span className=\"text-[10px] text-emerald-700\">\n                            Rent: {formatDZD(p.rentPrice)}/d\n                          </span>\n                        )}\n                      </div>\n                    </td>\n                    <td className=\"px-6 py-4\">\n                      {editingStockId === p.id ? (\n                        <div className=\"flex items-center gap-1.5\" id={`editing-stock-container-${p.id}`}>\n                          <input\n                            type=\"number\"\n                            min=\"0\"\n                            value={tempStock}\n                            onChange={(e) => setTempStock(Math.max(0, Number(e.target.value)))}\n                            className=\"w-16 bg-white border border-stone-300 rounded px-2 py-1 text-xs font-mono font-bold text-center\"\n                          />\n                          <button\n                            onClick={() => handleSaveStock(p.id)}\n                            className=\"bg-emerald-600 text-white p-1 rounded hover:bg-emerald-700 cursor-pointer\"\n                            title=\"Save stock value\"\n                          >\n                            <Check className=\"w-3.5 h-3.5\" />\n                          </button>\n                        </div>\n                      ) : (\n                        <div className=\"flex items-center gap-2\">\n                          <span className={`font-mono font-bold text-sm text-stone-800 bg-stone-100 px-2.5 py-1 rounded ${\n                            p.stock <= 1 ? \'bg-red-50 text-red-700 font-extrabold\' : \'\'\n                          }`}>\n                            {p.stock}\n                          </span>\n                          <button\n                            onClick={() => {\n                              setEditingStockId(p.id);\n                              setTempStock(p.stock);\n                            }}\n                            className=\"text-stone-400 hover:text-amber-800 p-1\"\n                            title=\"Quick Adjust Inventory Level\"\n                          >\n                            <Edit3 className=\"w-3.5 h-3.5\" />\n                          </button>\n                        </div>\n                      )}\n                    </td>\n                    <td className=\"px-6 py-4 text-right\">\n                      <button\n                        onClick={() => onDeleteProduct(p.id)}\n                        className=\"text-stone-350 hover:text-red-700 p-1.5 transition-colors cursor-pointer\"\n                        title=\"Delete product listing\"\n                      >\n                        <Trash2 className=\"w-4 h-4\" />\n                      </button>\n                    </td>\n                  </tr>\n                ))}\n              </tbody>\n            </table>\n          </div>\n        </div>\n      )}\n\n      {/* RENDER INCOMING ORDERS */}\n      {activeTab === \'orders\' && (\n        <div className=\"space-y-6\" id=\"seller-orders-control\">\n          <div className=\"flex justify-between items-center mb-2\">\n            <h4 className=\"font-serif text-lg font-bold text-stone-900\">Custom Orders & Fulfillment Progress</h4>\n            <span className=\"text-xs text-stone-400 font-mono\">{orders.length} orders total</span>\n          </div>\n\n          {orders.length === 0 ? (\n            <div className=\"text-center py-16 bg-stone-50 rounded-2xl border border-dashed border-stone-200\">\n              <ShoppingBag className=\"w-8 h-8 text-stone-300 mx-auto mb-3\" />\n              <p className=\"text-xs font-serif font-bold text-stone-700\">No incoming orders yet</p>\n              <p className=\"text-[11px] text-stone-400 max-w-xs mx-auto mt-1\">\n                Go to Buyer Shop to complete a mock purchase or client clothes rental, then review fulfillment workflow here.\n              </p>\n            </div>\n          ) : (\n            <div className=\"space-y-6\">\n              {orders.map((order) => (\n                <div\n                  key={order.id}\n                  className=\"border border-stone-200 rounded-3xl p-6 bg-white hover:shadow-xs transition-shadow\"\n                  id={`vendor-order-card-${order.id}`}\n                >\n                  {/* Order metadata top row */}\n                  <div className=\"flex flex-col md:flex-row md:items-center justify-between border-b border-stone-100 pb-4 mb-4 gap-2\">\n                    <div>\n                      <div className=\"flex items-center gap-2\">\n                        <span className=\"font-mono font-bold text-sm text-stone-900 bg-stone-100 px-2 py-0.5 rounded\">\n                          {order.id}\n                        </span>\n                        <span className=\"text-xs text-stone-400 font-mono\">{order.date}</span>\n                      </div>\n                      <p className=\"text-stone-500 text-xs mt-1\">\n                        Client: <span className=\"font-semibold text-stone-700\">{order.customerName}</span> ({order.customerEmail})\n                      </p>\n                    </div>\n\n                    {/* FULFILLMENT STATUS SWITCH CONTROLLER */}\n                    <div className=\"flex items-center gap-3\">\n                      <span className=\"text-[11px] text-stone-400 font-medium\">Fulfillment Status:</span>\n                      <select\n                        value={order.status}\n                        onChange={(e) => onUpdateOrderStatus(order.id, e.target.value as OrderStatus)}\n                        className={`text-xs font-bold px-3 py-1.5 rounded-xl border focus:outline-none ${\n                          order.status === \'pending\'\n                            ? \'bg-amber-50 text-amber-800 border-amber-200\'\n                            : order.status === \'processing\'\n                            ? \'bg-blue-50 text-blue-800 border-blue-200\'\n                            : order.status === \'shipped\'\n                            ? \'bg-indigo-50 text-indigo-850 border-indigo-200\'\n                            : order.status === \'delivered\'\n                            ? \'bg-emerald-50 text-emerald-800 border-emerald-200\'\n                            : \'bg-stone-50 text-stone-500 border-stone-200\'\n                        }`}\n                      >\n                        <option value=\"pending\">Pending Review</option>\n                        <option value=\"processing\">Processing & Packaged</option>\n                        <option value=\"shipped\">On Transit (Yalidine EMS)</option>\n                        <option value=\"delivered\">Completed / Delivered</option>\n                        <option value=\"cancelled\">Cancelled</option>\n                      </select>\n                    </div>\n                  </div>\n\n                  {/* Items list & shipping columns */}\n                  <div className=\"grid grid-cols-1 md:grid-cols-12 gap-6\">\n                    <div className=\"md:col-span-7 space-y-3\">\n                      <span className=\"text-[10px] font-bold uppercase tracking-wider text-stone-400 block\">\n                        Ordered Items\n                      </span>\n                      {order.items.map((item, index) => (\n                        <div key={index} className=\"flex gap-3 align-start text-xs border-b border-stone-50 pb-2\">\n                          <img\n                            src={item.image}\n                            alt={item.productName}\n                            className=\"w-10 h-10 object-cover rounded-lg border border-stone-150 shrink-0\"\n                            referrerPolicy=\"no-referrer\"\n                          />\n                          <div className=\"flex-1\">\n                            <p className=\"font-serif font-bold text-stone-800 leading-tight\">{item.productName}</p>\n                            <p className=\"text-[10px] text-stone-450 mt-1\">\n                              Fulfillment Category: <span className=\"text-stone-750 font-medium capitalize\">{item.category}</span>\n                            </p>\n                          </div>\n                          <div className=\"text-right\">\n                            <p className=\"font-semibold text-stone-800 font-mono\">\n                              {item.type === \'buy\' ? \'Buy Purchase\' : `Rent (${item.durationDays} days)`}\n                            </p>\n                            <p className=\"text-[10px] text-stone-400 font-mono\">Qty: {item.quantity}</p>\n                          </div>\n                        </div>\n                      ))}\n                    </div>\n\n                    {/* Delivery instructions column */}\n                    <div className=\"md:col-span-5 bg-stone-50 rounded-2xl p-4 text-xs font-sans space-y-3 border border-stone-100\">\n                      <div>\n                        <span className=\"text-[9px] font-bold uppercase tracking-wider text-stone-400 block mb-1\">\n                          Delivery Destinaton\n                        </span>\n                        <p className=\"font-medium text-stone-800 leading-normal\">\n                          {order.address}, {order.postalCode} <br />\n                          {order.city}, Algeria\n                        </p>\n                      </div>\n\n                      <div className=\"pt-2 border-t border-stone-150 flex justify-between\">\n                        <div>\n                          <span className=\"text-[9px] font-bold uppercase tracking-wider text-stone-400 block\">\n                            Contact dial\n                          </span>\n                          <span className=\"font-semibold text-stone-850 font-mono block mt-0.5\">{order.customerPhone}</span>\n                        </div>\n                        <div className=\"text-right\">\n                          <span className=\"text-[9px] font-bold uppercase tracking-wider text-stone-400 block\">\n                            Payment system\n                          </span>\n                          <span className=\"bg-yellow-400/10 text-amber-900 border border-amber-350/20 px-1.5 py-0.5 rounded font-extrabold text-[10px] uppercase inline-block mt-0.5\">\n                            {order.paymentMethod}\n                          </span>\n                        </div>\n                      </div>\n\n                      {order.rentalStartDate && (\n                        <div className=\"pt-2 border-t border-stone-150 bg-emerald-50/50 p-2 text-[10px] text-emerald-800 rounded\">\n                          <p className=\"font-bold flex items-center gap-1\">\n                            \360\237\223\205 Registered Dress Rental Period:\n                          </p>\n                          <p className=\"mt-1 font-mono\">\n                            Start: {order.rentalStartDate} | Return: {order.rentalEndDate}\n                          </p>\n                        </div>\n                      )}\n                    </div>\n                  </div>\n\n                  {/* Financial Total block */}\n                  <div className=\"border-t border-stone-100 pt-4 mt-4 flex justify-between items-center text-xs\">\n                    <span className=\"text-stone-400\">Transaction ID: <span className=\"font-mono text-[10px] font-bold text-stone-700\">{order.transactionId || \'N/A\'}</span></span>\n                    <span className=\"text-stone-500\">Gross Total payout: <span className=\"font-mono font-bold text-base text-amber-800\">{formatDZD(order.total)}</span></span>\n                  </div>\n                </div>\n              ))}\n            </div>\n          )}\n        </div>\n      )}\n\n      {/* RENDER ADD PRODUCT FORM */}\n      {activeTab === \'add\' && (\n        <form onSubmit={handleAddProductSubmit} className=\"space-y-6\" id=\"add-heritage-product-form\">\n          <div className=\"flex items-center gap-2 mb-2 pb-3 border-b border-stone-100\">\n            <FilePlus className=\"w-5 h-5 text-amber-700\" />\n            <h4 className=\"font-serif text-lg font-bold text-stone-900\">List New Traditional Algerian Work</h4>\n          </div>\n\n          <p className=\"text-stone-500 text-xs font-light mb-6\">\n            Input the specifications of your traditional handicraft or dress. Once submitted, it will instantly add to the local marketplace catalog to allow seamless buyer flow simulation testing.\n          </p>\n\n          {formSuccess && (\n            <motion.div\n              initial={{ scale: 0.9, opacity: 0 }}\n              animate={{ scale: 1, opacity: 1 }}\n              className=\"bg-emerald-50 border border-emerald-250 p-4 rounded-xl text-emerald-800 text-xs font-semibold flex items-center gap-2\"\n            >\n              <Check className=\"w-5 h-5\" />\n              <span>Beautiful product listed successfully! Redirecting back to your stock records...</span>\n            </motion.div>\n          )}\n\n          <div className=\"grid grid-cols-1 md:grid-cols-2 gap-6\">\n            {/* Left Col */}\n            <div className=\"space-y-4\">\n              <div>\n                <label className=\"block text-[11px] font-semibold uppercase tracking-wider text-stone-400 mb-1\">\n                  Product Name\n                </label>\n                <input\n                  type=\"text\"\n                  required\n                  placeholder=\"e.g., Embroidered Velvet Kabyle Cap (Chechia)\"\n                  value={newName}\n                  onChange={(e) => setNewName(e.target.value)}\n                  className=\"w-full bg-stone-50 border border-stone-200 rounded-xl px-4 py-2.5 text-xs focus:outline-none focus:border-amber-600 text-stone-800 font-sans\"\n                />\n              </div>\n\n              <div className=\"grid grid-cols-2 gap-4\">\n                <div>\n                  <label className=\"block text-[11px] font-semibold uppercase tracking-wider text-stone-400 mb-1\">\n                    Artifact Category\n                  </label>\n                  <select\n                    value={newCat}\n                    onChange={(e: any) => setNewCat(e.target.value)}\n                    className=\"w-full bg-stone-50 border border-stone-200 rounded-xl px-4 py-2.5 text-xs focus:outline-none focus:border-amber-600 text-stone-800\"\n                  >\n                    <option value=\"clothing\">Garments & Dress</option>\n                    <option value=\"handicrafts\">Handicraft</option>\n                    <option value=\"art\">Rug / Arts</option>\n                  </select>\n                </div>\n                <div>\n                  <label className=\"block text-[11px] font-semibold uppercase tracking-wider text-stone-400 mb-1\">\n                    Atelier Region\n                  </label>\n                  <select\n                    value={newOrigin}\n                    onChange={(e) => setNewOrigin(e.target.value)}\n                    className=\"w-full bg-stone-50 border border-stone-200 rounded-xl px-4 py-2.5 text-xs focus:outline-none focus:border-amber-600 text-stone-800\"\n                  >\n                    {ALGERIAN_CITIES.map((city) => (\n                      <option key={city} value={city}>\n                        {city}\n                      </option>\n                    ))}\n                  </select>\n                </div>\n              </div>\n\n              <div className=\"grid grid-cols-2 gap-4\">\n                <div>\n                  <label className=\"block text-[11px] font-semibold uppercase tracking-wider text-stone-400 mb-1\">\n                    Authentic Material\n                  </label>\n                  <input\n                    type=\"text\"\n                    placeholder=\"e.g., Pure silk, sheep wool, clay\"\n                    value={newMaterial}\n                    onChange={(e) => setNewMaterial(e.target.value)}\n                    className=\"w-full bg-stone-50 border border-stone-200 rounded-xl px-4 py-2.5 text-xs focus:outline-none focus:border-amber-600 text-stone-800\"\n                  />\n                </div>\n                <div>\n                  <label className=\"block text-[11px] font-semibold uppercase tracking-wider text-stone-400 mb-1\">\n                    Garment Size (optional)\n                  </label>\n                  <input\n                    type=\"text\"\n                    placeholder=\"e.g., M (Adjustable), L\"\n                    value={newSize}\n                    onChange={(e) => setNewSize(e.target.value)}\n                    className=\"w-full bg-stone-50 border border-stone-200 rounded-xl px-4 py-2.5 text-xs focus:outline-none focus:border-amber-600 text-stone-800\"\n                  />\n                </div>\n              </div>\n\n              <div>\n                <label className=\"block text-[11px] font-semibold uppercase tracking-wider text-stone-400 mb-1\">\n                  Product Description & Historical Significance\n                </label>\n                <textarea\n                  required\n                  rows={4}\n                  placeholder=\"Tell clients where this item is made, who crafted it, and details of its cultural style...\"\n                  value={newDesc}\n                  onChange={(e) => setNewDesc(e.target.value)}\n                  className=\"w-full bg-stone-50 border border-stone-200 rounded-xl px-4 py-2.5 text-xs focus:outline-none focus:border-amber-600 text-stone-800 leading-normal\"\n                />\n              </div>\n            </div>\n\n            {/* Right Col */}\n            <div className=\"space-y-4\">\n              <div className=\"bg-stone-50 p-5 rounded-2xl border border-stone-150 space-y-4\">\n                <span className=\"text-xs font-bold uppercase tracking-wider text-stone-400 block mb-2\">\n                  Pricing & Fulfillment Schemes\n                </span>\n\n                <div className=\"flex items-center gap-6 pb-2 border-b border-stone-200\">\n                  <label className=\"flex items-center gap-2 cursor-pointer text-xs\">\n                    <input\n                      type=\"checkbox\"\n                      checked={isBuyable}\n                      onChange={(e) => setIsBuyable(e.target.checked)}\n                      className=\"accent-amber-600\"\n                    />\n                    <span className=\"font-semibold text-stone-700\">Available to buy permanente</span>\n                  </label>\n                  <label className=\"flex items-center gap-2 cursor-pointer text-xs\">\n                    <input\n                      type=\"checkbox\"\n                      checked={isRentable}\n                      onChange={(e) => setIsRentable(e.target.checked)}\n                      className=\"accent-amber-600\"\n                    />\n                    <span className=\"font-semibold text-stone-700\">Available to rent temporarily</span>\n                  </label>\n                </div>\n\n                {isBuyable && (\n                  <div>\n                    <label className=\"block text-[10px] font-semibold uppercase tracking-wider text-stone-400 mb-1\">\n                      Sale Valuation Price (DZD)\n                    </label>\n                    <input\n                      type=\"number\"\n                      required={isBuyable}\n                      min=\"5000\"\n                      value={newPrice}\n                      onChange={(e) => setNewPrice(Number(e.target.value))}\n                      className=\"w-full bg-white border border-stone-200 rounded-lg px-3 py-2 text-xs font-mono font-bold\"\n                    />\n                  </div>\n                )}\n\n                {isRentable && (\n                  <div>\n                    <label className=\"block text-[10px] font-semibold uppercase tracking-wider text-stone-400 mb-1\">\n                      Daily Rental Rate Price (DZD / day)\n                    </label>\n                    <input\n                      type=\"number\"\n                      required={isRentable}\n                      min=\"500\"\n                      value={newRentPrice}\n                      onChange={(e) => setNewRentPrice(Number(e.target.value))}\n                      className=\"w-full bg-white border border-stone-200 rounded-lg px-3 py-2 text-xs font-mono font-bold\"\n                    />\n                  </div>\n                )}\n\n                <div>\n                  <label className=\"block text-[10px] font-semibold uppercase tracking-wider text-stone-400 mb-1\">\n                    Atelier Storage quantity (Stock level)\n                  </label>\n                  <input\n                    type=\"number\"\n                    min=\"1\"\n                    required\n                    value={newStock}\n                    onChange={(e) => setNewStock(Number(e.target.value))}\n                    className=\"w-full bg-white border border-stone-200 rounded-lg px-3 py-2 text-xs font-mono font-bold\"\n                  />\n                </div>\n              </div>\n\n              <div className=\"bg-amber-50/40 p-4 rounded-xl border border-amber-100 flex items-start gap-2.5 text-[11px] text-amber-900 leading-normal\">\n                <AlertCircle className=\"w-5 h-5 text-amber-700 shrink-0\" />\n                <span>\n                  <strong>Prototype Note:</strong> To keep this MVP robust, a preset high-resolution editorial background image will be automatically mapped to your product according to the material category.\n                </span>\n              </div>\n            </div>\n          </div>\n\n          <div className=\"mt-8 flex justify-end\">\n            <button\n              type=\"submit\"\n              className=\"bg-amber-800 hover:bg-amber-900 text-stone-50 font-bold text-xs tracking-wider py-3 px-8 rounded-xl transition-all cursor-pointer\"\n            >\n              List Heritage Piece to Market\n            </button>\n          </div>\n        </form>\n      )}\n    </div>\n  );\n}\n"
