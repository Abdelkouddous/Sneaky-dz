    replacement_chunks {
      replacement_content: "import { Product, Seller } from \'./types\';\n\nexport const INITIAL_SELLERS: Seller[] = [\n  {\n    id: \'s1\',\n    storeName: \'Dar El Karakou Algiers\',\n    email: \'contact@dar-karakou.dz\',\n    joinedDate: \'2025-01-15\',\n  },\n  {\n    id: \'s2\',\n    storeName: \'Artisanal Treasures of Ghardaia\',\n    email: \'mohamed.mzab@ghardaia-crafts.dz\',\n    joinedDate: \'2025-02-10\',\n  },\n  {\n    id: \'s3\',\n    storeName: \'Tlemcen Bridal Heritage\',\n    email: \'tlemcen.bridals@heritage.dz\',\n    joinedDate: \'2025-03-01\',\n  },\n  {\n    id: \'s4\',\n    storeName: \'Moorish Ceramics & Co.\',\n    email: \'khalil@moorish-ceramics.dz\',\n    joinedDate: \'2025-04-12\',\n  }\n];\n\nexport const INITIAL_PRODUCTS: Product[] = [\n  {\n    id: \'p1\',\n    name: \'Royal Algerian Karakou Deluxe\',\n    category: \'clothing\',\n    description: \'An elite Algiers Karakou jacket fashioned from royal black velvet. It is entirely hand-embroidered using premium metallic gold threads in traditional \"Majboud\" motifs, paired with smooth fluid silk sarouel challenger pants. Perfect for Algerian wedding ceremonies and royal celebrations.\',\n    price: 85000,\n    rentPrice: 4200,\n    image: \'https://images.unsplash.com/photo-1595777457583-95e059d581b8?auto=format&fit=crop&w=800&h=800&q=80\',\n    sellerId: \'s1\',\n    sellerName: \'Dar El Karakou Algiers\',\n    stock: 2,\n    isRentable: true,\n    isBuyable: true,\n    rating: 4.9,\n    origin: \'Algiers\',\n    material: \'Royal Velvet & Silk\',\n    size: \'M / L (Adjustable corset back)\'\n  },\n  {\n    id: \'p2\',\n    name: \'Tlemcen Bridal Chedda Outfit\',\n    category: \'clothing\',\n    description: \'A genuine high-collar UNESCO-heritage Chedda of Tlemcen. This breathtaking setup includes the kaftan, direct silk brocade wraps, and a majestic head ornament layout lavishly decorated with replica baroque pearls, gold medallions, and colorful handwoven silk trim.\',\n    price: 165000,\n    rentPrice: 8500,\n    image: \'https://images.unsplash.com/photo-1610030469983-98e550d6193c?auto=format&fit=crop&w=800&h=800&q=80\',\n    sellerId: \'s3\',\n    sellerName: \'Tlemcen Bridal Heritage\',\n    stock: 1,\n    isRentable: true,\n    isBuyable: true,\n    rating: 5.0,\n    origin: \'Tlemcen\',\n    material: \'Brocade, Velvet, Pearl embellishments\',\n    size: \'Fits sizes S to L (Custom laced fit)\'\n  },\n  {\n    id: \'p3\',\n    name: \'Berber handwoven Margoum Rug\',\n    category: \'art\',\n    description: \'A majestic high-density wool rug woven by the artisan women of the Mzab valley in Ghardaia. Features authentic geometric \"Margoum\" diamond symbols indicating protection, family unity, and prosperity. Dyed naturally using saffron, pomegranate skins, and indigo.\',\n    price: 98000,\n    image: \'https://images.unsplash.com/photo-1534447677768-be436bb09401?auto=format&fit=crop&w=800&h=800&q=80\',\n    sellerId: \'s2\',\n    sellerName: \'Artisanal Treasures of Ghardaia\',\n    stock: 3,\n    isRentable: false,\n    isBuyable: true,\n    rating: 4.8,\n    origin: \'Ghardaia\',\n    material: \'100% Organic Sheep Wool\'\n  },\n  {\n    id: \'p4\',\n    name: \'Traditional Kabyle Ribbon Dress (Foutha)\',\n    category: \'clothing\',\n    description: \'A magnificent everyday and ceremony Kabyle dress made from light breathable cotton. Decorated with traditional brightly colored silk ribbons in red, orange, and sunshine yellow arranged in intricate tribal zigzag patterns. Accompanied by a matching handwoven striped Foutha sash.\',\n    price: 24000,\n    rentPrice: 1500,\n    image: \'https://images.unsplash.com/photo-1607823476837-de16104bc1f5?auto=format&fit=crop&w=800&h=800&q=80\',\n    sellerId: \'s1\',\n    sellerName: \'Dar El Karakou Algiers\',\n    stock: 5,\n    isRentable: true,\n    isBuyable: true,\n    rating: 4.7,\n    origin: \'Kabylie\',\n    material: \'Premium Cotton & Satin Ribbons\',\n    size: \'M / L / XL\'\n  },\n  {\n    id: \'p5\',\n    name: \'Hand-Painted Moorish Zellij Ceramic Vase\',\n    category: \'handicrafts\',\n    description: \'Elegant wide-mouth terracotta vase painted by master potters from Tlemcen. Features intricate Moorish geometric wall Zellij patterns combined with traditional blue-and-green glazed floral designs. Fire-hardened twice in a traditional wood oven for maximum longevity.\',\n    price: 18500,\n    image: \'https://images.unsplash.com/photo-1579783900882-c0d3dad7b119?auto=format&fit=crop&w=800&h=800&q=80\',\n    sellerId: \'s4\',\n    sellerName: \'Moorish Ceramics & Co.\',\n    stock: 6,\n    isRentable: false,\n    isBuyable: true,\n    rating: 4.6,\n    origin: \'Tlemcen\',\n    material: \'Terracotta & Glazed Ceramics\'\n  },\n  {\n    id: \'p6\',\n    name: \'Constantine Engraved Copper Tea Service\',\n    category: \'handicrafts\',\n    description: \'An old-world copper teapot with an elegant swan-neck spout, hand-chiselled with fine traditional floral scrollwork. Includes a large matching 40cm copper serving tray and six heat-resistant tea glasses wrapped in delicate copper filigree jackets.\',\n    price: 32000,\n    image: \'https://images.unsplash.com/photo-1576092768241-dec231879fc3?auto=format&fit=crop&w=800&h=800&q=80\',\n    sellerId: \'s2\',\n    sellerName: \'Artisanal Treasures of Ghardaia\',\n    stock: 4,\n    isRentable: false,\n    isBuyable: true,\n    rating: 4.9,\n    origin: \'Constantine\',\n    material: \'100% Solid Engraved Copper\'\n  },\n  {\n    id: \'p7\',\n    name: \'Kabyle Enamelled Silver Brooch (Akhellal)\',\n    category: \'handicrafts\',\n    description: \'A museum-quality, historic Kabyle sterling silver triangular brooch (Akhellal). Meticulously decorated using traditional vibrant yellow, sky blue, and green cloisonn\303\251 enamels and set with premium red coral cabochons from the Mediterranean coast of B\303\251ja\303\257a.\',\n    price: 49000,\n    rentPrice: 3000,\n    image: \'https://images.unsplash.com/photo-1599643478518-a784e5dc4c8f?auto=format&fit=crop&w=800&h=800&q=80\',\n    sellerId: \'s3\',\n    sellerName: \'Tlemcen Bridal Heritage\',\n    stock: 2,\n    isRentable: true,\n    isBuyable: true,\n    rating: 5.0,\n    origin: \'Kabylie\',\n    material: \'925 Sterling Silver & Genuine Mediterranean Coral\'\n  },\n  {\n    id: \'p8\',\n    name: \'Moroccan-Algerian Brass Lantern (Fanal)\',\n    category: \'handicrafts\',\n    description: \'A gorgeous brass tabletop and hanging lantern featuring intricate hand-punched star-burst patterns. Adorned with amber and royal-blue stained glass panels that scatter stunning ambient geometric shadows of traditional Islamic art across any space.\',\n    price: 13500,\n    image: \'https://images.unsplash.com/photo-1540555700478-4be289fbecef?auto=format&fit=crop&w=800&h=800&q=80\',\n    sellerId: \'s4\',\n    sellerName: \'Moorish Ceramics & Co.\',\n    stock: 8,\n    isRentable: false,\n    isBuyable: true,\n    rating: 4.5,\n    origin: \'Algiers\',\n    material: \'Solid Brass & Stained Glass panels\'\n  }\n];\n\nexport const ALGERIAN_CITIES = [\n  \'Algiers\',\n  \'Tlemcen\',\n  \'Kabylie\',\n  \'Ghardaia\',\n  \'Constantine\',\n  \'Oran\',\n  \'Biskra\'\n];\n"
    }
