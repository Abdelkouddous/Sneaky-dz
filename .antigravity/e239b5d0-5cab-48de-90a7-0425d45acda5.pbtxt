    instruction: "Style the tabs, statistics, alerts and task components in SellerDashboard.tsx with Artistic Flair theme."
    replacement_infos {
      original_chunk {
        target_content: "  return (\n    <div className=\"w-full bg-white rounded-3xl border border-stone-150 p-6 md:p-8 shadow-xs\" id=\"seller-zone\">\n      {/* Dashboard Top bar navigation state toggle */}\n      <div className=\"flex flex-col md:flex-row md:items-center justify-between border-b border-stone-150 pb-6 mb-8 gap-4\">\n        <div>\n          <span className=\"text-xs font-bold text-amber-700 uppercase tracking-widest block mb-1\">Seller Administration Mode</span>\n          <h2 className=\"font-serif text-2xl font-bold text-stone-900\">Artisan Guild Inventory & Fulfillment Portal</h2>\n        </div>\n\n        {/* Action Select buttons */}\n        <div className=\"flex flex-wrap gap-2\">\n          {[\n            { id: \'stats\', label: \'\360\237\223\212 Guild Stats\' },\n            { id: \'inventory\', label: \'\360\237\223\246 Stock Records\' },\n            { id: \'orders\', label: \'\360\237\223\234 Client Orders\' },\n            { id: \'add\', label: \'\342\236\225 Catalog New Item\' }\n          ].map((tab) => (\n            <button\n              key={tab.id}\n              onClick={() => setActiveTab(tab.id as any)}\n              className={`px-4 py-2 rounded-xl text-xs font-bold tracking-wide transition-all cursor-pointer ${\n                activeTab === tab.id\n                  ? \'bg-amber-800 text-white shadow-xs\'\n                  : \'bg-stone-50 border border-stone-200 text-stone-600 hover:bg-stone-100\'\n              }`}\n            >\n              {tab.label}\n            </button>\n          ))}\n        </div>\n      </div>\n\n      {/* RENDER STATS TAB */}\n      {activeTab === \'stats\' && (\n        <div className=\"space-y-8\" id=\"seller-dashboard-stats\">\n          {/* KPI metrics cluster */}\n          <div className=\"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6\">\n            <div className=\"bg-stone-50 rounded-2xl p-5 border border-stone-150\">\n              <div className=\"flex items-center justify-between mb-3 text-stone-400\">\n                <span className=\"text-xs font-semibold uppercase tracking-wider\">Gross Earnings</span>\n                <DollarSign className=\"w-5 h-5 text-amber-700\" />\n              </div>\n              <p className=\"text-2xl font-bold font-mono text-stone-900\">{formatDZD(totalSalesVal)}</p>\n              <span className=\"text-[10px] text-green-600 font-medium block mt-1\">100% Secure payout guaranteed</span>\n            </div>\n\n            <div className=\"bg-stone-50 rounded-2xl p-5 border border-stone-150\">\n              <div className=\"flex items-center justify-between mb-3 text-stone-400\">\n                <span className=\"text-xs font-semibold uppercase tracking-wider\">Fulfillment Orders</span>\n                <ShoppingBag className=\"w-5 h-5 text-indigo-700\" />\n              </div>\n              <p className=\"text-2xl font-bold font-mono text-stone-900\">{orders.length}</p>\n              <span className=\"text-[10px] text-stone-450 block mt-1\">\n                {orders.filter((o) => o.status === \'pending\').length} pending processing\n              </span>\n            </div>\n\n            <div className=\"bg-stone-50 rounded-2xl p-5 border border-stone-150\">\n              <div className=\"flex items-center justify-between mb-3 text-stone-400\">\n                <span className=\"text-xs font-semibold uppercase tracking-wider\">Active Dress Rentals</span>\n                <CalendarRange className=\"w-5 h-5 text-emerald-700\" />\n              </div>\n              <p className=\"text-2xl font-bold font-mono text-stone-900\">{activeRentalsCount}</p>\n              <span className=\"text-[10px] text-emerald-600 block mt-1\">Sanitized items due soon</span>\n            </div>\n\n            <div className=\"bg-stone-50 rounded-2xl p-5 border border-stone-150\">\n              <div className=\"flex items-center justify-between mb-3 text-stone-400\">\n                <span className=\"text-xs f