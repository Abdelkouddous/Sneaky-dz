        target_content: "                {/* Garment Rental parameters */}\n                {hasRentals && (\n                  <div className=\"bg-emerald-50/50 border border-emerald-150 rounded-2xl p-5 mt-6\">\n                    <h5 className=\"font-serif text-sm font-bold text-emerald-900 flex items-center gap-1.5 mb-3.5\">\n                      \360\237\223\205 Configure Heritage Wear Rent Range\n                    </h5>\n                    <p className=\"text-[11px] text-emerald-800 mb-4 font-light\">\n                      At least one clothing or jewelry product is selected to rent. Pick your starting date and period. Daily rentals include fully dry-cleaned garments.\n                    </p>\n                    <div className=\"grid grid-cols-2 gap-4\">\n                      <div>\n                        <label className=\"block text-[10px] font-semibold uppercase tracking-wider text-stone-400 mb-1\">\n                          Delivery Start Date\n                        </label>\n                        <input\n                          type=\"date\"\n                          value={rentalDate}\n                          min={new Date().toISOString().split(\'T\')[0]}\n                          onChange={(e) => setRentalDate(e.target.value)}\n                          className=\"w-full bg-white border border-stone-200 rounded-lg px-3 py-2 text-xs text-stone-850\"\n                        />\n                      </div>\n                      <div>\n                        <label className=\"block text-[10px] font-semibold uppercase tracking-wider text-stone-400 mb-1\">\n                          Rental Length (days)\n                        </label>\n                        <select\n                          value={rentalDays}\n                          onChange={(e) => setRentalDays(Number(e.target.value))}\n                          className=\"w-full bg-white border border-stone-200 rounded-lg px-3 py-2 text-xs text-stone-850\"\n                        >\n                          <option value=\"3\">3 Days (Ceremony basic)</option>\n                          <option value=\"5\">5 Days (Wedding length)</option>\n                          <option value=\"7\">7 Days (Full week festival)</option>\n                          <option value=\"14\">14 Days (Extended vacation)</option>\n                        </select>\n                      </div>\n                    </div>\n                  </div>\n                )}\n\n                <div className=\"mt-8 flex justify-end\">\n                  <button\n                    type=\"submit\"\n                    className=\"bg-amber-800 hover:bg-amber-900 text-white font-bold text-xs tracking-wider py-3 px-6 rounded-xl flex items-center gap-1.5 transition-all outline-none cursor-pointer\"\n                  >\n                    Proceed to Payment Gate\n                    <ArrowRight className=\"w-4 h-4\" />\n                  </button>\n                </div>"
        replacement_content: "                {/* Garment Rental parameters */}\n                {hasRentals && (\n                  <div className=\"bg-[#E8E2DA]/50 border border-[#D9D1C7] rounded-[30px] p-5 mt-6 text-[#8B4513]\">\n                    <h5 className=\"font-serif text-sm font-bold text-[#8B4513] flex items-center gap-1.5 mb-3.5\">\n                      \360\237\223\205 Configure Heritage Wear Rent Range\n                    </h5>\n                    <p className=\"text-[11px] text-[#8B4513]/85 mb-4 font-light\">\n                      At least one clothing or jewelry product is selected to rent. Pick your starting date and period. Daily rentals include fully dry-cleaned garments.\n                    </p>\n                    <div className=\"grid grid-cols-2 gap-4\">\n                      <div>\n                        <label className=\"block text-[10px] font-bold uppercase tracking-wider text-[#8B4513]/60 mb-1\">\n                          Delivery Start Date\n                        </label>\n                        <input\n                          type=\"date\"\n                          value={rentalDate}\n                          min={new Date().toISOString().split(\'T\')[0]}\n                          onChange={(e) => setRentalDate(e.target.value)}\n                          className=\"w-full bg-white border border-[#D9D1C7] rounded-full px-4 py-2.5 text-xs text-[#1A1A1A]\"\n                        />\n                      </div>\n                      <div>\n                        <label className=\"block text-[10px] font-bold uppercase tracking-wider text-[#8B4513]/60 mb-1\">\n                          Rental Length (days)\n                        </label>\n                        <select\n                          value={rentalDays}\n                          onChange={(e) => setRentalDays(Number(e.target.value))}\n                          className=\"w-full bg-white border border-[#D9D1C7] rounded-full px-4 py-2.5 text-xs text-[#1A1A1A]\"\n                        >\n                          <option value=\"3\">3 Days (Ceremony basic)</option>\n                          <option value=\"5\">5 Days (Wedding length)</option>\n                          <option value=\"7\">7 Days (Full week festival)</option>\n                          <option value=\"14\">14 Days (Extended vacation)</option>\n                        </select>\n                      </div>\n                    </div>\n                  </div>\n                )}\n\n                <div className=\"mt-8 flex justify-end\">\n                  <button\n                    type=\"submit\"\n                    className=\"bg-[#BC5449] hover:bg-[#8B4513] text-white text-[10px] uppercase font-bold tracking-widest py-3.5 px-6 rounded-full flex items-center gap-1.5 transition-all outline-none cursor-pointer\"\n                  >\n                    Proceed to Payment Gateway\n                    <ArrowRight className=\"w-4 h-4\" />\n                  </button>\n                </div>"
