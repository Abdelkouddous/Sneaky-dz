    instruction: "Style credit card visuals, fields and authorization trigger button."
    replacement_infos {
      original_chunk {
        target_content: "                {/* Live visual Card layout! */}\n                <div className=\"mb-6\">\n                  <div className={`p-6 rounded-2xl text-white shadow-lg transition-all relative overflow-hidden aspect-[1.8/1] max-w-sm mx-auto ${\n                    paymentType === \'EDAHABIA\'\n                      ? \'bg-gradient-to-tr from-amber-600 via-amber-500 to-yellow-500\'\n                      : paymentType === \'CIB\'\n                      ? \'bg-gradient-to-tr from-indigo-900 to-emerald-700\'\n                      : \'bg-gradient-to-tr from-stone-900 to-stone-850\'\n                  }`}>\n                    {/* Metallic card chip */}\n                    <div className=\"w-10 h-8 bg-yellow-400/80 rounded-sm mb-6 border border-yellow-300\"></div>\n\n                    {/* Logo overlays based on type */}\n                    {paymentType === \'EDAHABIA\' && (\n                      <span className=\"absolute top-6 right-6 font-serif font-extrabold italic text-sm tracking-wide bg-stone-950/20 px-3 py-1 rounded\">\n                        Alg\303\251rie Poste \342\200\242 \330\247\331\204\330\260\331\207\330\250\331\212\330\251\n                      </span>\n                    )}\n                    {paymentType === \'CIB\' && (\n                      <span className=\"absolute top-6 right-6 font-sans font-extrabold text-sm tracking-wide bg-stone-50/15 px-3 py-1 rounded\">\n                        CIB SATIM\n                      </span>\n                    )}\n                    {paymentType === \'VISA_MC\' && (\n                      <span className=\"absolute top-6 right-6 font-mono font-bold text-xs tracking-wide border border-white/20 px-3 py-1 rounded\">\n                        INTERNATIONAL CARD\n                      </span>\n                    )}\n\n                    {/* Live values */}\n                    <div className=\"font-mono text-lg md:text-xl font-bold tracking-[0.2em] mb-4 text-center\">\n                      {cardNumber || \'\342\200\242\342\200\242\342\200\242\342\200\242 \342\200\242\342\200\242\342\200\242\342\200\242 \342\200\242\342\200\242\342\200\242\342\200\242 \342\200\242\342\200\242\342\200\242\342\200\242\'}\n                    </div>\n\n                    <div className=\"flex justify-between items-end mt-4\">\n                      <div>\n                        <span className=\"text-[9px] text-white/60 block uppercase tracking-wider\">Card Holder</span>\n                        <span className=\"font-semibold text-sm h-5 block uppercase font-mono tracking-wide\">\n                          {cardHolder || \'Your Name\'}\n                        </span>\n                      </div>\n                      <div>\n                        <span className=\"text-[9px] text-white/60 block uppercase tracking-wider\">Expires</span>\n                        <span className=\"font-mono text-sm h-5 block\">\n                          {cardExpiry || \'MM/YY\'}\n                        </span>\n                      </div>\n                    </div>\n                  </div>\n                </div>\n\n                {/* Numeric Card Forms */}\n                <div className=\"space-y-4\">\n                  <div>\n                    <label className=\"block text-[11px] font-semibold uppercase tracking-wider text-stone-400 mb-1\">\n                      {paymentType === \'EDAHABIA\' ? \'16-Digit Gold Card Number\' : paymentType === \'CIB\' ? \'16-Digit CIB Card Code\' : \'Credit Card Number\'}\n                    </label>\n                    <input\n                      type=\"text\"\n                      required\n                      placeholder=\"e.g., 5220 1234 5678 9012\"\n                      value={cardNumber}\n                      onChange={(e) => handleCardNumberChange(e.target.value)}\n                      className=\"w-full bg-stone-50 border border-stone-200 rounded-xl px-4 py-2.5 text-xs focus:outline-none focus:border-amber-600 font-mono text-stone-850\"\n                    />\n                  </div>\n\n                  <div>\n                    <label className=\"block text-[11px] font-semibold uppercase tracking-wider text-stone-400 mb-1\">\n                      Card Holder Name (Exact Name on Card)\n                    </label>\n                    <input\n                      type=\"text\"\n                      required\n                      placeholder=\"e.g., SLIMANE BENCHERIF\"\n                      value={cardHolder}\n                      onChange={(e) => setCardHolder(e.target.value)}\n                      className=\"w-full bg-stone-50 border border-stone-200 rounded-xl px-4 py-2.5 text-xs focus:outline-none focus:border-amber-600 font-mono text-stone-850 uppercase\"\n                    />\n                  </div>\n\n                  <div className=\"grid grid-cols-2 gap-4\">\n                    <div>\n                      <label className=\"block text-[11px] font-semibold uppercase tracking-wider text-stone-400 mb-1\">\n                        Expiry Date\n                      </label>\n                      <input\n                        type=\"text\"\n                        required\n                        placeholder=\"MM/YY\"\n                        value={cardExpiry}\n                        onChange={(e) => handleExpiryChange(e.target.value)}\n                        className=\"w-full bg-stone-50 border border-stone-200 rounded-xl px-4 py-2.5 text-xs focus:outline-none focus:border-amber-600 font-mono text-stone-850\"\n                      />\n                    </div>\n                    <div>\n                      <label className=\"block text-[11px] font-semibold uppercase tracking-wider text-stone-400 mb-1\">\n                        Security PIN / CVV\n                      </label>\n                      <input\n                        type=\"password\"\n                        required\n                        maxLength={4}\n                        placeholder=\"\342\200\242\342\200\242\342\200\242\"\n                        value={cardCVV}\n                        onChange={(e) => setCardCVV(e.target.value.replace(/\\D/g, \'\'))}\n                        className=\"w-full bg-stone-50 border border-stone-200 rounded-xl px-4 py-2.5 text-xs focus:outline-none focus:border-amber-600 font-mono text-stone-850\"\n                      />\n                    </div>\n                  </div>\n                </div>\n\n                <div className=\"mt-8 flex justify-between\">\n                  <button\n                    type=\"button\"\n                    onClick={() => {\n                      setStep(\'details\');\n                      setErrorMessage(\'\');\n                    }}\n                    className=\"border border-stone-300 font-bold text-xs px-5 py-3 rounded-xl text-stone-600 hover:bg-stone-50 transition-all cursor-pointer\"\n                  >\n                    Back to Shipping\n                  </button>\n                  <button\n                    type=\"submit\"\n                    className=\"bg-emerald-700 hover:bg-emerald-800 text-white font-bold text-xs tracking-wider py-3 px-6 rounded-xl flex items-center gap-2 transition-all outline-none cursor-pointer\"\n                  >\n                    <ShieldCheck className=\"w-4 h-4 text-emerald-300\" />\n                    Authorize payment {formatDZD(getGrandTotal())}\n                  </button>\n                </div>"
        replacement_content: "                {/* Live visual Card layout! */}\n                <div className=\"mb-6\">\n                  <div className={`p-6 rounded-[28px] text-white shadow-xl transition-all relative overflow-hidden aspect-[1.8/1] max-w-sm mx-auto border border-[#D9D1C7]/15 ${\n                    paymentType === \'EDAHABIA\'\n                      ? \'bg-gradient-to-tr from-amber-600 via-amber-500 to-yellow-500\'\n                      : paymentType === \'CIB\'\n                      ? \'bg-gradient-to-tr from-[#2D2D2D] to-emerald-800\'\n                      : \'bg-gradient-to-tr from-[#1A1A1A] to-stone-800\'\n                  }`}>\n                    {/* Metallic card chip */}\n                    <div className=\"w-10 h-8 bg-yellow-400/80 rounded-sm mb-6 border border-yellow-300\"></div>\n\n                    {/* Logo overlays based on type */}\n                    {paymentType === \'EDAHABIA\' && (\n                      <span className=\"absolute top-6 right-6 font-serif font-extrabold italic text-xs tracking-wide bg-stone-950/20 px-3 py-1 rounded\">\n                        BaridiMob \342\200\242 \330\247\331\204\330\260\331\207\330\250\331\212\330\251\n                      </span>\n                    )}\n                    {paymentType === \'CIB\' && (\n                      <span className=\"absolute top-6 right-6 font-sans font-extrabold text-xs tracking-wide bg-stone-50/15 px-3 py-1 rounded\">\n                        CIB SATIM\n                      </span>\n                    )}\n                    {paymentType === \'VISA_MC\' && (\n                      <span className=\"absolute top-6 right-6 font-mono font-bold text-[9px] tracking-wide border border-white/20 px-3 py-1 rounded\">\n                        VISA / MC\n                      </span>\n                    )}\n\n                    {/* Live values */}\n                    <div className=\"font-mono text-base md:text-lg font-bold tracking-[0.2em] mb-4 text-center text-[#FAF8F5]\">\n                      {cardNumber || \'\342\200\242\342\200\242\342\200\242\342\200\242 \342\200\242\342\200\242\342\200\242\342\200\242 \342\200\242\342\200\242\342\200\242\342\200\242 \342\200\242\342\200\242\342\200\242\342\200\242\'}\n                    </div>\n\n                    <div className=\"flex justify-between items-end mt-4\">\n                      <div>\n                        <span className=\"text-[8px] text-white/50 block uppercase tracking-wider\">Card Holder</span>\n                        <span className=\"font-semibold text-[11px] h-5 block uppercase font-mono tracking-wide text-white\">\n                          {cardHolder || \'Your Name\'}\n                        </span>\n                      </div>\n                      <div>\n                        <span className=\"text-[8px] text-white/50 block uppercase tracking-wider\">Expires</span>\n                        <span className=\"font-mono text-[11px] h-5 block text-white\">\n                          {cardExpiry || \'MM/YY\'}\n                        </span>\n                      </div>\n                    </div>\n                  </div>\n                </div>\n\n                {/* Numeric Card Forms */}\n                <div className=\"space-y-4\">\n                  <div>\n                    <label className=\"block text-[10px] font-bold uppercase tracking-wider text-[#8B4513]/70 mb-1\">\n                      {paymentType === \'EDAHABIA\' ? \'16-Digit Gold Card Number\' : paymentType === \'CIB\' ? \'16-Digit CIB Card Code\' : \'Credit Card Number\'}\n                    </label>\n                    <input\n                      type=\"text\"\n                      required\n                      placeholder=\"e.g., 5220 1234 5678 9012\"\n                      value={cardNumber}\n                      onChange={(e) => handleCardNumberChange(e.target.value)}\n                      className=\"w-full bg-white border border-[#D9D1C7] rounded-full px-5 py-3 text-xs focus:outline-none focus:border-[#BC5449] font-mono text-[#1A1A1A] transition-all\"\n                    />\n                  </div>\n\n                  <div>\n                    <label className=\"block text-[10px] font-bold uppercase tracking-wider text-[#8B4513]/70 mb-1\">\n                      Card Holder Name (Exact Name on Card)\n                    </label>\n                    <input\n                      type=\"text\"\n                      required\n                      placeholder=\"e.g., SLIMANE BENCHERIF\"\n                      value={cardHolder}\n                      onChange={(e) => setCardHolder(e.target.value)}\n                      className=\"w-full bg-white border border-[#D9D1C7] rounded-full px-5 py-3 text-xs focus:outline-none focus:border-[#BC5449] font-mono text-[#1A1A1A] transition-all uppercase\"\n                    />\n                  </div>\n\n                  <div className=\"grid grid-cols-2 gap-4\">\n                    <div>\n                      <label className=\"block text-[10px] font-bold uppercase tracking-wider text-[#8B4513]/70 mb-1\">\n                        Expiry Date\n                      </label>\n                      <input\n                        type=\"text\"\n                        required\n                        placeholder=\"MM/YY\"\n                        value={cardExpiry}\n                        onChange={(e) => handleExpiryChange(e.target.value)}\n                        className=\"w-full bg-white border border-[#D9D1C7] rounded-full px-5 py-3 text-xs focus:outline-none focus:border-[#BC5449] font-mono text-[#1A1A1A] transition-all\"\n                      />\n                    </div>\n                    <div>\n                      <label className=\"block text-[10px] font-bold uppercase tracking-wider text-[#8B4513]/70 mb-1\">\n                        Security PIN / CVV\n                      </label>\n                      <input\n                        type=\"password\"\n                        required\n                        maxLength={4}\n                        placeholder=\"\342\200\242\342\200\242\342\200\242\"\n                        value={cardCVV}\n                        onChange={(e) => setCardCVV(e.target.value.replace(/\\D/g, \'\'))}\n                        className=\"w-full bg-white border border-[#D9D1C7] rounded-full px-5 py-3 text-xs focus:outline-none focus:border-[#BC5449] font-mono text-[#1A1A1A] transition-all\"\n                      />\n                    </div>\n                  </div>\n                </div>\n\n                <div className=\"mt-8 flex justify-between\">\n                  <button\n                    type=\"button\"\n                    onClick={() => {\n                      setStep(\'details\');\n                      setErrorMessage(\'\');\n                    }}\n                    className=\"border border-[#D9D1C7] text-[#8B4513] hover:bg-[#F1EDE8] font-bold text-[10px] uppercase tracking-wider px-5 py-3 rounded-full transition-all cursor-pointer\"\n                  >\n                    Back to Shipping\n                  </button>\n                  <button\n                    type=\"submit\"\n                    className=\"bg-emerald-700 hover:bg-emerald-800 text-white font-bold text-[10px] uppercase tracking-wider py-3.5 px-6 rounded-full flex items-center gap-2 transition-all outline-none cursor-pointer\"\n                  >\n                    <ShieldCheck className=\"w-4 h-4 text-emerald-300\" />\n                    Authorize payment {formatDZD(getGrandTotal())}\n                  </button>\n                </div>"
      }
      num_matches: 1
    }
  }
}
